# Copy this file to ".env" and fill in your real values. Never commit .env.
# (.env is loaded automatically via `node --env-file=.env ...`)

# Your Resend API key (Settings > API Keys in the Resend dashboard)
RESEND_API_KEY=re_your_key_here

# The two audience IDs from Resend (Audiences tab — one per list)
RESEND_SEGMENT_ID_WEEKLY=your_vicfix_weekly_audience_id
RESEND_SEGMENT_ID_MONTHLY=your_djvic_monthly_audience_id

# The AFTER DARK sheet, published to web as CSV
# (Google Sheets > File > Share > Publish to web > CSV)
AFTERDARK_CSV_URL=https://docs.google.com/spreadsheets/d/e/XXXX/pub?output=csv

# Your blog RSS feed (live once rss.xml.js is deployed)
BLOG_RSS_URL=https://djvicofficial.com/rss.xml
