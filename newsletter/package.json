{
  "name": "djvic-newsletter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Newsletter send system for DJ VIC (monthly) and The Vic Fix (weekly), via Resend.",
  "scripts": {
    "weekly": "node --env-file=.env send-newsletter.mjs",
    "weekly:send": "node --env-file=.env send-newsletter.mjs --send",
    "monthly": "node --env-file=.env send-monthly.mjs",
    "monthly:send": "node --env-file=.env send-monthly.mjs --send"
  },
  "dependencies": {
    "resend": "^4.6.0",
    "rss-parser": "^3.13.0",
    "csv-parse": "^5.5.6"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
