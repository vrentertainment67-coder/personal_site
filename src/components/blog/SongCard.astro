---
interface Props {
  number: number;
  title: string;
  film: string;
  note?: string;
}
const { number, title, film, note } = Astro.props;
const num = String(number).padStart(2, '0');
---

<div class="song-card">
  <span class="song-number">{num}</span>
  <div class="song-info">
    <div class="song-title">{title}</div>
    <div class="song-film">{film}</div>
  </div>
  {note && <span class="song-note">{note}</span>}
</div>

<style>
  .song-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    background: #111111;
    border: 1px solid #1E1E1E;
    border-left: 3px solid #C9A84C;
    margin-bottom: 8px;
    border-radius: 2px;
    transition: background 0.2s ease;
  }
  .song-card:hover { background: #161616; }
  .song-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: #C9A84C;
    min-width: 32px;
    line-height: 1;
    opacity: 0.9;
  }
  .song-info { flex: 1; }
  .song-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #E8E8E0;
    letter-spacing: 0.02em;
  }
  .song-film {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 12px;
    color: #8A8878;
    margin-top: 2px;
  }
  .song-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: #C9A84C;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 3px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
</style>
