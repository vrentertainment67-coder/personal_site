---
interface Props {
  heading: string;
  sub: string;
  cta: string;
  href: string;
}
const { heading, sub, cta, href } = Astro.props;
---

<div class="blog-cta">
  <div class="cta-text">
    <div class="cta-heading">{heading}</div>
    <div class="cta-sub">{sub}</div>
  </div>
  <a href={href} class="cta-btn">{cta} →</a>
</div>

<style>
  .blog-cta {
    margin-top: 48px;
    padding: 28px;
    background: linear-gradient(135deg, rgba(201,168,76,0.08) 0%, transparent 100%);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 2px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .cta-heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    color: #E8E8E0;
    letter-spacing: 0.03em;
  }
  .cta-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #8A8878;
    margin-top: 4px;
  }
  .cta-btn {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 0.1em;
    color: #0A0A0A;
    background: #C9A84C;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 2px;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .cta-btn:hover { background: #d4b45a; }
</style>
