---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  aspect?: 'wide' | 'square' | 'tall';
}
const { src, alt, caption, aspect = 'wide' } = Astro.props;

const aspectMap = {
  wide:   'aspect-ratio: 16/7',
  square: 'aspect-ratio: 1/1',
  tall:   'aspect-ratio: 4/5',
};
---

<figure class="blog-image-fig">
  <div class="blog-image-wrap" style={aspectMap[aspect]}>
    <img src={src} alt={alt} loading="lazy" decoding="async" />
    <div class="blog-image-overlay"></div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .blog-image-fig {
    margin: 28px 0;
  }
  .blog-image-wrap {
    overflow: hidden;
    border: 1px solid #1E1E1E;
    border-left: 3px solid #C9A84C;
    position: relative;
  }
  .blog-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.82) saturate(0.72) contrast(1.05);
    transition: filter 0.3s ease;
  }
  .blog-image-wrap img:hover {
    filter: brightness(0.92) saturate(0.85) contrast(1.02);
  }
  .blog-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10,10,10,0.25) 0%,
      rgba(10,10,10,0.05) 50%,
      rgba(10,10,10,0.2) 100%
    );
    pointer-events: none;
  }
  figcaption {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 12px;
    color: #8A8878;
    margin-top: 8px;
    padding-left: 4px;
  }
</style>
