---
interface Props { question: string; }
const { question } = Astro.props;
---

<details class="faq-item">
  <summary class="faq-question">
    <span>{question}</span>
    <span class="faq-icon">+</span>
  </summary>
  <div class="faq-answer"><slot /></div>
</details>

<style>
  .faq-item {
    border-bottom: 1px solid #1E1E1E;
  }
  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    cursor: pointer;
    list-style: none;
    gap: 12px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #E8E8E0;
    line-height: 1.5;
    transition: color 0.2s;
  }
  .faq-question:hover { color: #C9A84C; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-icon {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: #C9A84C;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  details[open] .faq-icon { transform: rotate(45deg); }
  details[open] .faq-question { color: #C9A84C; }
  .faq-answer {
    padding: 0 0 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #8A8878;
    line-height: 1.8;
  }
</style>
