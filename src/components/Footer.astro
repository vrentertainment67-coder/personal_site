---
import EmailCapture from './EmailCapture.jsx';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer>
  <div class="footer-news">
    <div class="footer-news-copy">
      <span class="footer-news-eyebrow">Newsletter</span>
      <h2 class="footer-news-title">On the list</h2>
      <p class="footer-news-sub">New mixes, VIC Fix episodes &amp; event drops — straight to your inbox. No spam, unsubscribe anytime.</p>
    </div>
    <div class="footer-news-form">
      <EmailCapture client:visible source="footer" cta="Join" />
    </div>
  </div>

  <div class="footer-inner">

    <div class="footer-brand">
      <a href={`${base}/`} class="footer-logo">
        <img
          src={`${base}/images/logo.png`}
          alt="DJ VIC"
          width="594"
          height="263"
          loading="lazy"
        />
      </a>
      <p class="footer-bio">International DJ &amp; Producer<br/>based in Bangalore, India.</p>
    </div>

    <nav class="footer-nav" aria-label="Services">
      <span class="footer-nav-heading">Services</span>
      <a href={`${base}/weddings/`}>Weddings</a>
      <a href={`${base}/corporate/`}>Corporate</a>
      <a href={`${base}/sangeet/`}>Sangeet Night</a>
      <a href={`${base}/private-events/`}>Private Events</a>
      <a href={`${base}/nightlife/`}>Club &amp; Nightlife</a>
      <a href={`${base}/festivals/`}>Festivals</a>
    </nav>

    <nav class="footer-nav" aria-label="Explore">
      <span class="footer-nav-heading">Explore</span>
      <a href={`${base}/events/`}>Events</a>
      <a href={`${base}/blog/`}>Blog</a>
      <a href={`${base}/private-sessions/`}>Private Sessions</a>
      <a href={`${base}/thevicfix/`}>The VIC Fix</a>
      <a href={`${base}/remixes/`}>Remixes</a>
      <a href={`${base}/photos/`}>Gallery</a>
      <a href={`${base}/book/`}>Book DJ VIC</a>
      <a href={`${base}/book/`}>Contact</a>
      <a href="https://linktr.ee/djvicofficial" target="_blank" rel="noopener noreferrer">Press Kit</a>
    </nav>

    <div class="footer-social-col">
      <a href="https://instagram.djvicofficial.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Instagram
      </a>
      <a href="https://www.youtube.com/@thedjvicofficial" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
        </svg>
        YouTube
      </a>
      <a href="https://www.facebook.com/djvicofficial" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Facebook
      </a>
      <a href="https://wa.me/919611711677" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.004 0C5.374 0 0 5.373 0 12c0 2.139.561 4.14 1.538 5.878L0 24l6.305-1.511A11.95 11.95 0 0 0 12.004 24C18.63 24 24 18.627 24 12c0-6.628-5.371-12-11.996-12z"/>
        </svg>
        WhatsApp
      </a>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; {year} DJ VIC. All rights reserved.</p>
    <a href="mailto:bookings@djvicofficial.com" class="footer-email">
      bookings@djvicofficial.com
    </a>
  </div>
</footer>

<style>
  .footer-news {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    border-bottom: 1px solid rgba(201, 168, 76, 0.12);
  }
  .footer-news-eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 0.6rem;
  }
  .footer-news-title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    letter-spacing: 0.02em;
    color: #fff;
    margin: 0 0 0.6rem;
  }
  .footer-news-sub {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
    margin: 0;
    max-width: 42ch;
  }
  @media (max-width: 760px) {
    .footer-news {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2.5rem 1.5rem;
      text-align: center;
    }
    .footer-news-sub { margin-inline: auto; }
  }
</style>
