<script>
  // GA4 conversion tracking — survives Astro View Transitions via document-level delegation.
  // gtag.js (G-Z7YFSSWY3H) is loaded in the <head>; this only sends events.
  (function () {
    if (window.__vicAnalyticsBound) return;     // bind once, even if module re-evaluates
    window.__vicAnalyticsBound = true;

    var SB_URL = 'https://jftnhuutttmccmqnnybf.supabase.co';
    var SB_KEY = 'sb_publishable_ysWygc3QGKbfsUd0f7Evzw__98TEoo9';

    function track(name, params) {
      // 1) GA4
      if (typeof window.gtag === 'function') {
        window.gtag('event', name, params || {});
      } else {
        (window.dataLayer = window.dataLayer || []).push(
          Object.assign({ event: name }, params || {})
        );
      }
      // 2) Mirror to our own Supabase (real-time, blocker-proof) — never on Vic's own visits.
      logEvent(name, params || {});
    }

    function logEvent(name, p) {
      try { if (localStorage.getItem('vic_notrack') === '1') return; } catch (e) {}
      try {
        var device = (window.matchMedia && window.matchMedia('(max-width: 768px)').matches) ? 'mobile' : 'desktop';
        fetch(SB_URL + '/rest/v1/events_log', {
          method: 'POST', keepalive: true,
          headers: { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
          body: JSON.stringify({
            name: name,
            location: p.link_location || p.form_location || null,
            event_type: p.event_type || null,
            device: device,
            path: location.pathname
          })
        }).catch(function () {});
      } catch (e) {}
    }

    // The booking form submits via fetch (Supabase RPC), so lead tracking is fired
    // from its SUCCESS callback (BookingApp.jsx) — NOT a submit listener — so we only
    // count real, completed submissions. See task step 5.
    window.trackLead = function (eventType, formLocation) {
      track('generate_lead', {
        event_type: eventType || 'unknown',
        form_location: formLocation || 'book_page',
        currency: 'INR'
      });
    };

    function locationOf(el) {
      if (el.dataset && el.dataset.loc) return el.dataset.loc;
      if (el.closest('[data-sticky-cta]')) return 'sticky_bar';
      if (el.closest('footer')) return 'footer';
      if (el.closest('header')) return 'header';
      if (el.closest('form')) return 'book_form';
      return 'body';
    }

    // Outbound + contact link clicks (capture phase so it fires even if other JS stops propagation)
    document.addEventListener('click', function (e) {
      var a = e.target.closest && e.target.closest('a[href]');
      if (!a) return;
      var href = a.getAttribute('href') || '';
      if (href.indexOf('wa.me') !== -1 || href.indexOf('api.whatsapp.com') !== -1) {
        track('whatsapp_click', { link_url: href, link_location: locationOf(a) });
      } else if (href.indexOf('tel:') === 0) {
        track('tel_click', { link_url: href, link_location: locationOf(a) });
      } else if (href.indexOf('mailto:') === 0) {
        track('email_click', { link_url: href, link_location: locationOf(a) });
      }
    }, true);

    // Lead-form tracking is fired from each form's own success handler via
    // window.trackLead(eventType, formLocation) — NOT a submit listener — so we
    // only count completed submissions and stay independent of any form backend.
  })();
</script>
