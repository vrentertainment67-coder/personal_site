---
// ============================================================
// DJ VIC — site search overlay (Pagefind)
// Pagefind builds a static index into /pagefind during `postbuild`.
// The UI assets are lazy-loaded the first time the overlay opens,
// so they cost nothing on normal page loads. Open via any
// [data-search-open] trigger, the "/" key, or Cmd/Ctrl+K.
// (In `astro dev` there is no index yet — the overlay still opens
//  but shows no results; it works on the built/deployed site.)
// ============================================================
---
<div id="search-overlay" class="so" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
  <div class="so-backdrop" data-search-close></div>
  <div class="so-panel">
    <button class="so-close" type="button" aria-label="Close search" data-search-close>&times;</button>
    <div id="pagefind-ui"></div>
    <p class="so-hint">Press <kbd>Esc</kbd> to close</p>
  </div>
</div>

<style>
  .so {
    position: fixed;
    inset: 0;
    z-index: 10002;
    display: none;
    justify-content: center;
    align-items: flex-start;
    padding: 8vh 1rem 2rem;
  }
  .so.is-open { display: flex; }
  .so-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(3, 6, 5, 0.9);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .so-panel {
    position: relative;
    z-index: 1;
    width: min(680px, 100%);
    background: #0c0c0c;
    border: 1px solid rgba(201, 168, 76, 0.25);
    border-radius: 8px;
    padding: 1.75rem 1.5rem 1.25rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }
  .so-close {
    position: absolute;
    top: 0.6rem;
    right: 0.9rem;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.55);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
  }
  .so-close:hover { color: #fff; }
  .so-hint { margin: 0.9rem 0 0; font-size: 0.7rem; color: rgba(255, 255, 255, 0.35); text-align: center; }
  .so-hint kbd {
    background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 3px;
    padding: 1px 6px; font-size: 0.7rem; color: rgba(255,255,255,0.6);
  }

  /* Pagefind UI dark theme overrides */
  #pagefind-ui {
    --pagefind-ui-primary: #c9a84c;
    --pagefind-ui-text: #ffffff;
    --pagefind-ui-background: #0c0c0c;
    --pagefind-ui-border: #2a2a2a;
    --pagefind-ui-tag: #161616;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-font: var(--font-body, 'Space Grotesk', sans-serif);
  }
</style>

<script>
  (function () {
    if (window.__soWired) return;
    window.__soWired = true;

    let loaded = false;
    const overlay = () => document.getElementById('search-overlay');

    function loadAssets() {
      if (loaded) return Promise.resolve();
      loaded = true;
      return new Promise((resolve) => {
        const css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(css);
        const js = document.createElement('script');
        js.src = '/pagefind/pagefind-ui.js';
        js.onload = () => {
          try {
            // eslint-disable-next-line no-undef
            new PagefindUI({ element: '#pagefind-ui', showSubResults: true, showImages: false, resetStyles: false });
          } catch (e) { /* no index in dev */ }
          resolve();
        };
        js.onerror = () => resolve();
        document.body.appendChild(js);
      });
    }

    async function open() {
      const o = overlay();
      if (!o) return;
      await loadAssets();
      o.classList.add('is-open');
      o.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const input = o.querySelector('input');
      if (input) setTimeout(() => input.focus(), 60);
    }

    function close() {
      const o = overlay();
      if (!o || !o.classList.contains('is-open')) return;
      o.classList.remove('is-open');
      o.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.addEventListener('click', function (e) {
      if (e.target.closest && e.target.closest('[data-search-open]')) { e.preventDefault(); open(); return; }
      if (e.target.closest && e.target.closest('[data-search-close]')) { e.preventDefault(); close(); }
    });

    document.addEventListener('keydown', function (e) {
      const o = overlay();
      const isOpen = o && o.classList.contains('is-open');
      if (e.key === 'Escape' && isOpen) { close(); return; }
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); open(); return; }
      // "/" opens search when not typing in a field
      if (e.key === '/' && !isOpen) {
        const t = e.target;
        const typing = t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable);
        if (!typing) { e.preventDefault(); open(); }
        return;
      }
      // Focus trap while open
      if (e.key === 'Tab' && isOpen) {
        const f = o.querySelectorAll('button, [href], input, [tabindex]:not([tabindex="-1"])');
        const visible = Array.prototype.filter.call(f, (el) => el.offsetParent !== null);
        if (!visible.length) return;
        const first = visible[0];
        const last = visible[visible.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    document.addEventListener('astro:before-swap', close);
  })();
</script>
