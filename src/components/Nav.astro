---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const is = (path: string) => pathname === base + path || pathname === base + path + '/';
const startsWith = (path: string) => pathname.startsWith(base + path);
---

<header>
  <nav>
    <a href={`${base}/`} class="logo">
      <img
        src="https://hosting.renderforestsites.com/19480377/1066059/media/a492fd01e8532f473aa84075c5a1f840.png"
        alt="DJ VIC"
      />
    </a>
    <ul>
      <li><a href={`${base}/#about`} class:list={[{ active: is('/') }]}>About</a></li>
      <li><a href={`${base}/weddings/`} aria-current={startsWith('/weddings') ? 'page' : undefined}>Weddings</a></li>
      <li><a href={`${base}/corporate/`} aria-current={startsWith('/corporate') ? 'page' : undefined}>Corporate</a></li>
      <li><a href={`${base}/thevicfix/`} aria-current={startsWith('/thevicfix') ? 'page' : undefined}>The VIC Fix</a></li>
      <li><a href={`${base}/remixes/`} aria-current={startsWith('/remixes') ? 'page' : undefined}>Remixes</a></li>
      <li><a href={`${base}/photos/`} aria-current={startsWith('/photos') ? 'page' : undefined}>Photos</a></li>
    </ul>
    <a href={`${base}/#contact`} class="nav-phone">Contact</a>
  </nav>
</header>
