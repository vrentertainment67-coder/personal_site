---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const is = (path: string) => pathname === base + path || pathname === base + path + '/';
const startsWith = (path: string) => pathname.startsWith(base + path);

const services = [
  { href: `${base}/weddings/`, label: 'Weddings' },
  { href: `${base}/corporate/`, label: 'Corporate' },
  { href: `${base}/sangeet/`, label: 'Sangeet Night' },
  { href: `${base}/private-events/`, label: 'Private Events' },
  { href: `${base}/nightlife/`, label: 'Club & Nightlife' },
  { href: `${base}/festivals/`, label: 'Festivals' },
];

const isServices = startsWith('/weddings') || startsWith('/corporate') || startsWith('/sangeet') || startsWith('/private-events') || startsWith('/nightlife') || startsWith('/festivals');
---

<header id="site-header">
  <nav>
    <a href={`${base}/`} class="logo">
      <img
        src={`${base}/images/logo.png`}
        alt="DJ VIC"
        width="594"
        height="263"
      />
    </a>

    <!-- Desktop nav links -->
    <ul>
      <li><a href={`${base}/#about`} class:list={[{ active: is('/') }]}>About</a></li>
      <li class="has-dropdown">
        <button
          class:list={['dropdown-trigger', { active: isServices }]}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Work <span class="chevron" aria-hidden="true">&#8964;</span>
        </button>
        <ul class="dropdown">
          {services.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={startsWith(href.replace(base, '').replace(/\/$/, '')) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </li>
      <li><a href={`${base}/thevicfix/`} aria-current={startsWith('/thevicfix') ? 'page' : undefined}>The VIC Fix</a></li>
      <li><a href={`${base}/remixes/`} aria-current={startsWith('/remixes') ? 'page' : undefined}>Remixes</a></li>
      <li><a href={`${base}/photos/`} aria-current={startsWith('/photos') ? 'page' : undefined}>Gallery</a></li>
      <li><a href={`${base}/blog/`} aria-current={startsWith('/blog') ? 'page' : undefined}>Blog</a></li>
    </ul>

    <button class="nav-search-btn" type="button" data-search-open aria-label="Search the site">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>

    <a href={`${base}/book/`} class="nav-book-btn magnetic" data-mag="0.25">Book VIC</a>

    <!-- Hamburger button — mobile only -->
    <button
      class="nav-hamburger"
      id="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>
</header>

<!-- Mobile full-screen menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <button class="mobile-menu-close" id="mobile-menu-close" aria-label="Close navigation menu">
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
  <nav class="mobile-nav">
    <a href={`${base}/about/`} aria-current={startsWith('/about') ? 'page' : undefined}>About</a>
    <a href={`${base}/weddings/`} aria-current={startsWith('/weddings') ? 'page' : undefined}>Weddings</a>
    <a href={`${base}/corporate/`} aria-current={startsWith('/corporate') ? 'page' : undefined}>Corporate</a>
    <a href={`${base}/nightlife/`} aria-current={startsWith('/nightlife') ? 'page' : undefined}>Club &amp; Nightlife</a>
    <a href={`${base}/thevicfix/`} aria-current={startsWith('/thevicfix') ? 'page' : undefined}>The VIC Fix</a>
    <a href={`${base}/remixes/`} aria-current={startsWith('/remixes') ? 'page' : undefined}>Remixes</a>
    <a href={`${base}/photos/`} aria-current={startsWith('/photos') ? 'page' : undefined}>Gallery</a>
    <a href={`${base}/blog/`} aria-current={startsWith('/blog') ? 'page' : undefined}>Blog</a>
    <button type="button" class="mobile-search" data-search-open>Search ⌕</button>
    <a href={`${base}/book/`} class="mobile-cta">Book VIC</a>
  </nav>
</div>

<script>
  // ── Helpers ────────────────────────────────────────────────────────────

  function closeAllDropdowns() {
    document.querySelectorAll('.has-dropdown.open').forEach((el) => {
      el.classList.remove('open');
      (el.querySelector('.dropdown-trigger') as HTMLElement)
        ?.setAttribute('aria-expanded', 'false');
    });
  }

  function openMenu() {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const mobileMenu   = document.getElementById('mobile-menu');
    mobileMenu?.classList.add('is-open');
    hamburgerBtn?.classList.add('is-open');
    hamburgerBtn?.setAttribute('aria-expanded', 'true');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const mobileMenu   = document.getElementById('mobile-menu');
    mobileMenu?.classList.remove('is-open');
    hamburgerBtn?.classList.remove('is-open');
    hamburgerBtn?.setAttribute('aria-expanded', 'false');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // ── Global listeners — added once at module load ──────────────────────

  document.addEventListener('click', closeAllDropdowns);

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    closeAllDropdowns();
    if (document.getElementById('mobile-menu')?.classList.contains('is-open')) closeMenu();
  });

  // ── Setup: re-runs after every navigation ──────────────────────────────
  // Guard flags (data-dd-init, data-menu-init, data-nav-init) prevent the
  // same DOM element from accumulating duplicate listeners across navigations.

  let cleanupScroll: (() => void) | null = null;

  function setup() {
    // Sticky header — cancel previous scroll listener, bind to fresh element
    if (cleanupScroll) cleanupScroll();
    const header = document.getElementById('site-header');
    if (header) {
      const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 60);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      cleanupScroll = () => window.removeEventListener('scroll', onScroll);
    }

    // Desktop dropdown buttons — bind only if not already initialised
    document.querySelectorAll<HTMLElement>('.dropdown-trigger:not([data-dd-init])').forEach((btn) => {
      btn.setAttribute('data-dd-init', '1');
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const li = btn.closest('.has-dropdown');
        const isOpen = li?.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen) li?.classList.add('open');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    // Hamburger — bind only if not already initialised
    const hamburgerBtn = document.getElementById('hamburger-btn');
    if (hamburgerBtn && !hamburgerBtn.dataset.menuInit) {
      hamburgerBtn.dataset.menuInit = '1';
      hamburgerBtn.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.contains('is-open')
          ? closeMenu()
          : openMenu();
      });
    }

    // Close button — bind only if not already initialised
    const closeMobBtn = document.getElementById('mobile-menu-close');
    if (closeMobBtn && !closeMobBtn.dataset.menuInit) {
      closeMobBtn.dataset.menuInit = '1';
      closeMobBtn.addEventListener('click', closeMenu);
    }

    // Mobile nav links — bind only if not already initialised
    document.querySelectorAll<HTMLAnchorElement>('.mobile-nav a:not([data-nav-init])').forEach((link) => {
      link.setAttribute('data-nav-init', '1');
      link.addEventListener('click', closeMenu);
    });
  }

  // Run on initial page load, then after every View Transition navigation
  setup();
  document.addEventListener('astro:page-load', setup);
</script>

<style is:global>
  /* ── Header scroll behaviour ──────────────────────────────────────── */
  #site-header {
    background: transparent !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    border-bottom: 1px solid transparent !important;
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
  }

  #site-header.scrolled {
    background: rgba(6,6,6,0.97) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    border-bottom-color: rgba(201,168,76,0.12) !important;
  }

  /* ── "Book VIC" desktop button ────────────────────────────────────── */
  .nav-search-btn {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .nav-search-btn:hover {
    color: var(--gold);
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(201, 168, 76, 0.08);
  }

  .nav-book-btn {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #060606 !important;
    background: var(--gold);
    padding: 0.4rem 1.2rem;
    text-decoration: none;
    white-space: nowrap;
    margin-left: 0.9rem;
    transition: background 0.2s, color 0.2s;
    border: none;
  }

  .nav-book-btn:hover {
    background: var(--gold-light) !important;
    color: #060606 !important;
  }

  /* ── Hamburger button ─────────────────────────────────────────────── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    flex-shrink: 0;
  }

  .nav-hamburger .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: #e0dccf;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Hamburger → X when open */
  .nav-hamburger.is-open .bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .nav-hamburger.is-open .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger.is-open .bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ── Mobile breakpoint ───────────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Show hamburger */
    .nav-hamburger {
      display: flex;
    }

    /* Hide desktop links, search, and Book VIC button */
    header nav ul,
    .nav-search-btn,
    .nav-book-btn {
      display: none !important;
    }
  }

  /* ── Mobile full-screen menu ─────────────────────────────────────── */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: #060606;
    z-index: 999;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    overflow-y: auto;
  }

  .mobile-menu.is-open {
    display: flex;
    animation: mobileMenuIn 0.25s ease;
  }

  @keyframes mobileMenuIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Close (×) button inside mobile menu */
  .mobile-menu-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 28px;
    height: 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .mobile-menu-close .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: #e0dccf;
    border-radius: 2px;
  }

  .mobile-menu-close .bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .mobile-menu-close .bar:nth-child(2) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* Nav links inside mobile menu */
  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: 100%;
    max-width: 320px;
  }

  .mobile-nav a {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    letter-spacing: 0.06em;
    color: #e0dccf;
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1;
    text-align: center;
  }

  .mobile-nav a:hover,
  .mobile-nav a[aria-current='page'] {
    color: #c9a84c;
  }

  .mobile-nav .mobile-search {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    letter-spacing: 0.06em;
    color: #e0dccf;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s ease;
  }
  .mobile-nav .mobile-search:hover { color: #c9a84c; }

  .mobile-nav .mobile-cta {
    margin-top: 16px;
    color: #060606;
    background: #c9a84c;
    padding: 12px 40px;
    border-radius: 2px;
    font-size: 26px;
    transition: background 0.2s ease;
  }

  .mobile-nav .mobile-cta:hover {
    background: #b8923e;
    color: #060606;
  }
</style>

<style>
  /* ── Desktop dropdown trigger ─────────────────────────────────────── */
  .dropdown-trigger {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3em;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .dropdown-trigger:hover,
  .dropdown-trigger.active {
    color: var(--white);
  }

  .chevron {
    font-size: 0.8em;
    transition: transform 0.2s;
    display: inline-block;
  }

  .has-dropdown.open .chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown panel ───────────────────────────────────────────────── */
  .has-dropdown {
    position: relative;
    display: flex;
    align-items: center;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%);
    background: #0d0d0d;
    border: 1px solid rgba(201,168,76,0.18);
    min-width: 180px;
    z-index: 200;
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
    flex-direction: column;
  }

  .has-dropdown.open .dropdown {
    display: flex;
  }

  .dropdown li { margin: 0; padding: 0; }

  .dropdown a {
    display: block;
    padding: 0.6rem 1.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
  }

  .dropdown a:hover,
  .dropdown a[aria-current='page'] {
    color: var(--gold);
    background: rgba(201,168,76,0.06);
  }
</style>
