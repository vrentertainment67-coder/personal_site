---
const { pathname } = Astro.url;
const is = (path: string) => pathname === path || pathname === path + '/';
const startsWith = (path: string) => pathname.startsWith(path);
---

<header>
  <nav>
    <a href="/" class="logo">
      <img
        src="https://hosting.renderforestsites.com/19480377/1066059/media/a492fd01e8532f473aa84075c5a1f840.png"
        alt="DJ VIC"
      />
    </a>
    <ul>
      <li><a href="/#about" class:list={[{ active: is('/') }]}>About</a></li>
      <li><a href="/weddings/" aria-current={startsWith('/weddings') ? 'page' : undefined}>Weddings</a></li>
      <li><a href="/corporate/" aria-current={startsWith('/corporate') ? 'page' : undefined}>Corporate</a></li>
      <li><a href="/thevicfix/" aria-current={startsWith('/thevicfix') ? 'page' : undefined}>The VIC Fix</a></li>
      <li><a href="/remixes/" aria-current={startsWith('/remixes') ? 'page' : undefined}>Remixes</a></li>
      <li><a href="/photos/" aria-current={startsWith('/photos') ? 'page' : undefined}>Photos</a></li>
    </ul>
    <a href="/#contact" class="nav-phone">Contact</a>
  </nav>
</header>
