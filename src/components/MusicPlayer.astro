    { slug: 'kesariya-cant-stop-the-feeling',        yt: 'KWUoJJ6xsfk', title: "Kesariya × Can't Stop The Feeling" },
    { slug: 'oo-antava-afro-mashup',                 yt: 'rcGuVSoki6U', title: 'Oo Antava (Afro Mashup)' },
