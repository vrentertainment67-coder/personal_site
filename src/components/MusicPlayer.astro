---
// Persistent music player — fixed bottom bar, survives page navigation via ViewTransitions
// Listens for `play-track` custom events dispatched by track card play buttons
---

<div id="vic-player" transition:persist="vic-player" role="region" aria-label="Music player">
  <img id="vp-cover" src="" alt="" width="72" height="72" />

  <div id="vp-info">
    <span class="vp-label">NOW PLAYING</span>
    <span id="vp-title" class="vp-track-title"></span>
  </div>

  <div id="vp-controls">
    <button id="vp-prev" class="vp-btn" aria-label="Previous track" title="Previous">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
      </svg>
    </button>
    <button id="vp-play" class="vp-btn vp-btn--play" aria-label="Play">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </button>
    <button id="vp-next" class="vp-btn" aria-label="Next track" title="Next">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6 18l8.5-6L6 6v12zm2-12h2v12h-2z"/>
      </svg>
    </button>
  </div>

  <div id="vp-wave-area">
    <div id="vp-waveform"></div>
    <div id="vp-times">
      <span id="vp-cur">0:00</span>
      <span class="vp-sep">/</span>
      <span id="vp-dur">0:00</span>
    </div>
  </div>

  <button id="vp-close" class="vp-btn vp-btn--close" aria-label="Close player" title="Close">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
    </svg>
  </button>
</div>

<style>
  #vic-player {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 72px;
    background: #0a0a0a;
    border-top: 1px solid rgba(201, 168, 76, 0.2);
    z-index: 9998;
    align-items: center;
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.6);
  }

  #vic-player.vp--visible {
    display: flex;
  }

  /* Cover */
  #vp-cover {
    width: 72px;
    height: 72px;
    object-fit: cover;
    flex-shrink: 0;
    background: #111;
  }

  /* Info */
  #vp-info {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    padding: 0 1rem;
    width: 190px;
    flex-shrink: 0;
    min-width: 0;
  }

  .vp-label {
    font-size: 0.48rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(201, 168, 76, 0.6);
    text-transform: uppercase;
  }

  .vp-track-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  /* Controls */
  #vp-controls {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    flex-shrink: 0;
    padding: 0 0.5rem;
  }

  .vp-btn {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem;
    border-radius: 50%;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
    flex-shrink: 0;
  }

  .vp-btn:hover {
    color: #c9a84c;
    background: rgba(201, 168, 76, 0.1);
  }

  .vp-btn--play {
    background: rgba(201, 168, 76, 0.14);
    color: #c9a84c;
    width: 42px;
    height: 42px;
    padding: 0;
    margin: 0 0.15rem;
  }

  .vp-btn--play:hover {
    background: rgba(201, 168, 76, 0.26);
    color: #d4b060;
  }

  .vp-btn--close {
    margin: 0 0.75rem 0 0.5rem;
    opacity: 0.35;
    flex-shrink: 0;
  }

  .vp-btn--close:hover {
    opacity: 1;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.07);
  }

  /* Waveform area */
  #vp-wave-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0 0.75rem 0 0.5rem;
    min-width: 0;
    overflow: hidden;
  }

  #vp-waveform {
    height: 42px;
    min-width: 0;
    cursor: pointer;
  }

  #vp-times {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.58rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.3);
  }

  .vp-sep {
    color: rgba(255, 255, 255, 0.15);
  }

  /* Mobile */
  @media (max-width: 640px) {
    #vp-info {
      width: auto;
      flex: 1;
      padding: 0 0.75rem;
    }

    #vp-wave-area {
      display: none;
    }

    #vp-controls {
      padding: 0 0.35rem;
    }

    .vp-btn--close {
      margin-right: 0.5rem;
    }
  }

  @media (max-width: 400px) {
    #vp-cover {
      width: 56px;
      height: 56px;
    }
  }
</style>

<style is:global>
  body.has-player {
    padding-bottom: 72px;
  }

  @keyframes vp-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script is:inline>
