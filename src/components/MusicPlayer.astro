    { slug: 'tamma-tamma-makeba',                    yt: '5oA311R6Wkg', title: 'Tamma Tamma × Makeba' },
    { slug: 'jimmy-disco-edit',                      yt: 'PxgvwE1nZmw', title: 'Jimmy (VIC Disco Edit)' },
    { slug: 'ghungroo-sun-n-sand-rework',            yt: '4oTBe25wvE0', title: 'Ghungroo (Sun n Sand Rework)' },
    // Matched to Supabase files by filename word-match
    { slug: 'besharam-rang-mwaki',              yt: 'Apv1xk-0G8k', title: 'Besharam Rang × Mwaki',               file: 'Besharam Rang X Mwaki - DJ VIC.mp3' },
    { slug: 'softly-still-dre',                 yt: 'hwubhCn8wtQ', title: 'Softly × Still D.R.E.',               file: 'Softly X Still D.R.E.mp3' },
    { slug: 'naina-whistle',                    yt: 'Ci4CtatRRso', title: 'Naina × Whistle',                     file: 'VIC - Naina X Whistle (Mashup).mp3' },
