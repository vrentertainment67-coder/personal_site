    { slug: 'ye-ek-zindagi-afro-edit',          yt: 'gXFxyO7nGdU', title: 'Ye Ek Zindagi (Afro Edit)',           file: 'Yeh Ek Zindagi (Afro Edit) - DJ VIC.mp3' },
    // Uploaded with slug-based filenames
    { slug: 'dil-luteya-desi-mix',              yt: 'aN2BIfUNUs4', title: 'Dil Luteya (Desi Mix)' },
    { slug: 'kahin-aag-lage-tech-mix',          yt: 'gf0hYLxr6eo', title: 'Kahin Aag Lage × Rejection (Tech Mix)' },
    { slug: 'uptown-funk-muqabala',             yt: 'Bw0tMjMYpEw', title: 'Uptown Funk × Muqabala' },
    { slug: 'millionaire-new-thang',            yt: 'gTNbuGHdcuA', title: 'Millionaire × New Thang' },
    { slug: 'malang-sajna-forever-yours',       yt: 'Z1V_1w4i5No', title: 'Malang Sajna × Forever Yours' },
    { slug: 'aaj-ki-raat-progressive-edit',     yt: 'zhaNQwYQi_8', title: 'Aaj Ki Raat (Progressive Edit)' },
    { slug: 'chaleya-all-we-know',              yt: 'rH8DKG2JgO8', title: 'Chaleya × All We Know' },
    { slug: 'kinni-kinni-attention',            yt: 'tfhgPJ8PFXI', title: 'Kinni Kinni × Attention' },
    { slug: 'love-ya-gimme-gimme',              yt: '0z9IQ_qb5tE', title: 'Love Ya × Gimme Gimme' },
    { slug: 'akhiyan-gulab-tech-remix',         yt: 'Fui5ckcHkvA', title: 'Akhiyan Gulab (Tech Remix)' },
    { slug: 'arjan-vailly-we-will-rock-you',    yt: 'T2sSBzyiJ54', title: 'Arjan Vailly × We Will Rock You' },
    { slug: '945-pon-de-replay',                yt: 'xg9jLQYg-9k', title: '9:45 × Pon De Replay' },
    { slug: 'kalaastar-taki-taki',              yt: 'a7D11ICZ8pA', title: 'Kalaastar × Taki Taki' },
    { slug: 'jeene-ke-hain-rasputin',           yt: 'OtG9AWJn9M4', title: 'Jeene Ke Hain × Rasputin' },
    { slug: 'heeriye-belageddu',                yt: '3McvnbaEO24', title: 'Heeriye × Belageddu' },
    { slug: 'dil-of-the-tiger',                 yt: 'AqfAxxu8R4I', title: 'Dil of the Tiger' },
    { slug: 'nashe-si-chadh-gayi-hey-ma',       yt: '6Gz6UfDXZU8', title: 'Nashe Si Chadh Gayi × Hey Ma' },
    { slug: 'bewafa-mad-love',                  yt: 'KhRCbYQev34', title: 'Bewafa × Mad Love' },
    { slug: 'brown-munde-con-calma',            yt: '_4aAA0c72pM', title: 'Brown Munde × Con Calma' },
    { slug: 'jugnu-lover',                      yt: 'EcwD2wU5ov8', title: 'Jugnu × Lover' },
  ];

  var SB_TRACKS = 'https://jftnhuutttmccmqnnybf.supabase.co/storage/v1/object/public/tracks';
  var ws       = null;
  var curIdx   = -1;

  /* ── Helpers ── */
  function $id(id) { return document.getElementById(id); }

  function fmt(secs) {
    if (!secs || isNaN(secs)) return '0:00';
    var m = Math.floor(secs / 60);
    var s = Math.floor(secs % 60);
    return m + ':' + (s < 10 ? '0' : '') + s;
  }

  var ICON_PLAY    = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>';
  var ICON_PAUSE   = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
  var ICON_LOADING = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" style="animation:vp-spin 0.75s linear infinite"><circle cx="12" cy="12" r="9" stroke-opacity="0.18"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>';

  function setPlayState(state) {
    var btn = $id('vp-play');
    if (!btn) return;
    if (state === 'loading') { btn.innerHTML = ICON_LOADING; btn.setAttribute('aria-label', 'Loading…'); }
    else if (state === 'playing') { btn.innerHTML = ICON_PAUSE; btn.setAttribute('aria-label', 'Pause'); }
    else { btn.innerHTML = ICON_PLAY; btn.setAttribute('aria-label', 'Play'); }
  }

  function showPlayer() {
    var el = $id('vic-player');
    if (el && !el.classList.contains('vp--visible')) {
      el.classList.add('vp--visible');
      document.body.classList.add('has-player');
    }
  }

  /* ── Load WaveSurfer from CDN on first use ── */
  function ensureWS(cb) {
    if (window.WaveSurfer) { cb(); return; }
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/wavesurfer.js@7/dist/wavesurfer.min.js';
    s.onload  = cb;
    s.onerror = function () { console.warn('[VIC Player] WaveSurfer failed to load'); cb(); };
    document.head.appendChild(s);
  }

  /* ── Core: load a track object (handles both indexed and ad-hoc tracks) ── */
  function loadTrackObj(track, autoplay, onFinish) {
    if (!track) return;
    if (autoplay === undefined) autoplay = true;

    /* Update metadata in UI */
    var titleEl = $id('vp-title');
    var coverEl = $id('vp-cover');
    var curEl   = $id('vp-cur');
    var durEl   = $id('vp-dur');

    if (titleEl) titleEl.textContent = track.title;
    if (coverEl) { coverEl.src = 'https://img.youtube.com/vi/' + track.yt + '/maxresdefault.jpg'; coverEl.alt = track.title; }
    if (curEl)   curEl.textContent  = '0:00';
    if (durEl)   durEl.textContent  = '0:00';

    setPlayState('loading');
    showPlayer();

    /* Tiny rAF delay so player is visible before WS measures container width */
    requestAnimationFrame(function () {
      ensureWS(function () {
        /* Tear down previous instance */
        if (ws) { try { ws.destroy(); } catch (e) {} ws = null; }

        /* Build the audio URL — use track.file if set, else fall back to slug convention */
        var audioPath = track.file ? encodeURIComponent(track.file) : track.slug + '.mp3';
        var audioUrl  = SB_TRACKS + '/' + audioPath;

        if (!window.WaveSurfer) {
          /* Graceful fallback: plain <audio> without waveform */
          var audio = new Audio(audioUrl);
          audio.addEventListener('loadedmetadata', function () {
            if (durEl) durEl.textContent = fmt(audio.duration);
            setPlayState(autoplay ? 'playing' : 'paused');
          });
          audio.addEventListener('timeupdate', function () {
            if (curEl) curEl.textContent = fmt(audio.currentTime);
          });
          audio.addEventListener('ended', onFinish || function () {});
          audio.addEventListener('play',  function () { setPlayState('playing'); });
          audio.addEventListener('pause', function () { setPlayState('paused'); });
          audio.addEventListener('error', function () { setPlayState('paused'); });
          if (autoplay) audio.play().catch(function(){});
          /* Wrap so the rest of the code can call .playPause() / .destroy() */
          ws = {
            _audio: audio,
            playPause: function () { audio.paused ? audio.play().catch(function(){}) : audio.pause(); },
            destroy: function ()   { audio.pause(); audio.src = ''; }
          };
          return;
        }

        /* WaveSurfer path */
        var waveEl = $id('vp-waveform');
        if (!waveEl) return;

        ws = window.WaveSurfer.create({
          container:     waveEl,
          url:           audioUrl,
          waveColor:     'rgba(201,168,76,0.22)',
          progressColor: 'rgba(201,168,76,0.82)',
          cursorColor:   'rgba(201,168,76,0.55)',
          cursorWidth:   1,
          barWidth:      2,
          barGap:        1.5,
          barRadius:     2,
          height:        42,
          normalize:     true,
          interact:      true,
          autoplay:      autoplay,
        });

        ws.on('ready',      function ()  { if (durEl) durEl.textContent = fmt(ws.getDuration()); });
        ws.on('timeupdate', function (t) { if (curEl) curEl.textContent = fmt(t); });
        ws.on('play',       function ()  { setPlayState('playing'); });
        ws.on('pause',      function ()  { setPlayState('paused'); });
        ws.on('finish',     onFinish || function () {});
        ws.on('error',      function (e) { console.warn('[VIC Player]', e); setPlayState('paused'); });
      });
    });
  }

  /* ── Load by index (for prev/next and TRACKS-list plays) ── */
  function loadTrack(idx, autoplay) {
    if (autoplay === undefined) autoplay = true;
    var track = TRACKS[idx];
    if (!track) return;
    curIdx = idx;
    loadTrackObj(track, autoplay, nextTrack);
  }

  function nextTrack() { loadTrack(curIdx < TRACKS.length - 1 ? curIdx + 1 : 0, true); }
  function prevTrack() { loadTrack(curIdx > 0 ? curIdx - 1 : TRACKS.length - 1, true); }

  /* ── Button wiring ── */
  var prevBtn  = $id('vp-prev');
  var playBtn  = $id('vp-play');
  var nextBtn  = $id('vp-next');
  var closeBtn = $id('vp-close');

  if (prevBtn)  prevBtn.addEventListener('click',  prevTrack);
  if (nextBtn)  nextBtn.addEventListener('click',  nextTrack);

  if (playBtn) {
    playBtn.addEventListener('click', function () {
      if (curIdx === -1) { loadTrack(0, true); return; }
      if (ws && ws.playPause) ws.playPause();
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function () {
      if (ws) { try { ws.destroy(); } catch (e) {} ws = null; }
      var el = $id('vic-player');
      if (el) el.classList.remove('vp--visible');
      document.body.classList.remove('has-player');
      curIdx = -1;
      setPlayState('paused');
    });
  }

  /* ── Listen for play-track events from anywhere on the site ── */
  window.addEventListener('play-track', function (e) {
    var d = e && e.detail;
    if (!d || !d.slug) return;
    var idx = -1;
    for (var i = 0; i < TRACKS.length; i++) {
      if (TRACKS[i].slug === d.slug) { idx = i; break; }
    }
    if (idx !== -1) {
      /* Known track with MP3 — use indexed loader (enables prev/next) */
      loadTrack(idx, true);
    } else if (d.youtubeId) {
      /* Ad-hoc track — show player with cover/title, attempt MP3 load */
      curIdx = -1;
      loadTrackObj(
        { slug: d.slug, yt: d.youtubeId, title: d.title || d.slug },
        true,
        null   /* no auto-advance on finish */
      );
    }
  });

})();
</script>
