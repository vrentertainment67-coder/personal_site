    { slug: 'next-episode-raashah',             yt: 'kq5Q8VyPJEE', title: 'Snoop Dogg × Badshah — Next Episode', file: 'VIC - The Next Episode of Raashah (Mashup).mp3' },
    { slug: 'yeah-amplifier',                   yt: 'Y0YJ8FqMV2I', title: 'Yeah! × Amplifier',                   file: 'VIC - Yeah X Amplifier (Mashup).mp3' },
