<style is:global>
  /* ── Mobile floating CTA bar ─────────────────────────────────────── */
  .mob-float-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 990;
    background: rgba(8,8,8,0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(201,168,76,0.15);
    padding: 0.65rem 1rem calc(0.65rem + env(safe-area-inset-bottom, 0px));
    gap: 0.6rem;
    align-items: stretch;
    transform: translateY(110%);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (max-width: 768px) {
    .mob-float-bar { display: flex; }
    .mob-float-bar.is-visible { transform: translateY(0); }
    .mob-float-bar.is-hidden { display: none !important; }
    body { padding-bottom: 72px; }
  }

  .mfb-dismiss {
    background: transparent;
    border: none;
    border-left: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
    width: 44px;
    min-width: 44px;
    align-self: stretch;
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    flex-shrink: 0;
    transition: color 0.2s, background 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .mfb-dismiss:hover,
  .mfb-dismiss:active { color: #fff; background: rgba(255,255,255,0.06); }

  .mfb-wa {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    background: #25D366;
    color: #000;
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.8rem 1rem;
    border-radius: 3px;
    transition: background 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .mfb-wa:hover,
  .mfb-wa:active { background: #20bd5a; color: #000; }

  .mfb-book {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gold, #c9a84c);
    color: #000;
    font-family: var(--font-body, 'Space Grotesk', sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.8rem 1.25rem;
    border-radius: 3px;
    white-space: nowrap;
    transition: background 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .mfb-book:hover,
  .mfb-book:active { background: var(--gold-light, #e0c060); color: #000; }

  /* ── Skip link ────────────────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--gold, #c9a84c);
    color: #000;
    padding: 0.5rem 1rem;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 9999;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 1rem;
  }
</style>

<!--
  Formspree → WhatsApp bridge.
  Mirrors any Formspree form submit to the Supabase Edge Function via sendBeacon,
  so DJ VIC gets a WhatsApp ping (via CallMeBot) in addition to the Formspree email.
  - Listens on `document` so it survives Astro view transitions (document persists).
  - sendBeacon doesn't block the actual form POST to Formspree.
  - __vicNotifyWired guard prevents re-attaching listeners during view transitions.
  - The function URL is the same shape for all Supabase Edge Functions:
      https://<project-ref>.supabase.co/functions/v1/<function-name>
-->
<script is:inline>
  (function () {
    if (window.__vicNotifyWired) return;
    window.__vicNotifyWired = true;

    var NOTIFY_URL = 'https://jftnhuutttmccmqnnybf.supabase.co/functions/v1/notify';

    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (!form || form.tagName !== 'FORM') return;
      var action = (form.getAttribute('action') || '').toLowerCase();
      if (action.indexOf('formspree.io') === -1) return;

      try {
        var data = {};
        var fd = new FormData(form);
        fd.forEach(function (value, key) {
          // Skip Formspree internals and honeypot
          if (key.charAt(0) === '_') return;
          data[key] = typeof value === 'string' ? value : String(value);
        });
        data._page = location.pathname + location.search;
        data._title = document.title;

        var blob = new Blob([JSON.stringify(data)], { type: 'application/json' });
        navigator.sendBeacon(NOTIFY_URL, blob);
      } catch (err) {
        // Never block the real submit on a notification failure
      }
    }, true); // capture phase — fires before the form's own listeners
  })();
</script>

<script is:inline>
  (function () {
    var _listenersAdded = false;

    function initMobFloatBar() {
      var bar = document.getElementById('mob-float-bar');
      if (!bar) return;

      // Cancel any pending show timer from a previous page
      if (window._mfbTimer) { clearTimeout(window._mfbTimer); window._mfbTimer = null; }

      // Reset classes for this page load
      bar.classList.remove('is-visible');
      bar.classList.remove('is-hidden');

      // Hide entirely on the booking page (no redundant CTA)
      var path = window.location.pathname;
      if (/\/book\/?$/.test(path)) {
        bar.classList.add('is-hidden');
        return;
      }

      // Honour session-level dismiss
      try {
        if (sessionStorage.getItem('mfb-dismissed') === '1') {
          bar.classList.add('is-hidden');
          return;
        }
      } catch (e) {}

      // Slide up after 3-second delay
      window._mfbTimer = setTimeout(function () {
        var b = document.getElementById('mob-float-bar');
        if (b) b.classList.add('is-visible');
      }, 3000);
    }

    function addListeners() {
      if (_listenersAdded) return;
      _listenersAdded = true;

      document.addEventListener('click', function (e) {
        // Walk up the DOM to handle clicks on SVG children etc.
        var tgt = e.target;
        while (tgt && tgt !== document.body) {
          // ── Dismiss ──────────────────────────────────────────────
          if (tgt.id === 'mfb-dismiss-btn') {
            var bar = document.getElementById('mob-float-bar');
            if (bar) {
              if (window._mfbTimer) { clearTimeout(window._mfbTimer); window._mfbTimer = null; }
              bar.classList.remove('is-visible');
              // Wait for slide-down animation before hiding from DOM
              setTimeout(function () {
                var b = document.getElementById('mob-float-bar');
                if (b) b.classList.add('is-hidden');
              }, 460);
            }
            try { sessionStorage.setItem('mfb-dismissed', '1'); } catch (e) {}
            return;
          }
          // ── Book Now — scroll to #contact if available ───────────
          if (tgt.id === 'mfb-book-btn') {
            var contact = document.getElementById('contact');
            if (contact) {
              e.preventDefault();
              contact.scrollIntoView({ behavior: 'smooth' });
            }
            return;
          }
          tgt = tgt.parentElement;
        }
      });
    }

    // astro:page-load fires on initial load AND after every View Transition
    document.addEventListener('astro:page-load', function () {
      addListeners();
      initMobFloatBar();
    });
  })();
</script>
