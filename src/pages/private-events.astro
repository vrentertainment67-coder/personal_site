---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Private Event DJ Bangalore | Intimate Events | DJ VIC"
  description="DJ VIC brings professional DJ setups to private events in Bangalore — birthdays, house parties, anniversaries, and intimate celebrations. Book now."
  canonical="https://djvicofficial.com/private-events/"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Private Event DJ Bangalore — DJ VIC",
      "provider": { "@id": "https://djvicofficial.com/#business" },
      "serviceType": "Private Event DJ",
      "areaServed": ["Bangalore", "India"],
      "description": "Professional DJ setups and curated music for private events in Bangalore — birthdays, house parties, anniversaries, and intimate celebrations.",
      "url": "https://djvicofficial.com/private-events/"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What type of private events does DJ VIC cover?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DJ VIC covers milestone birthdays (21st, 30th, 40th, 50th), house parties, anniversary dinners, engagement parties, baby showers, farewell parties, and any intimate social gathering in Bangalore."
          }
        },
        {
          "@type": "Question",
          "name": "Does DJ VIC provide his own sound equipment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. DJ VIC brings a full professional Pioneer setup including speakers, controller, and all cabling. No additional sound hire is needed for most private events."
          }
        },
        {
          "@type": "Question",
          "name": "Can I give DJ VIC a specific playlist or must-play list?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. DJ VIC does a pre-event consultation where you share must-plays, do-not-plays, and the mood you want. He builds the set around your preferences while reading the room on the night."
          }
        },
        {
          "@type": "Question",
          "name": "How far in advance should I book DJ VIC for a private event?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For Bangalore private events, ideally 4–8 weeks in advance. Weekend dates fill up quickly, especially during wedding and festive seasons."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Private Events", "item": "https://djvicofficial.com/private-events/" }
      ]
    }
  ]}
>
  <Nav />
  <main id="main-content">

    <section id="private-hero" class="hero-section" data-img-slot="private-events.hero">
      <div class="hero-inner">
        <div class="section-label">Private Events</div>
        <h1>Your Party,<br/>Your Music</h1>
        <p class="hero-sub">Milestone birthdays, house parties, anniversaries — a professional setup and a set built entirely around you.</p>
        <a href={`${base}/book/`} class="cta-btn cta-btn--gold">Book DJ VIC for Your Event &rarr;</a>
      </div>
    </section>

    <section id="private-occasions">
      <div class="section-inner">
        <div class="section-label">Occasions</div>
        <h2>Built for Every Gathering</h2>
        <p class="section-sub">
          No templates, no generic playlists. DJ VIC works with you ahead of the event to understand
          your taste, your guests, and the mood you want to create.
        </p>
        <div class="occasions-grid">
          <div class="occasion-card">
            <span class="occasion-icon">🎂</span>
            <span class="occasion-name">Milestone Birthdays</span>
            <p>21st, 30th, 40th, 50th and beyond — sets that span the era and soundtrack the celebration properly.</p>
          </div>
          <div class="occasion-card">
            <span class="occasion-icon">🏠</span>
            <span class="occasion-name">House Parties</span>
            <p>Professional sound in an intimate setting — without the club energy if that's not the vibe.</p>
          </div>
          <div class="occasion-card">
            <span class="occasion-icon">💍</span>
            <span class="occasion-name">Anniversaries</span>
            <p>Background ambience to a full dance floor moment — calibrated to the tone of your evening.</p>
          </div>
          <div class="occasion-card">
            <span class="occasion-icon">🥂</span>
            <span class="occasion-name">Engagement Parties</span>
            <p>The perfect score for your engagement celebration — romantic, fun, and full of energy when it counts.</p>
          </div>
          <div class="occasion-card">
            <span class="occasion-icon">✈️</span>
            <span class="occasion-name">Farewell Parties</span>
            <p>Go out on a high note. DJ VIC curates a set full of shared memories and feel-good anthems.</p>
          </div>
          <div class="occasion-card">
            <span class="occasion-icon">🎊</span>
            <span class="occasion-name">Social Gatherings</span>
            <p>Reunions, get-togethers, rooftop nights — any occasion that deserves great music.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="private-how">
      <div class="section-inner">
        <div class="section-label">How It Works</div>
        <h2>Simple from Start to Finish</h2>
        <div class="steps-row">
          <div class="step">
            <span class="step-num">01</span>
            <span class="step-title">Get in Touch</span>
            <p>Share your event date, venue, and a rough idea of the vibe. DJ VIC checks availability and responds within 24 hours.</p>
          </div>
          <div class="step-arrow">&rarr;</div>
          <div class="step">
            <span class="step-num">02</span>
            <span class="step-title">Pre-Event Consult</span>
            <p>A quick call or WhatsApp chat to lock in must-plays, do-not-plays, the arc of the night, and any special moments.</p>
          </div>
          <div class="step-arrow">&rarr;</div>
          <div class="step">
            <span class="step-num">03</span>
            <span class="step-title">We Show Up & Deliver</span>
            <p>Full Pioneer setup, early arrival for soundcheck, and a set that makes your guests talk about it the next day.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="private-faq">
      <div class="section-inner">
        <div class="section-label">Questions</div>
        <h2>Frequently Asked</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>What type of private events does DJ VIC cover?</summary>
            <p>DJ VIC covers milestone birthdays (21st, 30th, 40th, 50th), house parties, anniversary dinners, engagement parties, baby showers, farewell parties, and any intimate social gathering in Bangalore.</p>
          </details>
          <details class="faq-item">
            <summary>Does DJ VIC provide his own sound equipment?</summary>
            <p>Yes. DJ VIC brings a full professional Pioneer setup including speakers, controller, and all cabling. No additional sound hire is needed for most private events.</p>
          </details>
          <details class="faq-item">
            <summary>Can I give DJ VIC a specific playlist or must-play list?</summary>
            <p>Absolutely. DJ VIC does a pre-event consultation where you share must-plays, do-not-plays, and the mood you want. He builds the set around your preferences while reading the room on the night.</p>
          </details>
          <details class="faq-item">
            <summary>How far in advance should I book DJ VIC for a private event?</summary>
            <p>For Bangalore private events, ideally 4–8 weeks in advance. Weekend dates fill up quickly, especially during wedding and festive seasons.</p>
          </details>
        </div>
      </div>
    </section>

    <section id="private-links">
      <div class="section-inner links-row">
        <span class="links-label">Explore more</span>
        <a href={`${base}/weddings/`}>Wedding DJ &rarr;</a>
        <a href={`${base}/sangeet/`}>Sangeet Night DJ &rarr;</a>
        <a href={`${base}/corporate/`}>Corporate DJ &rarr;</a>
        <a href={`${base}/private-sessions/`}>Private DJ Sessions &rarr;</a>
      </div>
    </section>

    <section id="private-cta" class="cta-section">
      <h2>Planning a Private Event?</h2>
      <p class="section-sub">Get in touch to check availability and discuss what you need.</p>
      <a href={`${base}/book/`} class="cta-btn cta-btn--gold">Get in Touch &rarr;</a>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  .hero-section {
    min-height: 50svh;
    display: flex;
    align-items: flex-end;
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.92) 35%, rgba(0,0,0,0.55) 70%, rgba(0,0,0,0.2) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%),
      url('https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?w=1600&q=85');
    background-size: cover;
    background-position: center;
    padding: 0;
  }

  .hero-inner {
    padding: 8rem 2.5rem 4rem;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
  }

  .hero-section h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 1rem;
    max-width: 50ch;
    margin: 0 0 2rem;
  }

  /* ─── Section layout ──────────────────────────── */
  .section-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 5rem 2.5rem;
  }

  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 { color: var(--white); margin-bottom: 1rem; }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 65ch;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  /* ─── Occasions grid ──────────────────────────── */
  .occasions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .occasion-card {
    background: #111;
    border: 1px solid rgba(201,168,76,0.12);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .occasion-icon { font-size: 1.5rem; }

  .occasion-name {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--white);
  }

  .occasion-card p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.65;
    margin: 0;
  }

  /* ─── How it works ────────────────────────────── */
  #private-how { background: #080808; }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--gold);
    opacity: 0.5;
    line-height: 1;
  }

  .step-title {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
  }

  .step p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.65;
    margin: 0;
  }

  .step-arrow {
    color: var(--gold);
    opacity: 0.4;
    font-size: 1.5rem;
    padding-top: 2rem;
    flex-shrink: 0;
  }

  /* ─── FAQ ─────────────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2rem;
    border-top: 1px solid rgba(201,168,76,0.12);
  }

  .faq-item {
    border-bottom: 1px solid rgba(201,168,76,0.12);
  }

  .faq-item summary {
    padding: 1.25rem 0;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    color: var(--gold);
    font-size: 1.25rem;
    font-weight: 300;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin: 0;
    padding-bottom: 1.25rem;
  }

  /* ─── Internal links ──────────────────────────── */
  #private-links {
    border-top: 1px solid rgba(201,168,76,0.08);
    border-bottom: 1px solid rgba(201,168,76,0.08);
  }

  .links-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .links-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-right: 0.5rem;
  }

  .links-row a {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .links-row a:hover { opacity: 0.7; }

  /* ─── CTA ─────────────────────────────────────── */
  .cta-section {
    text-align: center;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2 { font-size: clamp(1.6rem, 4vw, 2.4rem); }
  .cta-section h2::before { display: none; }
  .cta-section .section-sub { margin-inline: auto; }

  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 2rem;
    text-decoration: none;
  }

  .cta-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .cta-btn--gold:hover { background: var(--gold-light); color: #000; transform: translateY(-1px); }

  /* ─── Responsive ──────────────────────────────── */
  @media (max-width: 900px) {
    .occasions-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-row { flex-direction: column; }
    .step-arrow { display: none; }
  }

  @media (max-width: 600px) {
    .occasions-grid { grid-template-columns: 1fr; }
    .hero-inner { padding-inline: 1.25rem; }
    .section-inner { padding-inline: 1.25rem; }
  }
</style>
