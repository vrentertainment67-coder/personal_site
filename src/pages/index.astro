---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const BASE = 'https://hosting.renderforestsites.com/19480377/1066059/media/';

const primaryServices = [
  {
    name: "Weddings",
    href: "/weddings/",
    desc: "From sangeet nights to the last dance — curated music and visuals for every moment of your celebration.",
    bg: `${BASE}fc1c338a80d635c2429d234301f2ba98.jpg`,
  },
  {
    name: "Corporate Events",
    href: "/corporate/",
    desc: "Conferences, product launches, annual days — delivered with precision and the right energy for every room.",
    bg: `${BASE}c26853944612fd45df1fe9d9f6d3417f.jpg`,
  },
];

const secondaryServices = [
  {
    name: "Club & Nightlife",
    href: "/nightlife/",
    desc: "Open-format audio-visual sets built for the dance floor.",
  },
  {
    name: "Private Events",
    href: "/private-events/",
    desc: "Birthdays, anniversaries, intimate gatherings — personalised to your vibe.",
  },
  {
    name: "Festivals & Live Shows",
    href: "/festivals/",
    desc: "Large-format stages and open-air events across India and beyond.",
  },
  {
    name: "Brand & Experiential",
    href: "/#contact",
    desc: "Music woven into brand activations, pop-ups, and product drops.",
  },
  {
    name: "Private Sessions",
    href: "/private-sessions/",
    desc: "One-on-one craft sessions for those who want to master the art of the room. By enquiry only.",
  },
];

const testimonials = [
  {
    quote: "VIC made our wedding night truly unforgettable. The transitions were seamless, the energy never dropped, and the audio-visual element left our guests speechless.",
    name: "Kruthi S.",
    event: "Wedding, Bangalore",
  },
  {
    quote: "We booked VIC for our annual brand event and he read the room perfectly — from the opening set to the close, it was exactly the tone we needed.",
    name: "Rashmi J.",
    event: "Corporate Event",
  },
  {
    quote: "We wanted our reception to feel cinematic, not just loud. VIC understood exactly what we meant — the music and visuals together were something else.",
    name: "Aryaman & Prerna",
    event: "Wedding Reception",
  },
];

const featuredTrack = {
  id: "wHOB8H-HB_Y",
  title: "Tu Hi Meri Shab Hai × Say What (Afro Mashup)",
};

const tracks = [
  { id: "Hgb_g-xBblw",  title: "Tera Hone Laga Hoon × Viva La Vida" },
  { id: "ssFIKwChfHc",  title: "Sooraj Ki Baahon Mein × Forever" },
  { id: "modKUclnVJY",  title: "Sach Keh Raha Hai × Tujhe Bhula Diya" },
  { id: "aN2BIfUNUs4",  title: "Dil Luteya — Desi Mix" },
  { id: "KWUoJJ6xsfk",  title: "Kesariya × Can't Stop The Feeling" },
  { id: "rcGuVSoki6U",  title: "Oo Antava Time" },
  { id: "MXxbN1xYteY",  title: "Tere Liye — Progressive Edit" },
  { id: "zhaNQwYQi_8",  title: "Aaj Ki Raat — Progressive Edit" },
  { id: "gf0hYLxr6eo",  title: "Kahin Aag Lage × Rejection" },
  { id: "Yx3pD4uhJRE",  title: "Titliaan — Progressive Rework" },
  { id: "h48i6wSQjso",  title: "Boom Boom × Body Funk" },
  { id: "5oA311R6Wkg",  title: "Tamma Tamma × Makeba" },
  { id: "PxgvwE1nZmw",  title: "Jimmy (VIC Disco Edit)" },
  { id: "4oTBe25wvE0",  title: "Ghungroo — Sun n Sand Rework" },
];

const vicfixEpisodes = [
  {
    id: "rLDXYdh-TAc",
    label: "S2 · E13 · Latest",
    title: "Anoop Absolute — 34 Years of Doing It His Way",
    desc: "Luru, Howie B, and three decades in Bangalore's underground — one of India's longest-serving DJs, unfiltered.",
    slug: "anoop-absolute",
  },
  {
    id: "_7ique3N8KU",
    label: "S2 · E12",
    title: "Sharath Rice — Inside VRO Hospitality",
    desc: "The co-founder of Bangalore's biggest F&B empire on building nightlife brands from scratch.",
    slug: "sharath-rice",
  },
];
---

<Layout
  title="DJ VIC — Wedding & Corporate DJ in Bangalore | 19+ Years Experience"
  description="DJ VIC is Bangalore's premier DJ for weddings, corporate events, and nightlife. 19+ years, 1360+ events, 18 countries. Book for sangeet nights, receptions, product launches, and club nights."
  ogTitle="DJ VIC — International DJ · Audio-Visual Performances Across India & the World"
  ogDescription="19+ years. 18 countries. 1400+ performances. DJ VIC delivers premium audio-visual DJ sets for weddings, corporate events, and live shows across India and internationally."
  schema={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://djvicofficial.com/#person",
        "name": "DJ VIC",
        "description": "International DJ, producer, and remixer based in Bangalore with 19+ years of experience across 18 countries. Universal Music partner.",
        "url": "https://djvicofficial.com",
        "jobTitle": "DJ, Music Producer, Podcast Host",
        "sameAs": [
          "https://www.instagram.com/djvicofficial",
          "https://www.youtube.com/@thedjvicofficial",
          "https://www.facebook.com/djvicofficial"
        ]
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://djvicofficial.com/#business",
        "name": "DJ VIC Official",
        "description": "Premium DJ services for weddings, corporate events, clubs and festivals in Bangalore.",
        "url": "https://djvicofficial.com",
        "telephone": "+919611711677",
        "email": "bookings@djvicofficial.com",
        "priceRange": "₹₹₹",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Bangalore",
          "addressRegion": "Karnataka",
          "addressCountry": "IN"
        },
        "areaServed": ["Bangalore", "Mumbai", "Delhi", "Chennai", "India"]
      }
    ]
  }}
>
  <Nav />

  <main id="main-content">

    <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
    <section id="hero-cinema">
      <div class="hc-inner">
        <span class="hc-eyebrow">DJ &nbsp;·&nbsp; Producer &nbsp;·&nbsp; Remixer</span>
        <h1 class="hc-headline">
          Some nights,<br />
          the music is<br />
          the memory.
        </h1>
        <p class="hc-sub">
          International DJ, producer, and remixer.<br />
          Audio-visual performances from Bangalore to the world.
        </p>
        <div class="hc-ctas">
          <a href="/#contact" class="cta-btn-primary">Book VIC</a>
          <a href="/remixes/" class="cta-btn-outline">Watch Remixes</a>
        </div>
      </div>
      <div class="hc-scroll">
        <span class="hc-scroll-label">Scroll</span>
        <div class="hc-scroll-line"></div>
      </div>
    </section>

    <!-- ══════════════════════════ SIGNATURE STATEMENT ══════════════════════════ -->
    <div id="signature">
      <div class="sig-inner">
        <p class="sig-text">
          Not a DJ set.<br />
          An audio-visual performance.
        </p>
        <span class="sig-note">Signature format · since 2007</span>
      </div>
    </div>

    <!-- ════════════════════════════════ STATS ════════════════════════════════ -->
    <section id="about">
      <p class="stats-lead">
        Active since 2005 — two decades on stage, eighteen countries performed in,
        over 1,400 nights of live sets. Here's what that looks like in numbers.
      </p>
      <div class="stats-grid">
        <div class="stat-item">
          <strong>Est. 2005</strong>
          <span>In the Industry</span>
        </div>
        <div class="stat-item">
          <strong>18</strong>
          <span>Countries</span>
        </div>
        <div class="stat-item">
          <strong>1400+</strong>
          <span>Nights Performed</span>
        </div>
        <div class="stat-item">
          <strong>Universal</strong>
          <span>Music Partner</span>
        </div>
        <div class="stat-item">
          <strong>50+</strong>
          <span>Conversations Published</span>
        </div>
        <div class="stat-item">
          <strong>150+</strong>
          <span>Artists Collaborated With</span>
        </div>
        <div class="stat-item">
          <strong>10M+</strong>
          <span>Content Views</span>
        </div>
        <div class="stat-item">
          <strong>300+</strong>
          <span>Private &amp; Corporate Events</span>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════ VIC FIX CALLOUT ════════════════════════════ -->
    <section id="vicfix-callout">
      <span class="section-label">The VIC Fix · Podcast</span>
      <h2>Long-form conversations with the people who shaped the scene.</h2>
      <div class="vf-episodes">
        {vicfixEpisodes.map((ep) => (
          <a
            href={ep.slug ? `/thevicfix/${ep.slug}/` : `https://youtu.be/${ep.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="vf-ep"
          >
            <div class="vf-thumb">
              <img
                src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`}
                alt={ep.title}
                loading="lazy"
              />
              <div class="vf-play">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="vf-ep-label">{ep.label}</span>
            </div>
            <div class="vf-ep-info">
              <h3>{ep.title}</h3>
              <p>{ep.desc}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="vf-cta-wrap">
        <a href="/thevicfix/" class="vf-cta">Watch All Episodes &rarr;</a>
      </div>
    </section>

    <!-- ════════════════════════════════ WORK ════════════════════════════════ -->
    <section id="work">
      <span class="section-label">What VIC Does</span>
      <h2>Work</h2>

      <!-- Primary: 2 large cards -->
      <div class="work-primary-grid">
        {primaryServices.map((s) => (
          <a
            href={s.href}
            class="work-primary"
            style={`background-image: linear-gradient(to top, rgba(6,6,6,0.97) 0%, rgba(6,6,6,0.55) 55%, rgba(6,6,6,0.2) 100%), url('${s.bg}'); background-size: cover; background-position: center;`}
          >
            <div class="work-primary-text">
              <span class="work-name">{s.name}</span>
              <p>{s.desc}</p>
              <span class="work-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Secondary: 4 compact cards -->
      <div class="work-secondary-grid">
        {secondaryServices.map((s) => (
          <a href={s.href} class="work-secondary">
            <div class="work-secondary-border"></div>
            <span class="work-name">{s.name}</span>
            <p>{s.desc}</p>
            <span class="work-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════ TESTIMONIALS ════════════════════════════ -->
    <section id="testimonials">
      <span class="section-label">Client Voices</span>
      <h2>What they say</h2>
      <div class="testi-grid">
        {testimonials.map((t) => (
          <div class="testi-item">
            <div class="testi-quote-mark">&ldquo;</div>
            <p class="testi-text">{t.quote}</p>
            <div class="testi-attr">
              <strong>{t.name}</strong>
              <span>{t.event}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════ MUSIC ════════════════════════════════ -->
    <section id="music">
      <span class="section-label">Remixes &amp; Mashups</span>
      <h2>The Sound</h2>
      <p class="music-lead">From the dance floor to your playlist — remixed and reimagined.</p>

      <!-- Featured track -->
      <div class="music-featured-wrap">
      <a
        href={`https://youtu.be/${featuredTrack.id}`}
        target="_blank"
        rel="noopener noreferrer"
        class="music-featured"
        aria-label={`Watch ${featuredTrack.title} on YouTube`}
      >
        <div class="music-featured-thumb">
          <img
            src={`https://img.youtube.com/vi/${featuredTrack.id}/maxresdefault.jpg`}
            alt={featuredTrack.title}
            loading="lazy"
          />
          <div class="music-featured-overlay">
            <div class="music-featured-play">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="52" height="52">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="music-featured-info">
              <span class="music-featured-label">Featured · Latest Release</span>
              <p class="music-featured-title">{featuredTrack.title}</p>
            </div>
          </div>
        </div>
      </a>
      </div>

      <!-- Horizontal scroll tracks -->
      <div class="tracks-scroll" role="list">
        {tracks.map(({ id, title }) => (
          <a
            href={`https://youtu.be/${id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="track-item"
            role="listitem"
          >
            <div class="track-thumb">
              <img
                src={`https://img.youtube.com/vi/${id}/mqdefault.jpg`}
                alt={title}
                loading="lazy"
              />
              <div class="track-play">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            <span class="track-title">{title}</span>
          </a>
        ))}
      </div>

      <div class="music-cta-wrap">
        <a href="/remixes/" class="cta-btn-outline">Explore the Full Catalogue &rarr;</a>
      </div>
    </section>

    <!-- ════════════════════════════════ CONTACT ════════════════════════════════ -->
    <section id="contact">
      <span class="section-label">Bookings</span>
      <h2>Work With VIC</h2>
      <p class="contact-lead">
        VIC takes on a limited number of bookings each month to ensure every performance
        is delivered at its highest standard. If you have a date in mind — reach out now.
      </p>

      <div class="contact-layout">
        <div class="contact-form-col">
          <form id="booking-form" method="POST" action="https://formspree.io/f/xdapzdnw">
            <input type="hidden" name="_subject" value="New Booking Enquiry — DJ VIC" />
            <input type="hidden" name="_next" value="https://djvicofficial.com/thanks/" />
            <input type="text" name="_gotcha" style="display:none" />

            <div class="form-row">
              <div class="form-field">
                <label for="name">Your Name <span>*</span></label>
                <input id="name" type="text" name="name" required placeholder="Your name" autocomplete="name" />
              </div>
              <div class="form-field">
                <label for="email">Email Address <span>*</span></label>
                <input id="email" type="email" name="email" required placeholder="your@email.com" autocomplete="email" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="phone">Phone / WhatsApp <span>*</span></label>
                <input id="phone" type="tel" name="phone" required placeholder="+91 98765 43210" autocomplete="tel" />
              </div>
              <div class="form-field">
                <label for="event_type">Event Type <span>*</span></label>
                <select id="event_type" name="event_type" required>
                  <option value="" disabled selected>Select event type</option>
                  <option value="Wedding">Wedding</option>
                  <option value="Corporate">Corporate Event</option>
                  <option value="Private Party">Private Party</option>
                  <option value="Club Night">Club Night</option>
                  <option value="Festival">Festival</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="event_date">Event Date</label>
                <input id="event_date" type="date" name="event_date" />
              </div>
              <div class="form-field">
                <label for="city">City / Venue</label>
                <input id="city" type="text" name="city" placeholder="Bangalore, Mumbai…" />
              </div>
            </div>

            <div class="form-field">
              <label for="message">Tell us more</label>
              <textarea id="message" name="message" rows="4" placeholder="Brief about your event, guests, vibe…"></textarea>
            </div>

            <button type="submit">Send Enquiry</button>
          </form>
        </div>

        <div class="contact-aside">
          <div class="contact-wa-block">
            <p class="contact-wa-label">Fastest response</p>
            <a
              href="https://wa.me/919611711677"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-wa-btn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.004 0C5.374 0 0 5.373 0 12c0 2.139.561 4.14 1.538 5.878L0 24l6.305-1.511A11.95 11.95 0 0 0 12.004 24C18.63 24 24 18.627 24 12c0-6.628-5.371-12-11.996-12z"/>
              </svg>
              Chat on WhatsApp
            </a>
          </div>
          <div class="contact-direct">
            <a href="mailto:bookings@djvicofficial.com" class="contact-email">bookings@djvicofficial.com</a>
            <a href="tel:+919611711677" class="contact-phone">+91 96117 11677</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

<script>
  // WhatsApp notification on booking form submit
  const bookingForm = document.getElementById('booking-form');
  if (bookingForm) {
    bookingForm.addEventListener('submit', function () {
      const name = (document.getElementById('name') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('phone') as HTMLInputElement)?.value || '';
      const eventType = (document.getElementById('event_type') as HTMLSelectElement)?.value || '';
      const eventDate = (document.getElementById('event_date') as HTMLInputElement)?.value || '';
      const msg = encodeURIComponent(
        `🎧 New Booking Enquiry\n\nName: ${name}\nPhone: ${phone}\nEvent: ${eventType}\nDate: ${eventDate}\n\n(Full details sent to email)`
      );
      setTimeout(() => {
        window.open(`https://wa.me/919611711677?text=${msg}`, '_blank');
      }, 1000);
    });
  }
</script>

</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap');

  /* ══════════════════════════════════════════════
     ANIMATIONS
     ══════════════════════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes scrollBlink {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 1; }
  }

  /* ══════════════════════════════════════════════
     HERO CINEMA
     ══════════════════════════════════════════════ */
  #hero-cinema {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    max-width: 100%;
    padding: 0;
    background-color: #060606;
    background-image:
      linear-gradient(to right,  rgba(6,6,6,0.92) 0%,  rgba(6,6,6,0.65) 50%, rgba(6,6,6,0.2) 100%),
      linear-gradient(to bottom, rgba(6,6,6,0.5)  0%,  rgba(6,6,6,0)    30%, rgba(6,6,6,0.88) 100%),
      url('/images/hero2.jpg');
    background-size: auto, auto, cover;
    background-position: center, center, center right;
    background-repeat: no-repeat;
  }

  .hc-inner {
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding: 9rem 2.5rem 5rem;
  }

  .hc-eyebrow {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.15s;
  }

  .hc-headline {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7.5vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.9s ease forwards 0.35s;
  }

  .hc-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.875rem, 1.4vw, 1rem);
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    max-width: 44ch;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.55s;
  }

  .hc-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.75s;
  }

  /* Scroll indicator */
  .hc-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.1s;
    pointer-events: none;
  }

  .hc-scroll-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.52rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .hc-scroll-line {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, rgba(201,168,76,0.8), transparent);
    animation: scrollBlink 2s ease-in-out infinite;
  }

  /* ══════════════════════════════════════════════
     SIGNATURE STATEMENT
     ══════════════════════════════════════════════ */
  #signature {
    background: #060606;
    border-top: 1px solid #0f0f0f;
    border-bottom: 1px solid #0f0f0f;
  }

  .sig-inner {
    max-width: var(--max-width);
    margin-inline: auto;
