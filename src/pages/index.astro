---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroVideo from '../components/HeroVideo.astro';
import TestimonialsStrip from '../components/TestimonialsStrip.jsx';
import EventPopup from '../components/EventPopup.jsx';
import { getCollection } from 'astro:content';

const BASE = '/images/rf/';

// Build-time: pull reviews for AggregateRating rich snippets (mirrors the homepage strip).
const FALLBACK_REVIEWS = [
  { author: 'Kruthi S.', quote: 'VIC made our wedding night truly unforgettable. The transitions were seamless, the energy never dropped, and the audio-visual element left our guests speechless.', rating: 5 },
  { author: 'Rashmi J.', quote: 'We booked VIC for our annual brand event and he read the room perfectly — from the opening set to the close, it was exactly the tone we needed.', rating: 5 },
  { author: 'Aryaman & Prerna', quote: 'We wanted our reception to feel cinematic, not just loud. VIC understood exactly what we meant — the music and visuals together were something else.', rating: 5 },
];
let reviewExtra = {};
try {
  const rr = await fetch(`${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/rpc/public_reviews`, {
    method: 'POST',
    headers: {
      apikey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
      Authorization: `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}`,
      'Content-Type': 'application/json',
    },
    body: '{"p_category":"home"}',
  });
  const db = rr.ok ? await rr.json() : [];
  const reviews = (Array.isArray(db) && db.length ? db : FALLBACK_REVIEWS)
    .map((r) => ({ author: r.author, quote: r.quote, rating: r.rating || 5 }))
    .filter((r) => r.author && r.quote);
  if (reviews.length) {
    const avg = reviews.reduce((s, r) => s + r.rating, 0) / reviews.length;
    reviewExtra = {
      aggregateRating: { '@type': 'AggregateRating', ratingValue: avg.toFixed(1), reviewCount: reviews.length, bestRating: 5, worstRating: 1 },
      review: reviews.slice(0, 6).map((r) => ({
        '@type': 'Review',
        author: { '@type': 'Person', name: r.author },
        reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5, worstRating: 1 },
        reviewBody: r.quote,
      })),
    };
  }
} catch (e) { /* no rich snippets if the fetch fails */ }

const allRemixes = (await getCollection('remixes'))
  .sort((a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime());

const latestRemixes  = allRemixes.slice(0, 3);
const scrollRemixes  = allRemixes.slice(3);

const remixTypeLabel: Record<string, string> = {
  mashup:  'Mashup',
  remix:   'Remix',
  edit:    'Edit',
  rework:  'Rework',
};

const primaryServices = [
  {
    name: "Weddings",
    href: "/weddings/",
    desc: "From sangeet nights to the last dance — curated music and visuals for every moment of your celebration.",
    note: "Pan-India & international bookings available",
    bg: `${BASE}fc1c338a80d635c2429d234301f2ba98.jpg`,
    slot: "home.weddings-bg",
  },
  {
    name: "Corporate Events",
    href: "/corporate/",
    desc: "Conferences, product launches, annual days — delivered with precision and the right energy for every room.",
    bg: `${BASE}c26853944612fd45df1fe9d9f6d3417f.jpg`,
    slot: "home.corporate-bg",
  },
];

const secondaryServices = [
  {
    name: "Club & Nightlife",
    href: "/nightlife/",
    desc: "Open-format audio-visual sets built for the dance floor.",
  },
  {
    name: "Private Events",
    href: "/private-events/",
    desc: "Birthdays, anniversaries, intimate gatherings — personalised to your vibe.",
  },
  {
    name: "Festivals & Live Shows",
    href: "/festivals/",
    desc: "Large-format stages and open-air events across India and beyond.",
  },
  {
    name: "Brand & Experiential",
    href: "/book/",
    desc: "Music woven into brand activations, pop-ups, and product drops.",
  },
  {
    name: "Private Sessions",
    href: "/private-sessions/",
    desc: "One-on-one craft sessions for those who want to master the art of the room. By enquiry only.",
  },
];


const vicfixEpisodes = [
  {
    id: "j2jm-CHyoss",
    label: "S2 · E15 · Latest",
    title: "Sahil Madaan — The DJ Who Brought a Saxophone to the Dancefloor",
    desc: "Sunburn, Supersonic, a global progressive-house co-sign — and a live saxophone almost nobody in India plays.",
    slug: "sahil-madaan",
  },
  {
    id: "r7ZKXipivSA",
    label: "S2 · E14",
    title: "DJ Xirex — The Boy Who Brought His Phone to a Club",
    desc: "From a Motorola phone and aux cable to 7M+ views — Pioneer demo artist, Mashup City India founder, and the DJ who gave everything away for free.",
    slug: "dj-xirex",
  },
];
---

<Layout
  title="DJ VIC — Wedding & Corporate DJ Bangalore | 19 Years Experience"
  description="DJ VIC is Bangalore's premier DJ for weddings, corporate events, and nightlife. 19+ years, 1400+ performances across 18 countries. Book your event now."
  ogTitle="DJ VIC — International DJ · Audio-Visual Performances Across India & the World"
  ogDescription="19+ years. 18 countries. 1400+ performances. DJ VIC delivers premium audio-visual DJ sets for weddings, corporate events, and live shows across India and internationally."
  schema={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://djvicofficial.com/#person",
        "name": "DJ VIC",
        "alternateName": ["DJ Vic", "DJ VIC Official", "DJ VIC Bangalore"],
        "description": "International DJ, producer, and remixer based in Bangalore with 19+ years of experience across 18 countries. Universal Music partner.",
        "url": "https://djvicofficial.com",
        "jobTitle": "DJ, Music Producer, Podcast Host",
        "sameAs": [
          "https://www.instagram.com/djvicofficial",
          "https://www.youtube.com/@thedjvicofficial",
          "https://www.facebook.com/djvicofficial",
          "https://audiomack.com/vrentertainment67"
        ]
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://djvicofficial.com/#business",
        "name": "DJ VIC Official",
        "description": "Premium DJ services for weddings, corporate events, clubs and festivals in Bangalore.",
        "url": "https://djvicofficial.com",
        "telephone": "+919611711677",
        "email": "bookings@djvicofficial.com",
        "priceRange": "₹₹₹₹",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Bangalore",
          "addressRegion": "Karnataka",
          "addressCountry": "IN"
        },
        "areaServed": ["Bangalore", "Mumbai", "Delhi", "Chennai", "India"],
        ...reviewExtra
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://djvicofficial.com/" }
        ]
      }
    ]
  }}
>
  <Nav />

  <main id="main-content">

    <!-- ════════════════════════════════ HERO ════════════════════════════════ -->
    <HeroVideo />

    <!-- ══════════════════════════ SIGNATURE STATEMENT ══════════════════════════ -->
    <div id="signature">
      <div class="sig-inner">
        <p class="sig-text fx-reveal">
          Not a DJ set.<br />
          An audio-visual performance.
        </p>
        <span class="sig-note">Signature format · since 2007</span>
      </div>
    </div>

    <!-- ════════════════════════════════ STATS ════════════════════════════════ -->
    <section id="about">
      <p class="stats-lead fx-reveal">
        Active since 2005 — two decades on stage, eighteen countries performed in,
        over 1,400 nights of live sets. Here's what that looks like in numbers.
      </p>
      <div class="stats-grid">
        <div class="stat-item">
          <strong>Est. 2005</strong>
          <span>In the Industry</span>
        </div>
        <div class="stat-item">
          <strong data-count>18</strong>
          <span>Countries</span>
        </div>
        <div class="stat-item">
          <strong data-count>1400+</strong>
          <span>Nights Performed</span>
        </div>
        <div class="stat-item">
          <strong>Universal</strong>
          <span>Music Partner</span>
        </div>
        <div class="stat-item">
          <strong data-count>50+</strong>
          <span>Conversations Published</span>
        </div>
        <div class="stat-item">
          <strong data-count>150+</strong>
          <span>Artists Collaborated With</span>
        </div>
        <div class="stat-item">
          <strong data-count>10M+</strong>
          <span>Content Views</span>
        </div>
        <div class="stat-item">
          <strong data-count>300+</strong>
          <span>Private &amp; Corporate Events</span>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════ VIC FIX CALLOUT ════════════════════════════ -->
    <!-- ════════════════════════════════ WORK ════════════════════════════════ -->
    <section id="work">
      <span class="section-label fx-reveal">What VIC Does</span>
      <h2 class="fx-reveal" data-fx-delay="1">Work</h2>

      <!-- Primary: 2 large cards -->
      <div class="work-primary-grid">
        {primaryServices.map((s, i) => (
          <a
            href={s.href}
            class="work-primary fx-reveal"
            data-fx-delay={i + 1}
            data-img-slot={s.slot}
            style={`background-image: linear-gradient(to top, rgba(6,6,6,0.97) 0%, rgba(6,6,6,0.55) 55%, rgba(6,6,6,0.2) 100%), url('${s.bg}'); background-size: cover; background-position: center;`}
          >
            <div class="work-primary-text">
              <span class="work-name">{s.name}</span>
              <p>{s.desc}</p>
              {s.note && <span class="service-location-note">{s.note}</span>}
              <span class="work-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Secondary: 4 compact cards -->
      <div class="work-secondary-grid">
        {secondaryServices.map((s, i) => (
          <a href={s.href} class="work-secondary fx-reveal" data-fx-delay={(i % 4) + 1}>
            <div class="work-secondary-border"></div>
            <span class="work-name">{s.name}</span>
            <p>{s.desc}</p>
            <span class="work-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════ TESTIMONIALS ════════════════════════════ -->
    <section id="testimonials">
      <span class="section-label fx-reveal">Client Voices</span>
      <h2 class="fx-reveal" data-fx-delay="1">What they say</h2>
      <TestimonialsStrip client:visible />
    </section>

    <!-- ════════════════════════════════ MUSIC ════════════════════════════════ -->
    <section id="music">
      <span class="section-label fx-reveal">Remixes &amp; Mashups</span>
      <h2 class="fx-reveal" data-fx-delay="1">The Sound</h2>
      <p class="music-lead fx-reveal" data-fx-delay="2">From the dance floor to your playlist — remixed and reimagined.</p>

      <!-- Latest 3 releases -->
      <div class="latest-remixes-grid">
        {latestRemixes.map((r, i) => (
          <a href={`/remixes/${r.id}/`} class="lrc fx-reveal" data-fx-delay={(i % 3) + 1}>
            <div class="lrc-thumb">
              <img
                src={`https://img.youtube.com/vi/${r.data.youtubeId}/maxresdefault.jpg`}
                alt={r.data.title}
                loading="lazy"
                width="1280"
                height="720"
              />
              <div class="lrc-play" data-video={r.data.youtubeId} data-video-title={r.data.title} aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="lrc-badge">
                {i === 0 ? 'Latest' : remixTypeLabel[r.data.type] || 'Mashup'}
              </span>
            </div>
            <div class="lrc-info">
              <span class="lrc-type">{remixTypeLabel[r.data.type] || 'Mashup'}</span>
              <h3 class="lrc-title">{r.data.title}</h3>
              <span class="lrc-cta">Watch &rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Horizontal scroll — remaining tracks -->
      <div class="tracks-scroll" role="list">
        {scrollRemixes.map(r => (
          <a
            href={`/remixes/${r.id}/`}
            class="track-item"
            role="listitem"
          >
            <div class="track-thumb">
              <img
                src={`https://img.youtube.com/vi/${r.data.youtubeId}/mqdefault.jpg`}
                alt={r.data.title}
                loading="lazy"
                width="320"
                height="180"
              />
              <div class="track-play" data-video={r.data.youtubeId} data-video-title={r.data.title} aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            <span class="track-title">{r.data.title}</span>
          </a>
        ))}
      </div>

      <div class="music-cta-wrap">
        <a href="/remixes/" class="cta-btn-outline">Explore the Full Catalogue &rarr;</a>
      </div>
    </section>

    <!-- ══════════════════════════════ VIC FIX ══════════════════════════════ -->
    <section id="vicfix-callout">
      <span class="section-label fx-reveal">The VIC Fix · Podcast</span>
      <h2 class="fx-reveal" data-fx-delay="1">Long-form conversations with the people who shaped the scene.</h2>
      <div class="vf-episodes">
        {vicfixEpisodes.map((ep, i) => (
          <a
            href={ep.slug ? `/thevicfix/${ep.slug}/` : `https://youtu.be/${ep.id}`}
            {...(!ep.slug ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            class="vf-ep fx-reveal"
            data-fx-delay={(i % 3) + 1}
          >
            <div class="vf-thumb">
              <img
                src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`}
                alt={ep.title}
                loading="lazy"
              />
              <div class="vf-play" data-video={ep.id} data-video-title={ep.title} aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="vf-ep-label">{ep.label}</span>
            </div>
            <div class="vf-ep-info">
              <h3>{ep.title}</h3>
              <p>{ep.desc}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="vf-cta-wrap">
        <a href="/thevicfix/" class="vf-cta">Watch All Episodes &rarr;</a>
      </div>
    </section>


  </main>

  <Footer />

  <!-- Saturday event guest-list popup (homepage only) -->
  <EventPopup client:load />

</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap');

  /* ══════════════════════════════════════════════
     ANIMATIONS
     ══════════════════════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes scrollBlink {
    0%, 100% { opacity: 0.3; }
    50%       { opacity: 1; }
  }

  /* ══════════════════════════════════════════════
     HERO — see src/components/HeroVideo.astro
     (legacy #hero-cinema / .hc-* rules removed)
     ══════════════════════════════════════════════ */

  /* ══════════════════════════════════════════════
     SIGNATURE STATEMENT
     ══════════════════════════════════════════════ */
  #signature {
    background: #060606;
    border-top: 1px solid #0f0f0f;
    border-bottom: 1px solid #0f0f0f;
  }

  .sig-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 5rem 2.5rem;
    text-align: center;
  }

  .sig-text {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 4.5rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--white);
    line-height: 1.1;
    max-width: none;
    margin: 0 auto;
  }

  .sig-note {
    display: block;
    margin-top: 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.7;
  }

  /* ══════════════════════════════════════════════
     STATS
     ══════════════════════════════════════════════ */
  .stats-lead {
    font-family: 'DM Sans', sans-serif;
    font-style: italic;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid #1e1e1e;
  }

  .stat-item {
    padding: 1.5rem 1.75rem;
    border-right: 1px solid rgba(201,168,76,0.15);
    border-bottom: 1px solid rgba(201,168,76,0.08);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-item:nth-child(4n)   { border-right: none; }
  .stat-item:nth-last-child(-n+4) { border-bottom: none; }

  .stat-item strong {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    letter-spacing: 0.05em;
    color: var(--gold);
    line-height: 1;
  }

  .stat-item span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.5);
    line-height: 1.4;
  }

  /* ══════════════════════════════════════════════
     SECTION LABEL (shared utility)
     ══════════════════════════════════════════════ */
  .section-label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.75;
    margin-bottom: 0.75rem;
  }

  /* ══════════════════════════════════════════════
     VIC FIX CALLOUT
     ══════════════════════════════════════════════ */
  #vicfix-callout h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    max-width: 22ch;
    margin-bottom: 2.5rem;
  }

  .vf-episodes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .vf-ep {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    background: #111;
    border: 1px solid #1e1e1e;
    transition: border-color 0.25s;
  }

  .vf-ep:hover {
    border-color: rgba(201,168,76,0.4);
  }

  .vf-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .vf-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .vf-ep:hover .vf-thumb img {
    transform: scale(1.04);
  }

  .vf-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.25s;
    color: var(--gold);
  }

  .vf-ep:hover .vf-play {
    opacity: 1;
  }

  .vf-ep-label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #060606;
    background: var(--gold);
    padding: 0.25rem 0.6rem;
  }

  .vf-ep-info {
    padding: 0 1.25rem 1.5rem;
  }

  .vf-ep-info h3 {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.3rem);
    letter-spacing: 0.04em;
    color: var(--white);
    margin-bottom: 0.5rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .vf-ep-info p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }

  .vf-cta-wrap {
    margin-top: 2rem;
  }

  .vf-cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid rgba(201,168,76,0.4);
    padding-bottom: 3px;
    transition: color 0.2s, border-color 0.2s;
  }

  .vf-cta:hover {
    color: var(--gold-light);
    border-color: var(--gold-light);
  }

  /* ══════════════════════════════════════════════
     WORK (SERVICES TWO-TIER)
     ══════════════════════════════════════════════ */

  /* Primary: 2 large image cards */
  .work-primary-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    margin-top: 2rem;
    background: #1a1a1a;
  }

  .work-primary {
    position: relative;
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    text-decoration: none;
    overflow: hidden;
    background-color: #111;
  }

  .work-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .work-primary:hover::before {
    transform: scaleX(1);
  }

  .work-primary-text {
    position: relative;
    z-index: 1;
    padding: 2rem 2rem 2.25rem;
  }

  .work-name {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.25rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 0.6rem;
    transition: color 0.2s;
  }

  .work-primary:hover .work-name,
  .work-secondary:hover .work-name {
    color: var(--gold);
  }

