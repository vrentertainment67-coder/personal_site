---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

---

<Layout
  title="Corporate DJ in Bangalore — Conferences, Product Launches & Annual Days | DJ VIC"
  description="DJ VIC delivers premium DJ + MC services for corporate events in Bangalore. Trusted by SAP, Infosys, KPMG & more. Book for conferences, product launches, annual days, and brand activations."
  ogImage="https://djvicofficial.com/images/og-corporate.jpg"
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Corporate DJ Services by DJ VIC",
    "provider": { "@type": "LocalBusiness", "name": "DJ VIC Official", "url": "https://djvicofficial.com" },
    "serviceType": "Corporate Event DJ",
    "areaServed": ["Bangalore", "India", "International"],
    "description": "Premium DJ and MC services for corporate events including conferences, product launches, annual days, award nights, and brand activations.",
    "url": "https://djvicofficial.com/corporate/"
  }}
>
  <Nav />

  <main id="main-content">

    <!-- ══════════════════════════════════════════
         1. HERO
    ══════════════════════════════════════════ -->
    <section id="corporate-hero" class="hero-bg">
      <h1>Corporate DJ in Bangalore</h1>
      <p class="tagline">Built for Big Moments</p>
      <p>High-energy experiences, delivered with precision and crowd control.</p>
      <a href="/#contact" class="cta-btn cta-btn--gold">Book DJ VIC for Your Event</a>
    </section>

    <!-- ══════════════════════════════════════════
         2. ABOUT
    ══════════════════════════════════════════ -->
    <section id="corporate-about">
      <div class="section-label">Experience</div>
      <h2>19+ Years. 1360+ Events. 18 Countries.</h2>
      <p class="section-sub">
        DJ VIC is Bangalore's go-to corporate DJ — trusted by leading brands, event
        agencies, and HR teams to deliver premium music experiences that match the energy
        and identity of the occasion.
      </p>
      <div class="about-grid">
        <div class="about-card">
          <span class="about-stat">1360<span class="about-plus">+</span></span>
          <span class="about-label">Events Performed</span>
        </div>
        <div class="about-card">
          <span class="about-stat">19<span class="about-plus">+</span></span>
          <span class="about-label">Years in the Industry</span>
        </div>
        <div class="about-card">
          <span class="about-stat">18</span>
          <span class="about-label">Countries Performed In</span>
        </div>
        <div class="about-card">
          <span class="about-stat">100<span class="about-plus">+</span></span>
          <span class="about-label">Corporate Clients</span>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         3. WHAT DJ VIC BRINGS
    ══════════════════════════════════════════ -->
    <section id="corporate-services">
      <div class="formats-grid">

        <!-- Left: Statement block -->
        <div class="formats-left">
          <div class="formats-label">For Corporates</div>
          <h2 class="formats-heading">Every Brief.<br/>Every Room.<br/>Every Crowd.</h2>
          <p class="formats-body">
            From high-energy product launches to black-tie annual nights — DJ Vic reads
            the room, curates the set, and delivers an atmosphere that your guests will
            actually remember. No generic playlists. No filler. Just the right music at
            the right moment.
          </p>
          <p class="formats-body" style="margin-top:1rem;">
            DJ VIC is also known for his <strong style="color:var(--white);">audio-visual sets</strong> — original music synced with custom visuals, available as an elevated entertainment format for product launches, brand activations, and annual days.
          </p>
          <a href="/#contact" class="cta-btn cta-btn--gold formats-cta">
            Get a Corporate Quote &rarr;
          </a>
        </div>

        <!-- Right: Format tags -->
        <div class="formats-right">
          <div class="formats-label">Formats We Perform At</div>
          <div class="formats-tags">
            <span class="format-tag">Conferences &amp; Summits</span>
            <span class="format-tag">Product Launches</span>
            <span class="format-tag">Annual Days &amp; Townhalls</span>
            <span class="format-tag">Corporate Celebrations</span>
            <span class="format-tag">Brand &amp; Experiential Events</span>
            <span class="format-tag">Award Nights &amp; Galas</span>
            <span class="format-tag">Office Parties &amp; Milestone Events</span>
            <span class="format-tag">Dealer &amp; Channel Partner Meets</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. DJ VIC × MC DHANUSH
    ══════════════════════════════════════════ -->
    <section id="corporate-collab">
      <div class="collab-grid">

        <!-- Left: text -->
        <div class="collab-left">
          <div class="section-label">Collaboration</div>
          <h2>DJ VIC &times; MC Dhanush</h2>
          <p class="collab-body">
            DJ VIC partners with MC Dhanush to deliver a complete DJ + MC entertainment
            experience built specifically for corporate events. Together, they bring
            precision crowd energy, seamless transitions, and bilingual hosting that
            keeps large audiences engaged from first session to last dance.
          </p>
          <ul class="collab-list">
            <li>Bilingual hosting — English &amp; Hindi</li>
            <li>Crowd warm-ups and game facilitation</li>
            <li>Award ceremony and annual day coverage</li>
            <li>Seamless DJ–MC handoffs for zero dead air</li>
          </ul>
        </div>

        <!-- Right: video -->
        <a
          href="https://youtu.be/ikj-Juss6PM"
          target="_blank"
          rel="noopener noreferrer"
          class="collab-video"
          aria-label="Watch DJ VIC × MC Dhanush — Live Corporate Set"
        >
          <div class="collab-video-thumb">
            <img
              src="https://img.youtube.com/vi/ikj-Juss6PM/maxresdefault.jpg"
              alt="DJ VIC × MC Dhanush — Live Corporate Set"
              onerror="this.src='https://img.youtube.com/vi/ikj-Juss6PM/hqdefault.jpg'"
              loading="lazy"
            />
            <div class="collab-video-overlay">
              <div class="collab-play-btn">
                <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="collab-video-label">Watch the Collab in Action</span>
            </div>
          </div>
        </a>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         5. TRUSTED BY
    ══════════════════════════════════════════ -->
    <section id="corporate-clients" class="section-alt">
      <div class="section-label">Track Record</div>
      <h2>Trusted by Leading Brands</h2>
      <p class="section-sub">
        A growing roster of corporate clients across Bangalore and beyond — from startups
        to Fortune 500 companies.
      </p>
      <div class="logo-grid">
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/200px-SAP_2011_logo.svg.png" alt="SAP" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/82/PepsiCo_%282025%2C_wordmark%29.svg/200px-PepsiCo_%282025%2C_wordmark%29.svg.png" alt="PepsiCo" /></div>
        <div class="logo-item"><img src="https://www.microland.com/assets/images/logo.svg" alt="Microland" /></div>
        <div class="logo-item"><img src="https://nest-platform-assets.porter.in/porter_logo_v3_0186438e12.svg" alt="Porter" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/d/db/KPMG_blue_logo.svg/200px-KPMG_blue_logo.svg.png" alt="KPMG" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c9/Logo_of_JPMorganChase_2024.svg/200px-Logo_of_JPMorganChase_2024.svg.png" alt="JPMorgan Chase" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/en/thumb/a/a0/RitzCarlton.svg/200px-RitzCarlton.svg.png" alt="The Ritz-Carlton" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Infosys_logo.svg/200px-Infosys_logo.svg.png" alt="Infosys" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Apple_logo_black.svg/200px-Apple_logo_black.svg.png" alt="Apple" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b6/BHP_2017_logo.svg/200px-BHP_2017_logo.svg.png" alt="BHP" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/bc/Decathlon_-_logo_%28France%2C_2024%29.svg/200px-Decathlon_-_logo_%28France%2C_2024%29.svg.png" alt="Decathlon" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/28/HDFC_Bank_Logo.svg/200px-HDFC_Bank_Logo.svg.png" alt="HDFC Bank" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5b/Walmart_logo_%282025%29.svg/200px-Walmart_logo_%282025%29.svg.png" alt="Walmart" /></div>
        <div class="logo-item"><img src="https://thehouseofrare.com/cdn/shop/files/hor_1_ac34ebd3-4498-4f64-b50b-ae6bd5404df8_250x.png?v=1720351640" alt="Rare Rabbit" /></div>
        <div class="logo-item"><img src="https://assets.furlenco.com/image/upload/dpr_1.0,f_auto,q_auto/v1/s3-furlenco-images/yoda/furlenco-logo.png" alt="Furlenco" /></div>
        <div class="logo-item"><img src="https://upload.wikimedia.org/wikipedia/en/thumb/d/d3/Britannia_Industries_logo.svg/200px-Britannia_Industries_logo.svg.png" alt="Britannia" /></div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         6. CLOSING CTA
    ══════════════════════════════════════════ -->
    <section id="corporate-cta" class="cta-section">
      <h2>Ready to Elevate Your Next Corporate Event?</h2>
      <p class="section-sub">
        Get in touch and let's build the perfect music experience for your team.
      </p>
      <a href="/#contact" class="cta-btn cta-btn--gold">Book DJ VIC &rarr;</a>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  #corporate-hero {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 30%, rgba(0,0,0,0.5) 65%, rgba(0,0,0,0.2) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%),
      url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1600&q=85');
    background-position: center center;
  }

  /* ─── Gold CTA button ──────────────────────────── */
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 2rem;
  }
  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }
  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }

  /* ─── Section shared ──────────────────────────── */
  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: var(--white);
  }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 700px;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .section-alt {
    background: rgba(0,0,0,0.25);
  }

  /* ─── About stats grid ────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
    margin-top: 2.5rem;
  }

  .about-card {
    background: #0d0d0d;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .about-stat {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--gold);
    line-height: 1;
  }

  .about-plus {
    font-size: 0.6em;
    vertical-align: super;
  }

  .about-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  /* ─── Formats two-col section ─────────────────── */
  #corporate-services {
    background: #0a0a0a;
    padding: 0;
  }

  .formats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 80px 60px;
  }

  .formats-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--gold);
    display: inline-block;
  }

  .formats-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    line-height: 1.1;
    margin-top: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .formats-heading::before {
    display: none;
  }

  .formats-body {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    max-width: none;
    margin-bottom: 0;
  }

  .formats-cta {
    margin-top: 2rem;
    padding: 14px 32px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }

  .formats-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.25rem;
  }

  .format-tag {
    border: 1px solid var(--gold);
    color: var(--gold);
    background: transparent;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
    cursor: default;
  }

  .format-tag:hover {
    background: rgba(201,168,76,0.1);
  }

  /* ─── Collaboration two-col ──────────────────── */
  #corporate-collab {
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .collab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .collab-left h2 {
    margin-bottom: 1.25rem;
  }

  .collab-body {
    color: rgba(255,255,255,0.68);
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .collab-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .collab-list li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    padding-left: 1.25rem;
    position: relative;
  }

  .collab-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  /* ─── Collab video ────────────────────────────── */
  .collab-video {
    display: block;
    text-decoration: none;
  }

  .collab-video-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.2);
  }

  .collab-video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .collab-video:hover .collab-video-thumb img {
    transform: scale(1.03);
  }

  .collab-video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: background 0.3s;
  }

  .collab-video:hover .collab-video-overlay {
    background: rgba(0,0,0,0.25);
  }

  .collab-play-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--gold);
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, background 0.2s;
  }

  .collab-video:hover .collab-play-btn {
    transform: scale(1.1);
    background: var(--gold-light, #e0c060);
  }

  .collab-play-btn svg {
    margin-left: 3px;
  }

  .collab-video-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
  }

  /* ─── Logo grid ───────────────────────────────── */
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    margin-top: 2.5rem;
  }

  .logo-item {
    background: #141414;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 2.5rem;
    transition: background 0.2s;
  }

  .logo-item:hover {
    background: #1e1e1e;
  }

  .logo-item img {
    max-width: 130px;
    max-height: 48px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1) opacity(0.85);
    transition: filter 0.3s;
  }

  .logo-item:hover img {
    filter: none;
  }

  /* ─── Closing CTA ─────────────────────────────── */
  .cta-section {
    text-align: center;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }

  .cta-section h2::before {
    display: none;
  }

  .cta-section .section-sub {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .cta-section .cta-btn {
    margin-top: 2rem;
  }

  /* ─── Responsive ──────────────────────────────── */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .logo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .formats-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 3.5rem 2rem;
    }
    .collab-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 600px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .logo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .logo-item {
      padding: 1.5rem 1.25rem;
    }
    .logo-item img {
      max-width: 100px;
      max-height: 36px;
    }
    .collab-badge {
      width: 100%;
    }
    .formats-grid {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
