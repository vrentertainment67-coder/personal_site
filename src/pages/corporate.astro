---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

---

<Layout
  title="Corporate Event DJ Bangalore | DJ VIC | SAP Apple KPMG"
  description="Premium corporate DJ in Bangalore trusted by SAP, Apple, KPMG & 100+ brands. Conferences, product launches, annual days, and galas. Get a quote now."
  ogTitle="DJ VIC — Corporate Event DJ · Trusted by 100+ Brands Across India"
  ogDescription="Premium corporate DJ trusted by SAP, Apple, KPMG, JPMorgan and 100+ brands for product launches, annual days, conferences, and gala nights across India."
  ogImage="https://djvicofficial.com/images/og-corporate.jpg"
  schema={[{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Corporate Event DJ Bangalore",
    "provider": { "@id": "https://djvicofficial.com/#business" },
    "description": "Premium corporate DJ + MC for conferences, product launches, annual days and galas. Trusted by SAP, Apple, KPMG, JPMorgan.",
    "areaServed": "Bangalore, India"
  }, {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home",             "item": "https://djvicofficial.com/" },
      { "@type": "ListItem", "position": 2, "name": "Corporate Events", "item": "https://djvicofficial.com/corporate/" }
    ]
  }]}
>
  <Nav />

  <main id="main-content">

    <!-- ══════════════════════════════════════════
         1. HERO
    ══════════════════════════════════════════ -->
    <section id="corporate-hero" class="hero-bg" data-img-slot="corporate.hero">
      <h1>Built for<br/>Big Moments</h1>
      <p>High-energy experiences, delivered with precision and crowd control.</p>
      <a href="/book/" class="cta-btn cta-btn--gold">Book DJ VIC for Your Event</a>
    </section>

    <!-- ══════════════════════════════════════════
         2. ABOUT
    ══════════════════════════════════════════ -->
    <section id="corporate-about">
      <div class="section-label">Experience</div>
      <h2>19+ Years. 1360+ Events. 18 Countries.</h2>
      <p class="section-sub">
        DJ VIC is Bangalore's go-to corporate DJ — trusted by leading brands, event
        agencies, and HR teams to deliver premium music experiences that match the energy
        and identity of the occasion.
      </p>
      <div class="about-grid">
        <div class="about-card">
          <span class="about-stat">1360<span class="about-plus">+</span></span>
          <span class="about-label">Events Performed</span>
        </div>
        <div class="about-card">
          <span class="about-stat">19<span class="about-plus">+</span></span>
          <span class="about-label">Years in the Industry</span>
        </div>
        <div class="about-card">
          <span class="about-stat">18</span>
          <span class="about-label">Countries Performed In</span>
        </div>
        <div class="about-card">
          <span class="about-stat">100<span class="about-plus">+</span></span>
          <span class="about-label">Corporate Clients</span>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         3. WHAT DJ VIC BRINGS
    ══════════════════════════════════════════ -->
    <section id="corporate-services">
      <div class="formats-grid">

        <!-- Left: Statement block -->
        <div class="formats-left">
          <div class="formats-label">For Corporates</div>
          <h2 class="formats-heading">Every Brief.<br/>Every Room.<br/>Every Crowd.</h2>
          <p class="formats-body">
            From high-energy product launches to black-tie annual nights — DJ Vic reads
            the room, curates the set, and delivers an atmosphere that your guests will
            actually remember. No generic playlists. No filler. Just the right music at
            the right moment.
          </p>
          <p class="formats-body" style="margin-top:1rem;">
            DJ VIC is also known for his <strong style="color:var(--white);">audio-visual sets</strong> — original music synced with custom visuals, available as an elevated entertainment format for product launches, brand activations, and annual days.
          </p>
          <a href="/book/" class="cta-btn cta-btn--gold formats-cta">
            Get a Corporate Quote &rarr;
          </a>
        </div>

        <!-- Right: Format tags -->
        <div class="formats-right">
          <div class="formats-label">Formats We Perform At</div>
          <div class="formats-tags">
            <span class="format-tag">Conferences &amp; Summits</span>
            <span class="format-tag">Product Launches</span>
            <span class="format-tag">Annual Days &amp; Townhalls</span>
            <span class="format-tag">Corporate Celebrations</span>
            <span class="format-tag">Brand &amp; Experiential Events</span>
            <span class="format-tag">Award Nights &amp; Galas</span>
            <span class="format-tag">Office Parties &amp; Milestone Events</span>
            <span class="format-tag">Dealer &amp; Channel Partner Meets</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. DJ VIC × MC DHANUSH
    ══════════════════════════════════════════ -->
    <section id="corporate-collab">
      <div class="collab-grid">

        <!-- Left: text -->
        <div class="collab-left">
          <div class="section-label">Collaboration</div>
          <h2>DJ VIC &times; MC Dhanush</h2>
          <p class="collab-body">
            DJ VIC partners with MC Dhanush to deliver a complete DJ + MC entertainment
            experience built specifically for corporate events. Together, they bring
            precision crowd energy, seamless transitions, and bilingual hosting that
            keeps large audiences engaged from first session to last dance.
          </p>
          <ul class="collab-list">
            <li>Bilingual hosting — English &amp; Hindi</li>
            <li>Crowd warm-ups and game facilitation</li>
            <li>Award ceremony and annual day coverage</li>
            <li>Seamless DJ–MC handoffs for zero dead air</li>
          </ul>
        </div>

        <!-- Right: video -->
        <a
          href="https://youtu.be/ikj-Juss6PM"
          target="_blank"
          rel="noopener noreferrer"
          class="collab-video"
          aria-label="Watch DJ VIC × MC Dhanush — Live Corporate Set"
        >
          <div class="collab-video-thumb">
            <img
              src="https://img.youtube.com/vi/ikj-Juss6PM/maxresdefault.jpg"
              alt="DJ VIC × MC Dhanush — Live Corporate DJ and MC Set"
              onerror="this.src='https://img.youtube.com/vi/ikj-Juss6PM/hqdefault.jpg'"
              loading="lazy"
              width="1280"
              height="720"
            />
            <div class="collab-video-overlay">
              <div class="collab-play-btn">
                <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="collab-video-label">Watch the Collab in Action</span>
            </div>
          </div>
        </a>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         5. TRUSTED BY
    ══════════════════════════════════════════ -->
    <section id="corporate-clients" class="section-alt">
      <div class="section-label">Track Record</div>
      <h2>Trusted by Leading Brands</h2>
      <p class="section-sub">
        A growing roster of corporate clients across Bangalore and beyond — from startups
        to Fortune 500 companies.
      </p>
      <div class="logo-grid">
        <div class="logo-item"><img src="/images/clients/sap.svg"          alt="SAP"              loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/pepsico.svg"      alt="PepsiCo"          loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/microland.svg"    alt="Microland"        loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/porter.svg"       alt="Porter"           loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/kpmg.svg"         alt="KPMG"             loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/jpmorgan.svg"     alt="JPMorgan Chase"   loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/ritz-carlton.svg" alt="The Ritz-Carlton" loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/infosys.svg"      alt="Infosys"          loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/apple.svg"        alt="Apple"            loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/bhp.svg"          alt="BHP"              loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/decathlon.svg"    alt="Decathlon"        loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/hdfc.svg"         alt="HDFC Bank"        loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/walmart.svg"      alt="Walmart"          loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/rare-rabbit.png"  alt="Rare Rabbit"      loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/furlenco.png"     alt="Furlenco"         loading="lazy" width="200" height="60" /></div>
        <div class="logo-item"><img src="/images/clients/britannia.svg"    alt="Britannia"        loading="lazy" width="200" height="60" /></div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         6. FAQ
    ══════════════════════════════════════════ -->
    <section id="corporate-faq">
      <div class="faq-inner">
        <div class="section-label">Common Questions</div>
        <h2>Corporate Booking FAQ</h2>
        <div class="faq-grid">
          <details class="faq-item">
            <summary>Do you bring your own equipment?</summary>
            <p>Yes — full Pioneer CDJ setup with backup hardware. DJ VIC handles his own gear, professionally maintained, and will co-ordinate with the venue's sound team for seamless integration.</p>
          </details>
          <details class="faq-item">
            <summary>What music do you play at corporate events?</summary>
            <p>Fully tailored to the occasion and brief. Cocktail hours typically get lounge and ambient sets; annual days and brand activations move to high-energy commercial and Bollywood. DJ VIC reads the room in real time and adjusts accordingly.</p>
          </details>
          <details class="faq-item">
            <summary>Do you work with event management agencies?</summary>
            <p>Yes — a significant share of corporate bookings come through agencies. DJ VIC is comfortable liaising directly with the production team, following AV schedules, and operating within the show-flow.</p>
          </details>
          <details class="faq-item">
            <summary>Can you travel outside Bangalore for corporate events?</summary>
            <p>Absolutely. DJ VIC has performed at corporate events across India and in 18 countries. Travel and accommodation requirements are discussed during the booking process.</p>
          </details>
          <details class="faq-item">
            <summary>How far in advance should we book?</summary>
            <p>4–6 weeks is the recommended minimum. Peak season (October–February) and large-format events can book up to 3 months in advance. The earlier you confirm, the better the chance of securing your preferred date.</p>
          </details>
          <details class="faq-item">
            <summary>Is the DJ + MC package always with MC Dhanush?</summary>
            <p>The collaborative DJ + MC format features DJ VIC alongside MC Dhanush for bilingual hosting. It's available as an add-on to the core DJ booking. Get in touch to discuss the right format for your event.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         7. CLOSING CTA
    ══════════════════════════════════════════ -->
    <section id="corporate-cta" class="cta-section">
      <h2>Ready to Elevate Your Next Corporate Event?</h2>
      <p class="section-sub">
        Get in touch and let's build the perfect music experience for your team.
      </p>
      <a href="/book/" class="cta-btn cta-btn--gold">Book DJ VIC &rarr;</a>
    </section>

    <div class="corp-explore-strip">
      <span class="corp-explore-label">Also available for</span>
      <a href="/nightlife/">Club &amp; Nightlife &rarr;</a>
      <a href="/private-events/">Private Events &rarr;</a>
      <a href="/festivals/">Festivals &rarr;</a>
      <a href="/weddings/">Weddings &rarr;</a>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  #corporate-hero {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 30%, rgba(0,0,0,0.5) 65%, rgba(0,0,0,0.2) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%),
      url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1600&q=85');
    background-position: center center;
  }

  /* ─── Gold CTA button ──────────────────────────── */
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 2rem;
  }
  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }
  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }

  /* ─── Section shared ──────────────────────────── */
  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: var(--white);
  }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 700px;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .section-alt {
    background: rgba(0,0,0,0.25);
  }

  /* ─── About stats grid ────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
    margin-top: 2.5rem;
  }

  .about-card {
    background: #0d0d0d;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .about-stat {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--gold);
    line-height: 1;
  }

  .about-plus {
    font-size: 0.6em;
    vertical-align: super;
  }

  .about-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  /* ─── Formats two-col section ─────────────────── */
  #corporate-services {
    background: #0a0a0a;
    padding: 0;
  }

  .formats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 80px 60px;
  }

  .formats-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--gold);
    display: inline-block;
  }

  .formats-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    line-height: 1.1;
    margin-top: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .formats-heading::before {
    display: none;
  }

  .formats-body {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    max-width: none;
    margin-bottom: 0;
  }

  .formats-cta {
    margin-top: 2rem;
    padding: 14px 32px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }

  .formats-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.25rem;
  }

  .format-tag {
    border: 1px solid var(--gold);
    color: var(--gold);
    background: transparent;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
    cursor: default;
  }

  .format-tag:hover {
    background: rgba(201,168,76,0.1);
  }

  /* ─── Collaboration two-col ──────────────────── */
  #corporate-collab {
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .collab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .collab-left h2 {
    margin-bottom: 1.25rem;
  }

  .collab-body {
    color: rgba(255,255,255,0.68);
    font-size: 0.9375rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .collab-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .collab-list li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    padding-left: 1.25rem;
    position: relative;
  }

  .collab-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  /* ─── Collab video ────────────────────────────── */
  .collab-video {
    display: block;
    text-decoration: none;
  }

  .collab-video-thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.2);
  }

  .collab-video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .collab-video:hover .collab-video-thumb img {
    transform: scale(1.03);
  }

  .collab-video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: background 0.3s;
  }

  .collab-video:hover .collab-video-overlay {
    background: rgba(0,0,0,0.25);
  }

  .collab-play-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--gold);
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, background 0.2s;
  }

  .collab-video:hover .collab-play-btn {
    transform: scale(1.1);
    background: var(--gold-light, #e0c060);
  }

  .collab-play-btn svg {
    margin-left: 3px;
  }

  .collab-video-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
  }

  /* ─── Logo grid ───────────────────────────────── */
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    /* Real per-cell borders (top+left on the container, right+bottom on each
       item) instead of a 1px gap showing a background through — the gap trick
       breaks at fractional zoom levels (subpixel rounding drops the lines). */
    border-top: 1px solid rgba(255,255,255,0.07);
    border-left: 1px solid rgba(255,255,255,0.07);
    margin-top: 2.5rem;
  }

  .logo-item {
    background: #141414;
    border-right: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 2.5rem;
    transition: background 0.2s;
  }

  .logo-item:hover {
    background: #1e1e1e;
  }

  .logo-item img {
    max-width: 130px;
    max-height: 48px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1) opacity(0.85);
    transition: filter 0.3s;
  }

  .logo-item:hover img {
    filter: none;
  }

  /* ─── FAQ ─────────────────────────────────────── */
  #corporate-faq {
    border-top: 1px solid rgba(201,168,76,0.08);
    background: #060606;
  }

  .faq-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 5rem 2.5rem;
  }

  .faq-inner h2 { margin-bottom: 2.5rem; }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid rgba(201,168,76,0.1);
  }

  .faq-item {
    border-bottom: 1px solid rgba(201,168,76,0.1);
    border-right: 1px solid rgba(201,168,76,0.1);
  }

  .faq-item:nth-child(even) { border-right: none; }
  .faq-item:nth-last-child(-n+2) { border-bottom: none; }

  .faq-item summary {
    padding: 1.4rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--white);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 3rem;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    color: var(--gold);
    font-weight: 400;
    line-height: 1;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .faq-item[open] summary { color: var(--gold); }

  .faq-item p {
    padding: 0 1.5rem 1.4rem;
    font-size: 0.84rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
    margin: 0;
  }

  @media (max-width: 700px) {
    .faq-grid { grid-template-columns: 1fr; }
    .faq-item { border-right: none; }
    .faq-item:nth-last-child(-n+2) { border-bottom: 1px solid rgba(201,168,76,0.1); }
    .faq-item:last-child { border-bottom: none; }
    .faq-inner { padding-inline: 1.25rem; }
  }

  /* ─── Closing CTA ─────────────────────────────── */
  .cta-section {
    text-align: center;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }

  .cta-section h2::before {
    display: none;
  }

  .cta-section .section-sub {
    margin-left: auto;
    margin-right: auto;
