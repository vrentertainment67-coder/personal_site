---
// src/pages/inventory.astro
// Private inventory master list for Lloyds Pro Sound. Standalone tool page:
// no public site nav/footer, noindex + nofollow. Shares its catalogue with
// the invoice builder (localStorage INVENTORY_KEY).
import InventoryMaster from '../components/InventoryMaster.jsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lloyds Pro Sound — Inventory Master</title>
    <meta name="description" content="Private equipment master list for Lloyds Pro Sound." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root { color-scheme: light dark; }
      html, body { margin: 0; padding: 0; }
      body { background: #14120e; font-family: 'Space Grotesk', system-ui, sans-serif; color: #eee; }

      .inv-root { --gold: #c9a84c; --gold-dk: #a9883a; --ink: #1a1a1a; --line: #d9d4c8; --muted: #6a6a6a; }

      /* Toolbar */
      .inv-toolbar {
        position: sticky; top: 0; z-index: 20;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
        padding: 0.85rem 1.25rem; background: rgba(14,12,9,0.96);
        backdrop-filter: blur(10px); border-bottom: 1px solid rgba(201,168,76,0.22);
      }
      .inv-brand { display: flex; align-items: baseline; gap: 0.6rem; }
      .inv-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 0.18em; color: #fff; }
      .inv-sub { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); }
      .inv-actions { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
      .inv-link { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: #d8d1bd; text-decoration: none; }
      .inv-link:hover { color: var(--gold); }
      .inv-btn {
        font-family: 'Space Grotesk', sans-serif; font-size: 0.72rem; font-weight: 600;
        letter-spacing: 0.12em; text-transform: uppercase; padding: 0.6rem 1.1rem; border-radius: 3px;
        cursor: pointer; border: 1px solid transparent; transition: background 0.18s, color 0.18s, border-color 0.18s;
      }
      .inv-btn-gold { background: var(--gold); color: #14120e; }
      .inv-btn-gold:hover { background: #e0c672; }
      .inv-btn-ghost { background: transparent; color: #d8d1bd; border-color: rgba(201,168,76,0.4); }
      .inv-btn-ghost:hover { border-color: var(--gold); color: #fff; }

      /* Sheet */
      .inv-sheet {
        background: #fff; color: var(--ink); max-width: 1000px; margin: 2rem auto; padding: 2.5rem 2.75rem;
        box-shadow: 0 10px 45px rgba(0,0,0,0.5); line-height: 1.5;
      }
      .inv-sheet input, .inv-sheet select {
        font-family: inherit; font-size: inherit; color: inherit; background: transparent;
        border: 1px solid transparent; border-radius: 3px; padding: 3px 5px; width: 100%;
        transition: border-color 0.15s, background 0.15s;
      }
      .inv-sheet input:hover, .inv-sheet select:hover { border-color: var(--line); }
      .inv-sheet input:focus, .inv-sheet select:focus { outline: none; border-color: var(--gold); background: #fdf9ef; }

      .inv-head {
        display: flex; justify-content: space-between; align-items: flex-end; gap: 1.5rem;
        border-bottom: 2px solid var(--ink); padding-bottom: 1rem; flex-wrap: wrap;
      }
      .inv-title {
        font-family: 'Bebas Neue', sans-serif; font-weight: 400; font-size: 2.4rem; letter-spacing: 0.06em;
        text-transform: uppercase; color: var(--ink); margin: 0; line-height: 1;
      }
      .inv-tagline { font-size: 0.78rem; color: var(--muted); margin: 0.35rem 0 0; }
      .inv-summary { display: flex; gap: 1.5rem; }
      .inv-summary div { text-align: right; }
      .inv-summary strong {
        display: block; font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; color: var(--gold-dk); line-height: 1;
      }
      .inv-summary span { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); }

      /* Controls */
      .inv-controls { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin: 1.1rem 0 0.5rem; }
      .inv-search {
        flex: 1; min-width: 200px; border: 1px solid var(--line) !important; border-radius: 4px;
        padding: 0.5rem 0.7rem !important; font-size: 0.85rem;
      }
      .inv-cats { display: flex; gap: 0.3rem; flex-wrap: wrap; }
      .inv-cat {
        font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600;
        padding: 0.4rem 0.7rem; border: 1px solid var(--line); border-radius: 20px; background: #fff;
        color: var(--muted); cursor: pointer; transition: all 0.15s;
      }
      .inv-cat:hover { border-color: var(--gold-dk); color: var(--ink); }
      .inv-cat.is-active { background: var(--ink); border-color: var(--ink); color: #fff; }
      .inv-add { white-space: nowrap; }

      .inv-empty { color: var(--muted); font-style: italic; padding: 2rem 0; text-align: center; }

      /* Category blocks */
      .inv-cat-block { margin-top: 1.5rem; }
      .inv-cat-head {
        display: flex; align-items: baseline; justify-content: space-between;
        border-bottom: 1.5px solid var(--ink); padding-bottom: 0.3rem; margin-bottom: 0.35rem;
      }
      .inv-cat-head h3 {
        font-family: 'Bebas Neue', sans-serif; font-weight: 400; font-size: 1.25rem; letter-spacing: 0.1em;
        text-transform: uppercase; color: var(--ink); margin: 0;
      }
      .inv-cat-count { font-size: 0.68rem; color: var(--muted); }

      .inv-table { width: 100%; border-collapse: collapse; }
      .inv-table thead th {
        font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted);
        text-align: left; font-weight: 600; padding: 0.2rem 0.4rem; border-bottom: 1px solid var(--line);
      }
      .inv-table tbody td { padding: 1px 0.4rem; border-bottom: 1px solid #f0ede4; vertical-align: middle; font-size: 0.82rem; }
      .inv-c-cat { width: 170px; }
      .inv-c-rate { width: 120px; }
      .inv-c-qty { width: 95px; }
      .inv-c-notes { width: 24%; }
      .inv-c-del { width: 26px; }
      .inv-c-rate, .inv-c-qty { text-align: right; }
      .inv-table thead .inv-c-rate, .inv-table thead .inv-c-qty { text-align: right; }
      .inv-c-rate { display: flex; align-items: center; }
      .inv-rupee { color: var(--muted); font-size: 0.8rem; }
      .inv-num { text-align: right; font-variant-numeric: tabular-nums; }
      .inv-num::-webkit-outer-spin-button, .inv-num::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
      .inv-num { -moz-appearance: textfield; }
      .inv-catsel { font-size: 0.72rem; color: var(--muted); }
      .inv-icon-btn {
        width: 20px; height: 20px; line-height: 1; border-radius: 3px; border: 1px solid transparent;
        background: transparent; color: #c05; cursor: pointer; font-size: 1rem; opacity: 0.35;
        transition: opacity 0.15s, background 0.15s;
      }
      .inv-icon-btn:hover { opacity: 1; background: #fbeaea; }

      .inv-foot {
        display: flex; justify-content: space-between; gap: 1rem; margin-top: 2rem; padding-top: 0.75rem;
        border-top: 2px solid var(--ink); font-size: 0.7rem; color: var(--muted);
      }

      /* Print */
      @media print {
        @page { size: A4 landscape; margin: 10mm; }
        body { background: #fff !important; }
        .no-print { display: none !important; }
        .inv-sheet { box-shadow: none; margin: 0; max-width: none; padding: 0; }
        .inv-sheet input, .inv-sheet select { border-color: transparent !important; background: transparent !important; }
        .inv-cat-block { break-inside: avoid; }
      }

      @media (max-width: 640px) {
        .inv-sheet { padding: 1.4rem 1rem; margin: 1rem 0.5rem; }
        .inv-c-notes { display: none; }
        .inv-head { align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <InventoryMaster client:only="react" />
  </body>
</html>
