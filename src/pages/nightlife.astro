---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Nightlife DJ in Bangalore — Club Nights & Bar Events | DJ VIC"
  description="DJ VIC is one of Bangalore's top nightlife DJs. Known for high-energy club sets and audio-visual performances spanning Bollywood, hip-hop, EDM, and commercial house."
  canonical="https://djvicofficial.com/nightlife/"
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Nightlife DJ by DJ VIC",
    "provider": { "@type": "LocalBusiness", "name": "DJ VIC Official", "url": "https://djvicofficial.com" },
    "serviceType": "Nightlife & Club DJ",
    "areaServed": ["Bangalore", "India"],
    "description": "High-energy club sets spanning Bollywood, hip-hop, EDM, and commercial house for Bangalore's top bars and clubs.",
    "url": "https://djvicofficial.com/nightlife/"
  }}
>
  <Nav />
  <main id="main-content">

    <section id="nightlife-hero" class="hero-bg">
      <div class="section-label">Club & Bar Events</div>
      <h1>Nightlife DJ in Bangalore</h1>
      <p class="tagline">From First Drop to Last Call</p>
      <p>
        19+ years reading Bangalore's dance floors. DJ VIC brings the energy,
        the programming, and the instinct to keep every room locked in all night.
      </p>
      <a href={`${base}/#contact`} class="cta-btn cta-btn--gold">Book DJ VIC for Your Venue &rarr;</a>
    </section>

    <section id="nightlife-about">
      <div class="section-label">What We Do</div>
      <h2>Built for the Dance Floor</h2>
      <p class="section-sub">
        Guest slots, headline nights, and concept events — DJ VIC
        delivers a set calibrated to the room, the crowd, and the energy of the moment.
      </p>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-label">Bollywood & Commercial</span>
          <p>The Bollywood hits and remix edits that keep Indian dance floors moving from 10pm to close.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">Hip-Hop & R&B</span>
          <p>Current chart hits and classic anthems — seamlessly blended into the set at the right moment.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">EDM & House</span>
          <p>Commercial EDM to deep and tech house — DJ VIC reads the room and takes it where it needs to go.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">Audio Visual Sets</span>
          <p>DJ VIC is known for his audio-visual performances — music and visuals composed and synced together for a full sensory experience.</p>
        </div>
      </div>
    </section>

    <section id="nightlife-cta" class="cta-section">
      <h2>Book DJ VIC for Your Club Night</h2>
      <p class="section-sub">Get in touch to discuss availability, formats, and what works best for your venue.</p>
      <a href={`${base}/#contact`} class="cta-btn cta-btn--gold">Get in Touch &rarr;</a>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  #nightlife-hero {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 30%, rgba(0,0,0,0.5) 65%, rgba(0,0,0,0.2) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.75) 100%),
      url('https://images.unsplash.com/photo-1571266028243-e4733b0f0bb0?w=1600&q=85');
    background-position: center center;
  }
  .section-label {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem;
  }
  h2 { color: var(--white); }
  .section-sub { color: rgba(255,255,255,0.65); max-width: 680px; margin-top: 0.5rem; margin-bottom: 2rem; }
  .cta-btn {
    display: inline-block; padding: 0.85rem 2rem; font-family: var(--font-body);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px; margin-top: 2rem;
  }
  .cta-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .cta-btn--gold:hover { background: var(--gold-light); color: #000; transform: translateY(-1px); }
  .feature-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 2rem;
  }
  .feature-item {
    background: #111; border: 1px solid rgba(201,168,76,0.12);
    border-left: 3px solid var(--gold); padding: 1.5rem;
  }
  .feature-label {
    display: block; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem;
  }
  .feature-item p { font-size: 0.875rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin: 0; }
  .cta-section { text-align: center; background: rgba(0,0,0,0.4); border-top: 1px solid rgba(201,168,76,0.1); }
  .cta-section h2::before { display: none; }
  .cta-section .section-sub { margin-left: auto; margin-right: auto; text-align: center; }
  @media (max-width: 600px) { .feature-grid { grid-template-columns: 1fr; } }
</style>
