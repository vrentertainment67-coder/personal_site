---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const remixes = [
  { id: "wHOB8H-HB_Y", title: "VIC - Tu Hi Meri Shab Hai X Say What (Afro Mashup)" },
  { id: "Hgb_g-xBblw", title: "Tera hone laga hoon X Viva La Vida | Mashup | Atif Aslam | Coldplay | VIC" },
  { id: "ssFIKwChfHc", title: "Sooraj Ki Baahon Mein x Forever (Mashup) | VIC | Chris Brown | Zindagi Na Milegi Dobara" },
  { id: "modKUclnVJY", title: "Sach Keh Raha Hai X Tujhe Bhula Diya X I Adore You | VIC Mashup" },
  { id: "aN2BIfUNUs4", title: "Dil Luteya (Desi Mix) – Jazzy B Ft. Apache Indian | DJ VIC Remix" },
  { id: "KWUoJJ6xsfk", title: "Kesariya x Can't Stop The Feeling — Bollywood Meets Pop | VIC Mashup" },
  { id: "rcGuVSoki6U", title: "Its that Oo Antava Time | Mashup | DSP | Pushpa | Fisher | VIC" },
  { id: "MXxbN1xYteY", title: "Tere Liye | Progressive Edit | VIC | Prince | Atif Aslam" },
  { id: "zhaNQwYQi_8", title: "Aaj Ki Raat | Progressive Edit | VIC | Stree 2 | Tamannaah Bhatia | Sachin-Jigar" },
  { id: "gf0hYLxr6eo", title: "Kahin Aag Lage X Rejection | Tech Mix | VIC" },
  { id: "Yx3pD4uhJRE", title: "Titliaan – Progressive Rework | DJ VIC" },
  { id: "h48i6wSQjso", title: "Boom Boom X Body Funk | Nazia Hassan | VIC | Remix" },
  { id: "5oA311R6Wkg", title: "Tamma Tamma x Makeba | Sanjay Dutt | Madhuri Dixit | VIC | Remix" },
  { id: "PxgvwE1nZmw", title: "Jimmy (VIC Disco Edit) | Bollywood Remix 2025" },
  { id: "4oTBe25wvE0", title: "Ghungroo Remix | DJ VIC Sun n Sand Rework (War)" },
];

const platforms = [
  {
    name: "Audiomack",
    href: "https://audiomack.com/vrentertainment67",
    desc: "Free streaming & download",
  },
  {
    name: "Hearthis.at",
    href: "https://hearthis.at/djvicofficial",
    desc: "Stream DJ sets",
  },
  {
    name: "Mixcloud",
    href: "https://www.mixcloud.com/thedjvicofficial/",
    desc: "Full DJ mixes",
  },
];
---

<Layout
  title="Free DJ Remixes & Mashups Download — DJ VIC | Bangalore"
  description="Stream and download free DJ mashups and remixes by DJ VIC — Bangalore's leading DJ and Universal Music partner. English-Bollywood fusion mixes on Audiomack, Mixcloud, and Hearthis."
  schema={{
    "@context": "https://schema.org",
    "@type": "MusicPlaylist",
    "name": "DJ VIC Remixes & Mashups",
    "description": "Free DJ mashups and remixes by DJ VIC — English-Bollywood fusion mixes.",
    "url": "https://djvicofficial.com/remixes/",
    "author": { "@id": "https://djvicofficial.com/#person" }
  }}
>
  <Nav />

  <main id="main-content">

    <section id="remixes-hero" class="hero-section">
      <div class="hero-inner">
        <div class="section-label">Free Downloads</div>
        <h1>Remixes &amp; Mashups</h1>
        <p class="hero-sub">From the dance floor to your playlist — remixed and reimagined.</p>
      </div>
    </section>

    <section id="remixes-platforms">
      <div class="section-label">Stream &amp; Download Free</div>
      <h2>Available On</h2>
      <div class="platforms-grid">
        {platforms.map((p) => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="platform-card">
            <div class="platform-info">
              <span class="platform-name">{p.name}</span>
              <span class="platform-desc">{p.desc}</span>
            </div>
            <span class="platform-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <section id="remixes-grid">
      <div class="section-label">Latest Tracks</div>
      <h2>Watch &amp; Listen</h2>
      <div class="yt-grid">
        {remixes.map(({ id, title }) => (
          <a
            href={`https://youtu.be/${id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="yt-card"
          >
            <div class="yt-thumb">
              <img
                src={`https://img.youtube.com/vi/${id}/maxresdefault.jpg`}
                alt={title}
                loading="lazy"
              />
              <div class="yt-play">
                <svg viewBox="0 0 68 48" width="52" height="37">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--gold)"/>
                  <path d="M45 24 27 14v20" fill="#000"/>
                </svg>
              </div>
            </div>
            <p class="yt-caption">{title}</p>
          </a>
        ))}
      </div>
    </section>

    <section id="remixes-cta" class="cta-section">
      <h2>Want DJ VIC at Your Event?</h2>
      <p class="section-sub">Hear what he can do — then book him for your wedding, corporate night, or club event.</p>
      <a href="/#contact" class="cta-btn cta-btn--gold">Book DJ VIC &rarr;</a>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  .hero-section {
    min-height: 40svh;
    display: flex;
    align-items: flex-end;
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 40%, rgba(0,0,0,0.5) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%),
      url('https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=1600&q=85');
    background-size: cover;
    background-position: center;
    padding: 0;
  }

  .hero-inner {
    padding: 8rem 2.5rem 4rem;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
  }

  .hero-section h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 1rem;
    max-width: 50ch;
    margin: 0;
  }

  /* ─── Section shared ──────────────────────────── */
  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: var(--white);
    margin-bottom: 2rem;
  }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 600px;
    margin-bottom: 2rem;
  }

  /* ─── Platforms ───────────────────────────────── */
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
  }

  .platform-card {
    background: #0d0d0d;
    padding: 2rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .platform-card:hover {
    background: #161616;
  }

  .platform-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .platform-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--white);
  }

  .platform-desc {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.05em;
  }

  .platform-arrow {
    font-size: 1.1rem;
    color: var(--gold);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .platform-card:hover .platform-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ─── YouTube grid ────────────────────────────── */
  .yt-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .yt-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
  }

  .yt-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
    border-radius: 4px;
  }

  .yt-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .yt-card:hover .yt-thumb img {
    transform: scale(1.04);
  }

  .yt-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.45);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .yt-card:hover .yt-play {
    opacity: 1;
  }

  .yt-caption {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── CTA section ─────────────────────────────── */
  .cta-section {
    text-align: center;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }

  .cta-section h2::before { display: none; }

  .cta-section .section-sub {
    margin-inline: auto;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 1.5rem;
    text-decoration: none;
  }

  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }

  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }

  /* ─── Responsive ──────────────────────────────── */
  @media (max-width: 900px) {
    .yt-grid { grid-template-columns: repeat(3, 1fr); }
    .platforms-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 500px) {
    .yt-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-inner { padding-inline: 1.25rem; }
  }
</style>
