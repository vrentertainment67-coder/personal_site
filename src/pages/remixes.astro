import Footer from '../components/Footer.astro';

const ytVideos = [
  "wHOB8H-HB_Y","Hgb_g-xBblw","ssFIKwChfHc","modKUclnVJY","aN2BIfUNUs4",
  "KWUoJJ6xsfk","rcGuVSoki6U","MXxbN1xYteY","zhaNQwYQi_8","gf0hYLxr6eo",
  "Yx3pD4uhJRE","h48i6wSQjso","5oA311R6Wkg","PxgvwE1nZmw","4oTBe25wvE0",
];

const audiomackSlugs = [
  "badtameezdil",
  "ishqjalakar",
  "rambhaho",
  "luttlegaya",
  "softly",
  "69ca78246aaaa",
  "69ca7829bfeb3",
  "69ca782ad85f6",
  "69ca782b2ec06",
  "69ca782ead011",
  "69ca782ef1c46",
  "rapture-x-lat-lag-gayee",
  "69ca7833c1c91",
  "69ca7834567ec",
  "69ca7835af06e",
  "yeah-x-amplifier-usher-x-imran-khan",
  "saturday-saturday-tech-house-edit",
  "69ca783b117d5",
  "dola-re-x-waves-wavs",
  "yeh-ek-zindagi-afro-edit",
  "69ca7847102f9",
  "tere-liye-x-fallen-leaf",
  "besharam-rang-x-mwaki",
  "69ca784f8c695",
