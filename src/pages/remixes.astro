---

<Layout
  title="Bollywood Mashups & Remixes | DJ VIC Official"
  description="Stream and download free Bollywood mashups and remixes by DJ VIC — Universal Music partner. English-Bollywood fusion mixes on YouTube and Audiomack."
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "MusicPlaylist",
      "name": "DJ VIC Remixes & Mashups",
      "description": "Free DJ mashups and remixes by DJ VIC — English-Bollywood fusion mixes.",
      "url": "https://djvicofficial.com/remixes/",
      "author": { "@id": "https://djvicofficial.com/#person" }
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",    "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Remixes", "item": "https://djvicofficial.com/remixes/" }
      ]
    }
  ]}
>
  <Nav />

  <main id="main-content">

    <section id="remixes-hero" class="hero-section">
      <div class="hero-inner">
        <h1>Remixes &amp; Mashups</h1>
        <p class="hero-sub">From the dance floor to your playlist — remixed and reimagined.</p>
      </div>
    </section>

    <section id="remixes-grid">
      <div class="section-label">Latest Tracks</div>
      <h2>Listen</h2>
      <div class="yt-grid">
        {remixes.map(({ id, slug, title, detail, thumb }) => (
          <div class="yt-card">
            <div class="yt-thumb">
              <img
                src={`https://img.youtube.com/vi/${id}/${thumb ?? 'hqdefault'}.jpg`}
                alt={title}
                loading="lazy"
                width="480"
                height="360"
              />
              <button
                class="yt-play-btn"
                data-slug={slug}
                data-title={title}
                data-yt-id={id}
                aria-label={`Play ${title}`}
              >
                <svg viewBox="0 0 24 24" width="30" height="30" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </div>
            {detail
              ? <a href={`/remixes/${slug}/`} class="yt-caption">{title}</a>
              : <a href={`https://www.youtube.com/watch?v=${id}`} target="_blank" rel="noopener noreferrer" class="yt-caption">{title}</a>
            }
          </div>
        ))}
      </div>
    </section>

    <section id="remixes-platforms">
      <div class="section-label">More Platforms</div>
      <h2>Available On</h2>
      <div class="platforms-grid">
        {platforms.map((p) => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="platform-card">
            <div class="platform-info">
              <span class="platform-name">{p.name}</span>
              <span class="platform-desc">{p.desc}</span>
            </div>
            <span class="platform-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <section id="remixes-cta" class="cta-section">
      <h2>Want DJ VIC at Your Event?</h2>
      <p class="section-sub">Hear what he can do — then book him for your wedding, corporate night, or club event.</p>
      <a href="/book/" class="cta-btn cta-btn--gold">Book DJ VIC &rarr;</a>
      <div class="remixes-explore">
        <a href="/weddings/">Wedding DJ Bangalore &rarr;</a>
        <a href="/thevicfix/">The VIC Fix Podcast &rarr;</a>
        <a href="/nightlife/">Club &amp; Nightlife DJ &rarr;</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  .hero-section {
    min-height: 40svh;
    display: flex;
    align-items: flex-end;
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 40%, rgba(0,0,0,0.5) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%),
      url('https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=1600&q=85');
    background-size: cover;
    background-position: center;
    padding: 0;
  }

  .hero-inner {
    padding: 8rem 2.5rem 4rem;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
  }

  .hero-section h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 1rem;
    max-width: 50ch;
    margin: 0;
  }

  /* ─── Section shared ──────────────────────────── */
  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: var(--white);
    margin-bottom: 2rem;
  }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 600px;
    margin-bottom: 2rem;
  }

  /* ─── Platforms ───────────────────────────────── */
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
  }

  .platform-card {
    background: #0d0d0d;
    padding: 2rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .platform-card:hover {
    background: #161616;
  }

  .platform-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .platform-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--white);
  }

  .platform-desc {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.05em;
  }

  .platform-arrow {
    font-size: 1.1rem;
    color: var(--gold);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .platform-card:hover .platform-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ─── YouTube grid ────────────────────────────── */
  .yt-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .yt-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .yt-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
    border-radius: 4px;
  }

  .yt-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .yt-card:hover .yt-thumb img {
    transform: scale(1.04);
  }

  /* Play button overlay — triggers the music player */
  .yt-play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.48);
    border: none;
    color: #c9a84c;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.22s;
    padding: 0;
  }

  .yt-play-btn svg {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.6));
  }

  .yt-card:hover .yt-play-btn {
    opacity: 1;
  }

  .yt-play-btn:focus-visible {
    opacity: 1;
    outline: 2px solid var(--gold);
    outline-offset: -2px;
  }

  /* Caption — now a link to the remix detail page */
  .yt-caption {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-decoration: none;
    transition: color 0.18s;
  }

  .yt-caption:hover {
    color: rgba(255,255,255,0.85);
  }

  /* ─── CTA section ─────────────────────────────── */
  .cta-section {
    text-align: center;
    background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
  }

  .cta-section h2::before { display: none; }

  .cta-section .section-sub {
    margin-inline: auto;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 1.5rem;
    text-decoration: none;
  }

  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }

  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }

  /* ─── Remixes cross-link explore strip ───────── */
  .remixes-explore {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(201,168,76,0.1);
  }
  .remixes-explore a {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .remixes-explore a:hover { color: var(--gold, #c9a84c); }

  /* ─── Responsive ──────────────────────────────── */
  @media (max-width: 1100px) {
    .platforms-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .yt-grid { grid-template-columns: repeat(3, 1fr); }
    .platforms-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .platforms-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 500px) {
    .yt-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-inner { padding-inline: 1.25rem; }
  }
</style>

<script is:inline>
/* Wire play buttons → VIC Player via custom event.
   Uses data-vp-bound to avoid double-binding if the script re-runs. */
(function () {
  function bindPlayButtons() {
    document.querySelectorAll('.yt-play-btn:not([data-vp-bound])').forEach(function (btn) {
      btn.setAttribute('data-vp-bound', '1');
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        window.dispatchEvent(new CustomEvent('play-track', {
          detail: {
            slug:     btn.dataset.slug,
            title:    btn.dataset.title,
            youtubeId: btn.dataset.ytId,
          },
        }));
      });
    });
  }

  /* Run immediately for the current page load */
  bindPlayButtons();

  /* Re-run after View Transition navigations (add listener only once) */
  if (!window.__vicRemixBindInit) {
    window.__vicRemixBindInit = true;
    document.addEventListener('astro:page-load', bindPlayButtons);
  }
})();
</script>
