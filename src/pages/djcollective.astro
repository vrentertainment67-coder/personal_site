---
// Dedicated, shareable landing for The DJ Collective (Bengaluru) meetup.
// Its OWN Open Graph card so WhatsApp/Instagram/etc. preview the event —
// /thevicfix/ keeps its podcast preview untouched. Opens straight into the
// RSVP popup (auto-opens once per visitor + the big button).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DJCollectivePopup from '../components/DJCollectivePopup.jsx';
---

<Layout
  title="The DJ Collective, Bengaluru — RSVP"
  description="No agenda. Just Bengaluru's DJs catching up. RSVP for the next meetup of The DJ Collective, Bengaluru."
  ogTitle="The DJ Collective, Bengaluru — You're Invited"
  ogDescription="No agenda. Just Bengaluru's DJs catching up. Tap to RSVP for the next meetup."
  ogImage="https://djvicofficial.com/images/og-djcollective.jpg"
  canonical="https://djvicofficial.com/djcollective/"
>
  <Nav />
  <main id="main-content" class="djc-page">
    <section class="djcp-hero">
      <span class="djcp-eyebrow">You're invited</span>
      <h1 class="djcp-brand">The DJ Collective</h1>
      <span class="djcp-city">Bengaluru</span>
      <p class="djcp-tag">No agenda. Just Bengaluru's DJs catching up.<br />Let us know you're coming.</p>
      <button type="button" class="djcp-cta" data-djc-open>RSVP — Count me in</button>
      <p class="djcp-fine">No agenda. No headliner.</p>
    </section>
  </main>

  <DJCollectivePopup client:load />
  <Footer />
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Lora:ital@1&family=Inter:wght@400;500&display=swap');
  .djc-page { background: #080808; }
  .djcp-hero {
    min-height: 74vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 7.5rem 1.5rem 4.5rem;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,168,76,0.10), transparent 65%);
  }
  .djcp-eyebrow { font-family: 'Oswald', sans-serif; font-weight: 500; font-size: 0.8rem; letter-spacing: 0.34em; text-transform: uppercase; color: #C9A84C; }
  .djcp-brand { font-family: 'Oswald', sans-serif; font-weight: 700; font-size: clamp(2.6rem, 9vw, 5.5rem); line-height: 1; letter-spacing: 0.04em; text-transform: uppercase; color: #E0DCCF; margin: 1.2rem 0 0; }
  .djcp-city { font-family: 'Oswald', sans-serif; font-weight: 500; font-size: clamp(0.9rem, 2.5vw, 1.2rem); letter-spacing: 0.5em; text-transform: uppercase; color: #C9A84C; margin-top: 0.6rem; }
  .djcp-tag { font-family: 'Lora', serif; font-style: italic; font-size: clamp(1rem, 2.4vw, 1.3rem); line-height: 1.6; color: rgba(224,220,207,0.82); margin: 1.8rem 0 0; max-width: 44ch; }
  .djcp-cta { margin-top: 2.2rem; appearance: none; background: #C9A84C; color: #080808; border: 0; font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 1.05rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 1rem 2.3rem; border-radius: 4px; cursor: pointer; transition: filter 0.2s, transform 0.15s; }
  .djcp-cta:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .djcp-fine { font-family: 'Lora', serif; font-style: italic; font-size: 0.85rem; color: rgba(224,220,207,0.4); margin-top: 1.7rem; }
</style>
