---
// MOVED — the Collective now lives on its own domain.
// Source for the live page: /collective (deployed to bengalurudjscollective.com).
//
// This page only exists to catch old links (WhatsApp shares, Instagram bio,
// anything already printed) and hand them on. GitHub Pages can't issue a real
// 301, so this does the next best thing: rel=canonical pointing at the new
// URL so search engines consolidate there, plus an instant meta-refresh and a
// JS fallback. If djvicofficial.com's DNS sits on Cloudflare, add a Redirect
// Rule for /djcollective* → https://bengalurudjscollective.com/ to make it a
// true 301 and delete this file.
const NEW_URL = 'https://bengalurudjscollective.com/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bengaluru DJs Collective has moved</title>
    <link rel="canonical" href={NEW_URL} />
    <meta http-equiv="refresh" content={`0; url=${NEW_URL}`} />
    <meta name="description" content="The Bengaluru DJs Collective now lives at bengalurudjscollective.com." />
    <script is:inline define:vars={{ NEW_URL }}>window.location.replace(NEW_URL);</script>
    <style>
      body { margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
        background: #080808; color: #E0DCCF; font-family: system-ui, sans-serif; text-align: center; padding: 24px; }
      a { color: #C9A84C; }
    </style>
  </head>
  <body>
    <div>
      <p>The Bengaluru DJs Collective has a new home.</p>
      <p><a href={NEW_URL}>bengalurudjscollective.com →</a></p>
    </div>
  </body>
</html>
