---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fromVicFix = Astro.url.searchParams.get('from') === 'vicfix';
---

<Layout
  title="Thanks — DJ VIC"
  description="Thanks for reaching out. We'll be in touch shortly."
  noindex={true}
>
  <Nav />
  <main id="main-content">
    <section class="thanks-section">
      {fromVicFix ? (
        <>
          <div class="thanks-label">The VIC Fix</div>
          <h1>Story Received.</h1>
          <p class="thanks-lead">Thanks for applying to The VIC Fix. We review every submission personally — if there's a fit, you'll hear back within a week.</p>
        </>
      ) : (
        <>
          <div class="thanks-label">Booking Enquiry</div>
          <h1>Got it. We'll be in touch.</h1>
          <p class="thanks-lead">Your booking enquiry has been received. Expect a response within 24 hours.</p>
        </>
      )}
      <p class="thanks-sub">Need a faster response? Hit the WhatsApp button below.</p>
      <div class="thanks-actions">
        <a
          href="https://wa.me/918105363636?text=Hi+Vic,+I+just+filled+your+booking+enquiry+form"
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.004 0C5.374 0 0 5.373 0 12c0 2.139.561 4.14 1.538 5.878L0 24l6.305-1.511A11.95 11.95 0 0 0 12.004 24C18.63 24 24 18.627 24 12c0-6.628-5.371-12-11.996-12z"/>
          </svg>
          Chat on WhatsApp
        </a>
        <a href={`${base}/`} class="back-link">&larr; Back to homepage</a>
      </div>
    </section>
  </main>
  <Footer />

<script>
  const params = new URLSearchParams(window.location.search);
  const from = params.get('from');
  const waBtn = document.querySelector('.whatsapp-btn');
  if (waBtn) {
    if (from === 'vicfix') {
      waBtn.href = 'https://wa.me/918105363636?text=Hi+Vic,+I+just+applied+to+be+a+guest+on+The+Vic+Fix';
    } else {
      waBtn.href = 'https://wa.me/918105363636?text=Hi+Vic,+I+just+filled+your+booking+enquiry+form';
    }
  }
</script>

</Layout>

<style>
  .thanks-section {
    min-height: 70svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 2.5rem 5rem;
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .thanks-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .thanks-section h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    color: var(--white);
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .thanks-lead {
    color: rgba(255,255,255,0.75);
    font-size: 1.0625rem;
    line-height: 1.75;
    max-width: 52ch;
    margin-bottom: 0.75rem;
  }

  .thanks-sub {
    color: rgba(255,255,255,0.45);
    font-size: 0.875rem;
    margin-bottom: 2.5rem;
    max-width: 52ch;
  }

  .thanks-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.75rem;
    background: #25D366;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s;
    text-decoration: none;
  }

  .whatsapp-btn:hover {
    background: #1ebe5d;
    color: #fff;
    transform: translateY(-1px);
  }

  .back-link {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .thanks-section {
      padding-inline: 1.25rem;
    }
  }
</style>
