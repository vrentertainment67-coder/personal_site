---
// src/pages/book.astro
// Booking page — now wrapped in the standard site Layout + Nav so it matches the
// rest of the site and visitors can navigate back to Home and every other page.
// The React app (BookingApp) renders as the page's <main> content; its old
// self-contained topbar was removed in favour of the real <Nav />.
//
// Admin dashboard: no longer a public toggle. Reach it discreetly at /book?admin
// (or #dashboard). The public "Book VIC" nav link lands on the client funnel.
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BookingApp from "../components/BookingApp.jsx";

const title = "Book DJ Vic — Live Availability & Booking | VR Entertainment";
const description =
  "Check DJ Vic's live availability and send a booking request for your sangeet, nightlife, private event, or festival. 19+ years, 18 countries, Universal Music partner.";
---

<Layout
  title={title}
  description={description}
  canonical="https://djvicofficial.com/book/"
  noindex={true}
>
  <Nav />
  <!--
    client:only="react" — the funnel is pure interactivity (Supabase auth, live
    calendar fetches, browser APIs), nothing useful to server-render.
  -->
  <main id="main-content">
    <BookingApp client:only="react" />
  </main>
  <Footer />
</Layout>
