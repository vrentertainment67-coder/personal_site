---
// src/pages/book.astro
// Booking page — now wrapped in the standard site Layout + Nav so it matches the
// rest of the site and visitors can navigate back to Home and every other page.
// The React app (BookingApp) renders as the page's <main> content; its old
// self-contained topbar was removed in favour of the real <Nav />.
//
// Admin dashboard: no longer a public toggle. Reach it discreetly at /book?admin
// (or #dashboard). The public "Book VIC" nav link lands on the client funnel.
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BookingApp from "../components/BookingApp.jsx";

const title = "Book DJ Vic — Live Availability & Booking | VR Entertainment";
const description =
  "Check DJ Vic's live availability and send a booking request for your sangeet, nightlife, private event, or festival. 20+ years, 18 countries, Universal Music partner.";
---

<Layout
  title={title}
  description={description}
  canonical="https://djvicofficial.com/book/"
  noindex={true}
>
  <Nav />
  <!--
    client:only="react" — the funnel is pure interactivity (Supabase auth, live
    calendar fetches, browser APIs), nothing useful to server-render.
  -->
  <main id="main-content">
    <!-- Server-rendered skeleton: shows instantly, removed by the app on mount -->
    <div id="book-skel" aria-hidden="true"><span class="bs-spin"></span></div>
    <BookingApp client:only="react" />
  </main>
  <Footer />
</Layout>

<style is:global>
  #book-skel { position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; background: #0A0A0A; }
  .bs-spin { width: 34px; height: 34px; border: 3px solid rgba(201,168,76,0.25); border-top-color: #C9A84C; border-radius: 50%; animation: bsspin 0.8s linear infinite; }
  @keyframes bsspin { to { transform: rotate(360deg); } }
</style>
