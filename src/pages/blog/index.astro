---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => {
  const da = a.data.publishDate ?? (a.data.date ? new Date(a.data.date) : new Date(0));
  const db = b.data.publishDate ?? (b.data.date ? new Date(b.data.date) : new Date(0));
  return db.getTime() - da.getTime();
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="DJ VIC Blog — Nightlife, Music & Event Insights"
  description="Insights on nightlife, DJ culture, weddings, and events from DJ VIC — Bangalore's leading international DJ with 19+ years of experience."
  canonical="https://djvicofficial.com/blog/"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "DJ VIC Blog",
      "description": "Insights on nightlife, DJ culture, weddings, and events from DJ VIC.",
      "url": "https://djvicofficial.com/blog/",
      "author": { "@id": "https://djvicofficial.com/#person" }
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://djvicofficial.com/blog/" }
      ]
    }
  ]}
>
  <Nav />
  <main id="main-content">

    <section id="blog-hero" class="hero-section">
      <div class="hero-inner">
        <div class="section-label">Insights</div>
        <h1>The Blog</h1>
        <p class="hero-sub">Nightlife, music, weddings, and events — from behind the decks.</p>
      </div>
    </section>

    <section id="blog-posts">
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`${base}/blog/${post.id}/`} class="post-card">
            {post.data.image && (
              <div class="post-card-thumb">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" data-img-slot={`blog.${post.id}`} />
              </div>
            )}
            <div class="post-card-body">
              <div class="post-meta">
                <span class="post-date">{(post.data.publishDate ?? (post.data.date ? new Date(post.data.date) : null))?.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                {post.data.tags && post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <span class="post-read">Read More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Blog booking CTA ──────────────────────── -->
    <section class="blog-booking-cta">
      <div class="bbc-inner">
        <p class="bbc-label">Work with DJ VIC</p>
        <h2>Planning an Event?</h2>
        <p class="bbc-sub">Weddings · Corporate · Club Nights · Sangeet · Festivals</p>
        <div class="bbc-actions">
          <a
            href="https://wa.me/919611711677?text=Hi+DJ+VIC%2C+I+read+your+blog+and+would+like+to+enquire+about+a+booking." data-loc="blog"
            target="_blank"
            rel="noopener noreferrer"
            class="bbc-btn bbc-btn--wa"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true" style="display:inline;vertical-align:middle;margin-right:0.4em;flex-shrink:0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp VIC
          </a>
          <a href="/book/" class="bbc-btn bbc-btn--gold">Get a Quote &rarr;</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .hero-section {
    min-height: 35svh;
    display: flex;
    align-items: flex-end;
    background-image:
      linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.85) 100%);
    padding: 0;
  }

  .hero-inner {
    padding: 7rem 2.5rem 3.5rem;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
  }

  .hero-section h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    color: var(--white);
    margin-bottom: 1rem;
  }

  .hero-sub {
    color: rgba(255,255,255,0.6);
    font-size: 1rem;
    max-width: 50ch;
    margin: 0;
  }

  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  #blog-posts {
    padding: 4rem 2rem;
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: #111;
    border: 1px solid rgba(201,168,76,0.1);
    border-top: 3px solid var(--gold);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }

  .post-card:hover {
    background: #161616;
    border-top-color: var(--gold-light);
  }

  .post-card-thumb {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0c0c0c;
  }

  .post-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .post-card:hover .post-card-thumb img {
    transform: scale(1.04);
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 2rem 2rem;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .post-tag {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(201,168,76,0.1);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    letter-spacing: 0.04em;
    color: var(--white);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .post-excerpt {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .post-read {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 0.5rem;
    transition: color 0.2s;
  }

  .post-card:hover .post-read {
    color: var(--gold-light);
  }

  @media (max-width: 800px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 500px) {
    .posts-grid { grid-template-columns: 1fr; }
    .hero-inner { padding-inline: 1.25rem; }
  }

  /* ─── Blog booking CTA ───────────────────────── */
  .blog-booking-cta {
    background: #080808;
    border-top: 1px solid rgba(201,168,76,0.1);
    text-align: center;
  }

  .bbc-inner {
    max-width: 680px;
    margin-inline: auto;
    padding: 4rem 2rem;
  }

  .bbc-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .blog-booking-cta h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .blog-booking-cta h2::before { display: none; }

  .bbc-sub {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .bbc-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .bbc-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.2s, transform 0.15s;
  }

  .bbc-btn--wa { background: #25D366; color: #000; }
  .bbc-btn--wa:hover { background: #20bd5a; transform: translateY(-1px); }

  .bbc-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .bbc-btn--gold:hover { background: var(--gold-light); transform: translateY(-1px); }
</style>
