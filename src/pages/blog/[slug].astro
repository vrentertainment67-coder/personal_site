---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title={post.data.title + ' — DJ VIC Blog'}
  description={post.data.description}
  canonical={`https://djvicofficial.com/blog/${post.id}/`}
  ogType="article"
  ogImage={post.data.image || post.data.ogImage}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.publishDate?.toISOString() || post.data.date,
      "dateModified": post.data.updatedDate?.toISOString() || post.data.dateModified || post.data.publishDate?.toISOString() || post.data.date,
      "image": post.data.image || post.data.ogImage || "https://djvicofficial.com/images/og-default.jpg",
      "keywords": post.data.tags?.join(", "),
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://djvicofficial.com/blog/${post.id}/` },
      "author": { "@id": "https://djvicofficial.com/#person" },
      "publisher": { "@id": "https://djvicofficial.com/#business" },
      "url": `https://djvicofficial.com/blog/${post.id}/`
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog",           "item": "https://djvicofficial.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.data.title,  "item": `https://djvicofficial.com/blog/${post.id}/` }
      ]
    },
    ...(post.data.faq ? [{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": post.data.faq.map((item: { q: string; a: string }) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a }
      }))
    }] : [])
  ]}
>
  <Nav />
  <main id="main-content">

    <article id="blog-post">

      <header class="post-header">
        <a href={`${base}/blog/`} class="back-link">&larr; All Posts</a>
        <div class="post-meta">
          <span class="post-date">{(post.data.publishDate || new Date(post.data.date!)).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          {post.data.tags && post.data.tags.map((tag: string) => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-byline">By DJ VIC</p>
      </header>

      <div class="post-body">
        <Content />
      </div>

      <footer class="post-footer">
        <div class="post-cta">
          <span class="cta-label">Book DJ VIC</span>
          <a href={`${base}/#contact`} class="cta-btn cta-btn--gold">Get in Touch &rarr;</a>
        </div>
        <a href={`${base}/blog/`} class="back-link">&larr; Back to Blog</a>
      </footer>

    </article>

  </main>
  <Footer />
</Layout>

<style>
  /* Kill the body's green radial gradient on blog post pages */
  main#main-content {
    background: #0A0A0A;
    position: relative;
    z-index: 0;
  }

  #blog-post {
    max-width: 720px;
    margin-inline: auto;
    padding: 8rem 2rem 5rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }

  .back-link {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
    margin-bottom: 2rem;
  }

  .back-link:hover { color: var(--gold); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .post-date {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .post-tag {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(201,168,76,0.1);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .post-header h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .post-byline {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    margin: 0;
    text-transform: uppercase;
  }

  /* Article body typography */
  .post-body {
    color: rgba(255,255,255,0.8);
    font-size: 1.0625rem;
    line-height: 1.85;
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    color: var(--white);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style: disc;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
    color: rgba(255,255,255,0.75);
  }

  .post-body :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  .post-body :global(a) {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--gold-light);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(201,168,76,0.15);
    margin: 2.5rem 0;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .post-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .cta-btn {
    display: inline-block; padding: 0.7rem 1.5rem; font-family: var(--font-body);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px; text-decoration: none;
  }

  .cta-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .cta-btn--gold:hover { background: var(--gold-light); color: #000; transform: translateY(-1px); }

  @media (max-width: 600px) {
    #blog-post { padding-inline: 1.25rem; }
    .post-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
