---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title={post.data.title + ' — DJ VIC Blog'}
  description={post.data.description}
  canonical={`https://djvicofficial.com/blog/${post.id}/`}
  ogType="article"
  ogImage={post.data.image || post.data.ogImage}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.publishDate?.toISOString() || post.data.date,
      "dateModified": post.data.updatedDate?.toISOString() || post.data.dateModified || post.data.publishDate?.toISOString() || post.data.date,
      "image": post.data.image || post.data.ogImage || "https://djvicofficial.com/images/og-default.jpg",
      "keywords": post.data.tags?.join(", "),
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://djvicofficial.com/blog/${post.id}/` },
      "author": { "@id": "https://djvicofficial.com/#person" },
      "publisher": { "@id": "https://djvicofficial.com/#business" },
      "url": `https://djvicofficial.com/blog/${post.id}/`
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog",           "item": "https://djvicofficial.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.data.title,  "item": `https://djvicofficial.com/blog/${post.id}/` }
      ]
    },
    ...(post.data.faq ? [{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": post.data.faq.map((item: { q: string; a: string }) => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a }
      }))
    }] : [])
  ]}
>
  <Nav />
  <main id="main-content">

    <article id="blog-post">

      <header class="post-header">
        <a href={`${base}/blog/`} class="post-back">← ALL POSTS</a>
        <div class="post-meta-row">
          <span class="post-date">{(post.data.publishDate || new Date(post.data.date!)).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          <span class="post-meta-sep">·</span>
          <span class="post-author">By {post.data.author || 'DJ VIC'}</span>
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag: string) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="post-title">{post.data.title}</h1>
      </header>

      {post.data.image && (
        <div class="post-hero">
          <img src={post.data.image} alt={post.data.imageAlt || post.data.title} data-img-slot={`blog.${post.id}`} />
        </div>
      )}

      <div class="post-body">
        <Content />
      </div>

      <footer class="post-footer">
        <div class="post-cta">
          <span class="cta-label">Book DJ VIC</span>
          <a href={`${base}/book/`} class="cta-btn cta-btn--gold">Get in Touch &rarr;</a>
        </div>
        <a href={`${base}/blog/`} class="back-link">&larr; Back to Blog</a>
      </footer>

    </article>

  </main>
  <Footer />
</Layout>

<style>
  /* Kill the body's green radial gradient on blog post pages */
  main#main-content {
    background: #0A0A0A;
    position: relative;
    z-index: 0;
  }

  #blog-post {
    max-width: 720px;
    margin-inline: auto;
    padding: 7.5rem 2rem 5rem;
  }

  .post-header {
    /* Override global `header { position: fixed; ... }` which targets ALL <header> elements */
    position: static;
    z-index: auto;
    padding: 0 0 2rem;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid rgba(201,168,76,0.15);
    /* Layout */
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    width: 100%;
  }

  /* Back link — top of header, small and subtle */
  .post-back {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #8A8878;
    text-decoration: none;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
    transition: color 0.2s;
  }
  .post-back:hover { color: #C9A84C; }

  /* Meta row: date · author */
  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #8A8878;
  }
  .post-meta-sep { color: #2a2a2a; }
  .post-date { color: #8A8878; }
  .post-author { color: #C9A84C; }

  /* Tags — horizontal pills, wrapping row */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .post-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 400;
    color: #9A7A32;
    border: 1px solid rgba(201,168,76,0.2);
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  /* Title — off-white, correct weight for Bebas Neue */
  .post-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 5.5vw, 3.75rem);
    font-weight: 400;
    color: #E8E8E0;
    line-height: 1.05;
    letter-spacing: 0.02em;
    margin: 0;
    text-transform: uppercase;
  }

  /* Footer back link — kept separate from header .post-back */
  .back-link {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
  }
  .back-link:hover { color: var(--gold); }

  /* Post hero image (replaceable from the admin Page Images tab) */
  .post-hero {
    margin: 0 0 3rem;
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid rgba(201,168,76,0.15);
  }
  .post-hero img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* Article body typography */
  .post-body {
    color: rgba(255,255,255,0.8);
    font-size: 1.0625rem;
    line-height: 1.85;
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    color: var(--white);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
    max-width: none;
  }

  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style: disc;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
    color: rgba(255,255,255,0.75);
  }

  .post-body :global(strong) {
    color: var(--white);
    font-weight: 600;
  }

  .post-body :global(a) {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--gold-light);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(201,168,76,0.15);
    margin: 2.5rem 0;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .post-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .cta-btn {
    display: inline-block; padding: 0.7rem 1.5rem; font-family: var(--font-body);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px; text-decoration: none;
  }

  .cta-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .cta-btn--gold:hover { background: var(--gold-light); color: #000; transform: translateY(-1px); }

  @media (max-width: 600px) {
    #blog-post { padding-inline: 1.25rem; }
    .post-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
