  { src: 'fe08c6a572f16d1240f67ba7bfd7db1c.jpg', alt: 'DJ VIC mixing at a birthday celebration event in Bangalore' },
  { src: '126ec1d3128a6ef981a1c441bbf81f60.jpg', alt: 'DJ VIC performing at an award ceremony in Bangalore' },
  { src: '1d6eeb6b40e1892ad04c43cf08ec89a3.jpg', alt: 'DJ VIC at a product launch event in India' },
  { src: '3c8bf758088e7183b09a03f7fcbfd6a9.jpg', alt: 'DJ VIC on stage at an outdoor festival performance' },
  { src: '6b7bdc87a5287ffe665ad959a29301ae.jpg', alt: 'DJ VIC performing at a luxury wedding venue' },
  { src: '83ab4f60989d531b991915ff5eae456b.jpg', alt: 'DJ VIC at a corporate annual day celebration' },
  { src: 'c0199910b1e772b84eea44b34d52c783.jpg', alt: 'DJ VIC behind the decks at a themed party event' },
  { src: '188a0ef5634fc8e5183570efd933d4cb.jpg', alt: 'DJ VIC performing at a Hyatt hotel event in Bangalore' },
  { src: '08c724ec311ec5e595cb366401e0d8ff.jpg', alt: 'DJ VIC at an anniversary celebration event' },
  { src: '1f95638535f32016a47b0deacc01ec00.jpg', alt: 'DJ VIC performing at a Goa beach party' },
  { src: '87e451f54c478d9a3a09bbc70e6de835.jpg', alt: 'DJ VIC at a club night with DJ booth lighting' },
  { src: '8af6dead5831ada33a771ca333ff9400.jpg', alt: 'DJ VIC mixing at an international venue performance' },
  { src: '035a62b9d94630a5ac59f8fe1b8f1cc7.jpg', alt: 'DJ VIC at a premium bar event in Bangalore' },
  { src: '083fe810983b545beddc2af7c3d1f058.jpg', alt: 'DJ VIC performing at a corporate party in India' },
  { src: '21a5b0ba6fdbd10a2f44c432306785db.jpg', alt: 'DJ VIC on the decks at a wedding sangeet night' },
  { src: '38757946d4f77aa7f52552c06f54812b.jpg', alt: 'DJ VIC performing at a large-format live event' },
  { src: '48b9289351995dc5ce57d99323b5f4b0.jpg', alt: 'DJ VIC at a concert stage performance' },
