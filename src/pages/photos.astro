  { src: '298c07a92d4903cbabd91c0b2a16abd6.jpg', alt: 'DJ VIC behind the Pioneer CDJ decks at a live event' },
  { src: '395173e132071fd9ba0a5358c0fcd303.jpg', alt: 'DJ VIC on stage at a wedding reception in Bangalore' },
  { src: '5bfd516625730ff7f8fc3183473e2be2.jpg', alt: 'DJ VIC performing at a premium nightclub event' },
  { src: '8cf00a645bcc4ebe2a282ecaa8ec0ad6.jpg', alt: 'DJ VIC performing an audio-visual set at a corporate event' },
