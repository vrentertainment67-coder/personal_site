  { src: 'ff3d91ead582e8b7a152679931daad5a.jpg', alt: 'DJ VIC performing at a wedding cocktail hour' },
  { src: '056fb93002c33eaa1763e4e880c2eecd.jpg', alt: 'DJ VIC performing with crowd visible at a club night' },
  { src: '0ed4bc46f1b6c558d03abac15e3ac199.jpg', alt: 'DJ VIC on stage at a corporate gala evening' },
  { src: 'bb614cf2b38f2b212cc415c0cf57deee.jpg', alt: 'DJ VIC at a brand activation event in India' },
  { src: 'cd1199f6cfd9a119850b2f34d49a1e9b.jpg', alt: 'DJ VIC performing at a destination wedding celebration' },
  { src: 'ce0766bc3ffa73fc87e8dfaf906738a9.jpg', alt: 'DJ VIC behind the decks at a late-night set in Bangalore' },
