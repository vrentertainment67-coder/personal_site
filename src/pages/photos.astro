---

<Layout
  title="DJ VIC Photo Gallery | Live Events, Weddings & Clubs"
  description="Browse photos from DJ VIC's live performances across Bangalore's top clubs, weddings, and corporate events. Over 35 shots from real nights."
  canonical="https://djvicofficial.com/photos/"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "ImageGallery",
      "name": "DJ VIC Photo Gallery",
      "description": "Photos from DJ VIC's live performances across clubs, weddings, and corporate events in Bangalore.",
      "url": "https://djvicofficial.com/photos/",
      "author": { "@id": "https://djvicofficial.com/#person" }
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",   "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Gallery", "item": "https://djvicofficial.com/photos/" }
      ]
    }
  ]}
>
  <Nav />

  <main id="main-content">
    <section id="gallery-hero" class="hero-bg" data-img-slot="photos.hero">
      <div class="section-label">Gallery</div>
      <h1>Live Events &amp;<br/>Performances</h1>
      <p>
        From Bangalore's top clubs to destination weddings and corporate stages —
        captured in the moment.
      </p>
    </section>

    <section id="gallery">
      <Gallery client:visible fallback={photos} base={BASE} />
    </section>

    <!-- ── Booking CTA ──────────────────────────── -->
    <section class="photos-booking-cta">
      <div class="pbc-inner">
        <p class="pbc-label">Like what you see?</p>
        <h2>Let's Create Moments Like These at Your Event</h2>
        <p class="pbc-sub">Weddings · Corporate · Clubs · Sangeet Nights · Festivals</p>
        <div class="pbc-actions">
          <a
            href="https://wa.me/919611711677?text=Hi+DJ+VIC%2C+I+saw+your+photos+and+would+like+to+enquire+about+a+booking."
            target="_blank"
            rel="noopener noreferrer"
            class="pbc-btn pbc-btn--wa"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true" style="display:inline;vertical-align:middle;margin-right:0.4em;flex-shrink:0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            WhatsApp VIC
          </a>
          <a href="/book/" class="pbc-btn pbc-btn--gold">Get a Quote &rarr;</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  #gallery-hero {
    background-image:
      linear-gradient(to bottom, rgba(6,6,6,0.3) 0%, rgba(6,6,6,0.65) 50%, rgba(6,6,6,1) 100%),
      url('/images/rf/cbcb21ad3960fc82de8f296e385e745e.jpg');
  }

  /* ─── Gallery ───────────────────────────────── */
  #gallery {
    padding: 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  .photo-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: #111;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    transition: transform 0.4s ease;
  }

  .photo-item:hover img {
    transform: scale(1.05);
  }

  @media (max-width: 900px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .photo-section {
      padding: 2rem 1rem;
    }
  }

  @media (max-width: 380px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ─── Booking CTA ────────────────────────────── */
  .photos-booking-cta {
    background: #080808;
    border-top: 1px solid rgba(201,168,76,0.1);
    border-bottom: 1px solid rgba(201,168,76,0.1);
    text-align: center;
  }

  .pbc-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 4rem 2rem;
  }

  .pbc-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 auto 0.75rem;
  }

  .photos-booking-cta h2 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .photos-booking-cta h2::before { display: none; }

  .pbc-sub {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 auto 2rem;
  }

  .pbc-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pbc-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.2s, transform 0.15s;
  }

  .pbc-btn--wa {
    background: #25D366;
    color: #000;
  }
  .pbc-btn--wa:hover { background: #20bd5a; transform: translateY(-1px); }

  .pbc-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }
  .pbc-btn--gold:hover { background: var(--gold-light); transform: translateY(-1px); }

  /* ─── Photo item cursor ──────────────────────── */
  .photo-item {
    cursor: zoom-in;
  }

  /* ─── Lightbox ───────────────────────────────── */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.96);
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #lightbox.open {
    display: flex;
  }

  #lb-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    flex: 1;
    padding: 4rem 6rem;
    box-sizing: border-box;
    min-height: 0;
  }

  #lb-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
    user-select: none;
  }

  #lb-caption {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding-bottom: 1.5rem;
  }

  #lb-caption-venue {
    font-family: var(--font-display);
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
  }

  #lb-caption-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
  }

  #lb-counter {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.3);
    padding-bottom: 0.75rem;
  }

  #lb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 2.25rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s;
    z-index: 1001;
    padding: 0.25rem 0.5rem;
  }

  #lb-close:hover {
    color: var(--white);
  }

  #lb-prev,
  #lb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    color: var(--white);
    font-size: 1.25rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    z-index: 1001;
  }

  #lb-prev { left: 1.25rem; }
  #lb-next { right: 1.25rem; }

  #lb-prev:hover,
  #lb-next:hover {
    background: rgba(201,168,76,0.2);
    border-color: var(--gold);
    color: var(--gold);
  }

  @media (max-width: 600px) {
    #lb-img-wrap {
      padding: 4.5rem 1rem 1rem;
    }
    #lb-prev { left: 0.5rem; }
    #lb-next { right: 0.5rem; }
  }
</style>

