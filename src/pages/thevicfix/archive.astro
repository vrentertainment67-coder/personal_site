---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

// ── Real episode collection → archive catalogue ──────────────────────────
const CATEGORIES = [
  { key: 'behind-the-decks',     label: 'Behind the Decks',     desc: 'The DJs.' },
  { key: 'room-makers',          label: 'The Room Makers',      desc: 'The venue owners.' },
  { key: 'architects',           label: 'The Architects',       desc: 'The founders & builders.' },
  { key: 'other-side-of-the-bar',label: 'Other Side of the Bar',desc: 'The bartenders.' },
  { key: 'bigger-picture',       label: 'The Bigger Picture',   desc: 'Industry, scene & culture.' },
];
const catLabel = (k) => (CATEGORIES.find((c) => c.key === k) || {}).label || k;
// Until guest_type is backfilled, derive a rough person-type from the editorial category.
const TYPE_FROM_CAT = { 'behind-the-decks': 'dj', 'room-makers': 'venue', 'architects': 'founder', 'other-side-of-the-bar': 'bartender', 'bigger-picture': 'voice' };
const PERSON = [
  { key: 'dj', label: 'DJs', sub: 'Selectors, residents & headliners.' },
  { key: 'founder', label: 'Founders', sub: 'The ones who started it.' },
  { key: 'venue', label: 'Venue Owners', sub: 'The room makers.' },
  { key: 'bartender', label: 'Bartenders', sub: 'The other side of the bar.' },
  { key: 'voice', label: 'Voices & Artists', sub: 'Hosts, artists, the wider scene.' },
];

const all = (await getCollection('vicfixEpisodes')).sort((a, b) => (a.data.season !== b.data.season ? b.data.season - a.data.season : b.data.episode - a.data.episode));

const eps = all.map((e) => ({
  n: e.data.episode, s: e.data.season,
  name: e.data.guestName, role: e.data.guestTitle,
  slug: `/thevicfix/${e.id}/`,
  cat: e.data.category, catLabel: e.data.categoryLabel || catLabel(e.data.category),
  topics: e.data.topics || [],
  hook: e.data.tagline || '',
  pop: parseInt(e.data.viewCount, 10) || 0,
  type: TYPE_FROM_CAT[e.data.category] || 'voice',
  thumb: e.data.guestPhoto || (e.data.youtubeId ? `https://img.youtube.com/vi/${e.data.youtubeId}/hqdefault.jpg` : ''),
  featured: !!e.data.featured,
  yt: e.data.youtubeId || '',
}));

const initials = (name) => name.split(/[\s&.]+/).filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
const dueto = (name) => { let h = 0; for (const c of name) h = (h * 31 + c.charCodeAt(0)) >>> 0; const a = 20 + (h % 14), b = 28 + ((h >> 4) % 18); return `background:radial-gradient(120% 130% at 78% 18%, hsl(42,40%,${10 + (h % 5)}%), transparent 55%),linear-gradient(150deg,hsl(${a},22%,9%),hsl(${b},30%,15%))`; };

// Rails (SSR) — every card is a real <a href>, the SEO spine.
const featured = [...eps].sort((a, b) => (b.featured - a.featured) || (b.pop - a.pop)).slice(0, 6);
const FLAGS = ['Start Here', 'Most Watched', "Editor's Pick", 'Most Talked About', "If You're New", 'Deep Cut'];
const rails = [
  { title: 'Latest Episodes', desc: 'Freshest from the cutting room.', eps: eps.slice(0, 12) },
  { title: 'Most Watched', desc: 'What the scene keeps coming back to.', eps: [...eps].sort((a, b) => b.pop - a.pop).slice(0, 12) },
  ...CATEGORIES.map((c) => ({ title: c.label, desc: c.desc, eps: eps.filter((e) => e.cat === c.key) })).filter((r) => r.eps.length),
  { title: 'Season 2', desc: 'The current chapter.', eps: eps.filter((e) => e.s === 2) },
  { title: 'Season 1', desc: 'Where it started.', eps: eps.filter((e) => e.s === 1) },
].filter((r) => r.eps.length);

const topicSet = [...new Set(eps.flatMap((e) => e.topics))].map((t) => ({ key: t, label: t, count: eps.filter((e) => e.topics.includes(t)).length })).sort((a, b) => b.count - a.count);
const topStats = { episodes: eps.length, seasons: new Set(eps.map((e) => e.s)).size, categories: CATEGORIES.filter((c) => eps.some((e) => e.cat === c.key)).length, topics: topicSet.length };

const itemList = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: 'The VIC Fix — Archive', url: 'https://djvicofficial.com/thevicfix/archive/',
  mainEntity: { '@type': 'ItemList', itemListElement: eps.map((e, i) => ({ '@type': 'ListItem', position: i + 1, url: `https://djvicofficial.com${e.slug}`, name: `${e.name} — The VIC Fix S${e.s}E${e.n}` })) },
};
const breadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://djvicofficial.com/' },
  { '@type': 'ListItem', position: 2, name: 'The VIC Fix', item: 'https://djvicofficial.com/thevicfix/' },
  { '@type': 'ListItem', position: 3, name: 'Archive', item: 'https://djvicofficial.com/thevicfix/archive/' },
] };
---

<Layout
  title="The VIC Fix — Archive | Every Episode | DJ VIC"
  description={`The full VIC Fix archive — ${eps.length} long-form conversations with the DJs, founders, venue owners and voices behind India's nightlife. Browse by person, story or season.`}
  canonical="https://djvicofficial.com/thevicfix/archive/"
  schema={[itemList, breadcrumb]}
>
  <Nav />

  <main id="main-content" class="vf">

    <!-- ── HERO ── -->
    <section class="vf-hero">
      <div class="vf-eyebrow">The Archive · Season 2 running</div>
      <h1>The VIC Fix</h1>
      <p class="vf-position">The people who build the night — DJs, founders, venue owners and the voices who never get the credit.</p>
      <div class="vf-stats">
        <div class="vf-stat"><span class="n">{topStats.episodes}</span><span class="l">Episodes</span></div>
        <div class="vf-stat"><span class="n">{topStats.seasons}</span><span class="l">Seasons</span></div>
        <div class="vf-stat"><span class="n">{topStats.categories}</span><span class="l">Strands</span></div>
        <div class="vf-stat"><span class="n">{topStats.topics}</span><span class="l">Topics</span></div>
      </div>
      <label class="vf-search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="vfSearch" type="text" placeholder="Search a guest, venue, topic…" aria-label="Search the archive" autocomplete="off" />
        <button type="button" class="vf-filterbtn" id="vfFilterToggle"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 4h18M7 12h10M11 20h2"/></svg> Filters <span class="dot"></span></button>
      </label>
      <div class="vf-chips" id="vfChips">
        <button class="vf-chip on" data-cat="">All</button>
        {CATEGORIES.filter((c) => eps.some((e) => e.cat === c.key)).map((c) => <button class="vf-chip" data-cat={c.key}>{c.label}</button>)}
      </div>
    </section>

    <!-- ── SEARCH / FILTER RESULTS (JS, hidden until used) ── -->
    <section class="vf-results" id="vfResults" aria-live="polite">
      <div class="vf-rhead"><h2 id="vfResTitle">Results</h2><button class="vf-clear" id="vfClear">Clear ✕</button></div>
      <div class="vf-grid" id="vfResGrid"></div>
    </section>

    <div id="vfBrowseable">

      <!-- ── START HERE ── -->
      <section class="vf-band">
        <div class="vf-bandhead"><div><h2>Start Here</h2><span class="vf-desc">New to The VIC Fix? The films that define the room.</span></div><span class="vf-idx">Flagship · {String(featured.length).padStart(2, '0')}</span></div>
        <div class="vf-featgrid">
          {featured.map((e, i) => (
            <a class="vf-feat" href={e.slug}>
              <div class="vf-still" style={e.thumb ? `background-image:url('${e.thumb}')` : dueto(e.name)}></div>
              <div class="vf-scrim"></div>
              <div class="vf-fmeta">
                <span class="vf-flag">{FLAGS[i]}</span>
                <h3>{e.name}</h3>
                <div class="vf-who">EP {e.n} · {e.role}</div>
                <div class="vf-fhook">{e.hook}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- ── RAILS (SEO spine — real anchors) ── -->
      {rails.map((rail, ri) => (
        <section class="vf-rail">
          <div class="vf-railhead">
            <span class="num">{String(ri + 1).padStart(2, '0')}</span>
            <h2>{rail.title}</h2>
            <span class="vf-desc">{rail.desc}</span>
            <span class="vf-count">{rail.eps.length} {rail.eps.length === 1 ? 'film' : 'films'}</span>
            <span class="vf-arrows"><button aria-label="Scroll left" data-dir="-1"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg></button><button aria-label="Scroll right" data-dir="1"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></button></span>
          </div>
          <div class="vf-hair"></div>
          <div class="vf-track">
            {rail.eps.map((e) => (
              <article class="vf-card">
                <a class="vf-cardlink" href={e.slug}>
                  <div class="vf-cstill" style={e.thumb ? `background-image:url('${e.thumb}')` : dueto(e.name)}>
                    {!e.thumb && <span class="vf-initials">{initials(e.name)}</span>}
                    <span class="vf-ghost">{e.n}</span>
                    <span class="vf-epline">EP {e.n} · S{e.s}</span>
                  </div>
                  <div class="vf-cbody">
                    <div class="vf-name">{e.name}</div>
                    <div class="vf-role">{e.role}</div>
                    <div class="vf-hook">{e.hook}</div>
                  </div>
                </a>
                <div class="vf-actions">
                  {e.yt && <a class="vf-watch" href={`https://youtu.be/${e.yt}`} target="_blank" rel="noopener noreferrer">▶ Watch</a>}
                  <a class="vf-read" href={e.slug}>Read</a>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      <!-- ── BROWSE: by person / by story ── -->
      <section class="vf-browse">
        <div class="vf-blead"><div class="vf-eyebrow">Two ways in</div><h2>Browse the Archive</h2><p>You don't always remember a name — you remember the story. Pick your entry point; both lead to the same films.</p></div>
        <div class="vf-modetabs"><button class="on" data-mode="person">By Person</button><button data-mode="story">By Story</button></div>
        <div class="vf-modegrid" id="vfModeGrid"></div>
      </section>

      <!-- ── COLLECTIONS ── -->
      <section class="vf-collections">
        <div class="vf-bandhead"><div><h2>Topic Collections</h2><span class="vf-desc">Threads that run across seasons.</span></div><span class="vf-idx">{String(topicSet.length).padStart(2, '0')} threads</span></div>
        <div class="vf-colgrid" id="vfColGrid"></div>
      </section>

    </div>
  </main>

  <!-- ── FILTER DRAWER ── -->
  <div class="vf-drawerbg" id="vfDrawerBg"></div>
  <aside class="vf-drawer" id="vfDrawer" role="dialog" aria-label="Filter episodes" aria-modal="true">
    <button class="vf-dclose" id="vfDrawerClose" aria-label="Close filters">✕</button>
    <h3>Filter</h3><p class="vf-dsub">Stack any combination. Results update live.</p>
    <div id="vfFilterGroups"></div>
    <div class="vf-dactions"><button class="reset" id="vfReset">Reset</button><button class="apply" id="vfApply">Show results</button></div>
  </aside>

  <Footer />

  <script is:inline set:html={`window.__VF_CAT = ${JSON.stringify(eps)}; window.__VF_CATS = ${JSON.stringify(CATEGORIES)}; window.__VF_PERSON = ${JSON.stringify(PERSON)}; window.__VF_TOPICS = ${JSON.stringify(topicSet)};`}></script>
</Layout>

<style>
  .vf { --gold:#c9a84c; --gold-br:#e6c768; --carbon:#121214; --line:rgba(232,232,224,.10); --head:#e8e8e0; --bd:#8a8878; --hi:#a8a898; }
  .vf { background:#080808; }
  .vf a { text-decoration:none; color:inherit; }

  /* hero */
  .vf-hero { max-width:1320px; margin:0 auto; text-align:center; padding:clamp(7rem,11vw,9rem) clamp(16px,4vw,40px) clamp(1.5rem,4vw,2.5rem); }
  .vf-eyebrow { font-family:var(--font-display); font-size:.85rem; letter-spacing:.34em; text-transform:uppercase; color:var(--gold); }
  .vf-hero h1 { font-family:var(--font-display); font-weight:400; color:var(--head); font-size:clamp(3rem,10vw,7rem); line-height:.92; text-transform:uppercase; margin:1.2rem 0 0; }
  .vf-position { font-style:italic; font-size:clamp(.95rem,2vw,1.25rem); color:var(--hi); max-width:640px; margin:1.2rem auto 0; line-height:1.5; }
  .vf-stats { display:flex; justify-content:center; flex-wrap:wrap; gap:clamp(20px,5vw,64px); margin:2rem auto 0; padding:1.2rem 0; border-top:1px solid var(--line); border-bottom:1px solid var(--line); max-width:680px; }
  .vf-stat .n { display:block; font-family:var(--font-display); font-size:clamp(1.8rem,4vw,2.6rem); color:var(--gold); line-height:1; }
  .vf-stat .l { font-family:var(--font-display); font-size:.7rem; letter-spacing:.24em; text-transform:uppercase; color:var(--bd); margin-top:.4rem; }
  .vf-search { display:flex; align-items:center; gap:10px; max-width:620px; margin:2rem auto 0; background:var(--carbon); border:1px solid var(--line); border-radius:3px; padding:12px 16px; transition:border-color .2s, box-shadow .2s; }
  .vf-search:focus-within { border-color:var(--gold); box-shadow:0 0 0 1px rgba(201,168,76,.3); }
  .vf-search svg { opacity:.7; flex-shrink:0; }
  .vf-search input { flex:1; background:none; border:0; color:var(--head); font-family:var(--font-body); font-size:1rem; outline:none; }
  .vf-search input::placeholder { color:var(--bd); }
  .vf-filterbtn { display:flex; align-items:center; gap:6px; flex-shrink:0; border:1px solid var(--line); border-radius:2px; padding:8px 12px; font-family:var(--font-display); font-size:.78rem; letter-spacing:.14em; text-transform:uppercase; color:var(--head); cursor:pointer; transition:.2s; }
  .vf-filterbtn:hover { border-color:var(--gold); color:var(--gold); }
  .vf-filterbtn .dot { width:6px; height:6px; border-radius:50%; background:var(--gold); display:none; }
  .vf-filterbtn.active .dot { display:block; }
  .vf-chips { display:flex; flex-wrap:wrap; justify-content:center; gap:8px; margin:1.4rem auto 0; max-width:820px; }
  .vf-chip { font-family:var(--font-display); font-size:.8rem; letter-spacing:.1em; text-transform:uppercase; color:var(--bd); border:1px solid var(--line); border-radius:999px; padding:7px 16px; cursor:pointer; transition:.2s; }
  .vf-chip:hover { color:var(--head); border-color:var(--hi); }
  .vf-chip.on { background:var(--gold); color:#0a0a0a; border-color:var(--gold); }

  /* shared section heads */
  .vf-band, .vf-collections { max-width:1320px; margin:clamp(3rem,7vw,4.5rem) auto 0; padding:0 clamp(16px,4vw,40px); }
  .vf-bandhead { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:1.4rem; }
  .vf-bandhead h2 { font-family:var(--font-display); font-weight:400; font-size:clamp(1.5rem,2.6vw,2rem); color:var(--head); text-transform:uppercase; letter-spacing:.04em; line-height:1; }
  .vf-desc { font-style:italic; font-size:.9rem; color:var(--bd); display:block; margin-top:.3rem; }
  .vf-idx { font-family:var(--font-display); font-size:.78rem; letter-spacing:.2em; color:var(--gold); border:1px solid var(--line); padding:5px 9px; border-radius:2px; white-space:nowrap; }

  /* featured */
  .vf-featgrid { display:grid; grid-template-columns:1.6fr 1fr 1fr; gap:14px; }
  .vf-feat { position:relative; border:1px solid var(--line); border-radius:3px; overflow:hidden; min-height:330px; display:flex; flex-direction:column; justify-content:flex-end; transition:transform .35s cubic-bezier(.2,.7,.2,1), border-color .35s; }
  .vf-feat:hover { transform:translateY(-4px); border-color:var(--gold); }
  .vf-still { position:absolute; inset:0; z-index:0; background-size:cover; background-position:center; }
  .vf-scrim { position:absolute; inset:0; z-index:1; background:linear-gradient(to top,rgba(6,6,6,.96) 8%,rgba(6,6,6,.3) 55%,rgba(6,6,6,.7) 100%); }
  .vf-fmeta { position:relative; z-index:2; padding:22px; }
  .vf-flag { font-family:var(--font-display); font-size:.66rem; letter-spacing:.26em; text-transform:uppercase; color:#0a0a0a; background:var(--gold); display:inline-block; padding:4px 9px; margin-bottom:12px; }
  .vf-feat h3 { font-family:var(--font-display); font-weight:400; font-size:clamp(1.3rem,2.3vw,1.7rem); color:var(--head); text-transform:uppercase; line-height:1.04; }
  .vf-who { font-family:var(--font-body); font-size:.78rem; color:var(--gold); margin-top:.4rem; }
  .vf-fhook { font-style:italic; font-size:.9rem; color:var(--hi); margin-top:.5rem; line-height:1.45; }

  /* rails */
  .vf-rail { max-width:1320px; margin:clamp(2.6rem,5vw,3.6rem) auto 0; padding:0 clamp(16px,4vw,40px); }
  .vf-railhead { display:flex; align-items:flex-end; gap:14px; margin-bottom:.9rem; }
  .vf-railhead .num { font-family:var(--font-display); font-size:.9rem; color:var(--gold); letter-spacing:.1em; opacity:.85; }
  .vf-railhead h2 { font-family:var(--font-display); font-weight:400; font-size:clamp(1.2rem,2.2vw,1.6rem); color:var(--head); text-transform:uppercase; letter-spacing:.05em; line-height:1; }
  .vf-railhead .vf-count { margin-left:auto; font-family:var(--font-display); font-size:.72rem; letter-spacing:.22em; color:var(--bd); text-transform:uppercase; white-space:nowrap; }
  .vf-arrows { display:flex; gap:6px; }
  .vf-arrows button { width:30px; height:30px; border:1px solid var(--line); border-radius:2px; display:grid; place-items:center; color:var(--head); cursor:pointer; transition:.2s; background:none; }
  .vf-arrows button:hover { border-color:var(--gold); color:var(--gold); }
  .vf-hair { height:1px; background:linear-gradient(to right,var(--gold),transparent); opacity:.5; margin-bottom:1.1rem; }
  .vf-track { display:flex; gap:clamp(10px,1.4vw,18px); overflow-x:auto; scroll-snap-type:x mandatory; padding-bottom:8px; scrollbar-width:none; }
  .vf-track::-webkit-scrollbar { display:none; }

  /* card */
  .vf-card { flex:0 0 clamp(220px,22vw,272px); scroll-snap-align:start; border:1px solid var(--line); border-radius:3px; overflow:hidden; background:var(--carbon); transition:transform .35s cubic-bezier(.2,.7,.2,1), border-color .35s, box-shadow .35s; }
  .vf-card:hover { transform:translateY(-6px); border-color:var(--gold); box-shadow:0 18px 40px -18px rgba(0,0,0,.9),0 0 0 1px rgba(201,168,76,.25); }
  .vf-cstill { position:relative; aspect-ratio:4/3; overflow:hidden; background-size:cover; background-position:center; }
  .vf-ghost { position:absolute; right:8px; bottom:-14px; font-family:var(--font-display); font-size:88px; line-height:1; color:rgba(255,255,255,.08); }
  .vf-initials { position:absolute; left:16px; top:12px; font-family:var(--font-display); font-size:2rem; color:rgba(232,220,207,.85); }
  .vf-epline { position:absolute; left:14px; bottom:10px; font-family:var(--font-display); font-size:.7rem; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); text-shadow:0 1px 6px rgba(0,0,0,.8); }
  .vf-cbody { padding:14px 15px 15px; }
  .vf-name { font-family:var(--font-display); font-size:1.15rem; color:var(--head); text-transform:uppercase; letter-spacing:.02em; line-height:1.05; }
  .vf-role { font-family:var(--font-body); font-size:.74rem; color:var(--gold); margin-top:.3rem; }
  .vf-hook { font-style:italic; font-size:.82rem; color:var(--hi); line-height:1.42; max-height:0; opacity:0; overflow:hidden; transition:max-height .4s ease, opacity .3s, margin .3s; }
  .vf-card:hover .vf-hook, .vf-card:focus-within .vf-hook { max-height:90px; opacity:1; margin-top:.55rem; }
  .vf-actions { display:flex; gap:8px; padding:0 15px 15px; }
  .vf-actions a { flex:1; text-align:center; font-family:var(--font-display); font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; padding:9px 6px; border-radius:2px; transition:.2s; }
  .vf-watch { background:var(--gold); color:#0a0a0a; }
  .vf-watch:hover { background:var(--gold-br); }
  .vf-read { border:1px solid var(--line); color:var(--head); }
  .vf-read:hover { border-color:var(--gold); color:var(--gold); }

  /* browse + collections */
  .vf-browse { max-width:1320px; margin:clamp(3.5rem,8vw,5.5rem) auto 0; padding:clamp(28px,4vw,44px) clamp(16px,4vw,40px); border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:linear-gradient(180deg,rgba(201,168,76,.04),transparent); }
  .vf-blead { text-align:center; margin-bottom:1.6rem; }
  .vf-blead h2 { font-family:var(--font-display); font-weight:400; font-size:clamp(1.6rem,3vw,2.2rem); color:var(--head); text-transform:uppercase; margin-top:.6rem; }
  .vf-blead p { font-style:italic; font-size:.92rem; color:var(--hi); margin:.6rem auto 0; max-width:520px; line-height:1.5; }
  .vf-modetabs { display:flex; justify-content:center; margin-bottom:1.5rem; }
  .vf-modetabs button { font-family:var(--font-display); font-size:.85rem; letter-spacing:.18em; text-transform:uppercase; color:var(--bd); padding:12px 26px; border:0; border-bottom:2px solid transparent; background:none; cursor:pointer; transition:.2s; }
  .vf-modetabs button.on { color:var(--gold); border-color:var(--gold); }
  .vf-modegrid { display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:12px; max-width:920px; margin:0 auto; }
  .vf-modecell { border:1px solid var(--line); border-radius:3px; padding:18px 16px; background:var(--carbon); cursor:pointer; transition:.25s; text-align:left; }
  .vf-modecell:hover { border-color:var(--gold); transform:translateY(-3px); }
  .vf-mctop { display:flex; align-items:center; justify-content:space-between; }
  .vf-mctop .k { font-family:var(--font-display); font-size:1.05rem; color:var(--head); text-transform:uppercase; letter-spacing:.03em; }
  .vf-mctop .c { font-family:var(--font-display); font-size:.8rem; color:var(--gold); }
  .vf-mcsub { font-style:italic; font-size:.8rem; color:var(--bd); margin-top:.5rem; line-height:1.4; }
  .vf-colgrid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; margin-top:1.1rem; }
  .vf-col { position:relative; border:1px solid var(--line); border-radius:3px; min-height:120px; display:flex; flex-direction:column; justify-content:flex-end; padding:16px; cursor:pointer; background:var(--carbon); transition:.3s; text-align:left; overflow:hidden; }
  .vf-col:hover { border-color:var(--gold); transform:translateY(-3px); }
  .vf-col h3 { font-family:var(--font-display); font-weight:400; font-size:1.05rem; color:var(--head); text-transform:uppercase; letter-spacing:.02em; line-height:1.05; }
  .vf-col .n { font-family:var(--font-display); font-size:.72rem; letter-spacing:.18em; color:var(--gold); text-transform:uppercase; margin-top:.5rem; display:inline-block; }

  /* results overlay */
  .vf-results { display:none; max-width:1320px; margin:1.5rem auto 0; padding:0 clamp(16px,4vw,40px); }
  .vf-results.show { display:block; }
  #vfBrowseable.hidden { display:none; }
  .vf-rhead { display:flex; align-items:center; gap:12px; margin-bottom:1.1rem; }
  .vf-rhead h2 { font-family:var(--font-display); font-weight:400; font-size:1.5rem; color:var(--head); text-transform:uppercase; letter-spacing:.03em; }
  .vf-clear { margin-left:auto; font-family:var(--font-display); font-size:.78rem; letter-spacing:.16em; text-transform:uppercase; color:var(--gold); border:1px solid var(--line); padding:7px 13px; border-radius:2px; cursor:pointer; background:none; transition:.2s; }
  .vf-clear:hover { border-color:var(--gold); }
  .vf-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(clamp(220px,22vw,272px),1fr)); gap:14px; }
  .vf-grid .vf-card { flex:initial; }
  .vf-none { font-style:italic; color:var(--bd); padding:2rem 0; }

  /* filter drawer */
  .vf-drawerbg { position:fixed; inset:0; z-index:120; background:rgba(0,0,0,.6); backdrop-filter:blur(3px); opacity:0; pointer-events:none; transition:opacity .3s; }
  .vf-drawerbg.open { opacity:1; pointer-events:auto; }
  .vf-drawer { position:fixed; top:0; right:0; bottom:0; z-index:121; width:min(380px,90vw); background:var(--carbon); border-left:1px solid var(--line); transform:translateX(100%); transition:transform .35s cubic-bezier(.2,.7,.2,1); overflow-y:auto; padding:26px 24px; }
  .vf-drawer.open { transform:translateX(0); }
  .vf-drawer h3 { font-family:var(--font-display); font-size:1.1rem; letter-spacing:.12em; text-transform:uppercase; color:var(--head); }
  .vf-dsub { font-style:italic; font-size:.85rem; color:var(--bd); margin-bottom:1.4rem; }
  .vf-fgroup { margin-bottom:1.4rem; border-bottom:1px solid var(--line); padding-bottom:1.2rem; }
  .vf-glbl { font-family:var(--font-display); font-size:.78rem; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); margin-bottom:.7rem; }
  .vf-fopts { display:flex; flex-wrap:wrap; gap:8px; }
  .vf-fopt { font-family:var(--font-display); font-size:.78rem; letter-spacing:.06em; text-transform:uppercase; color:var(--bd); border:1px solid var(--line); border-radius:999px; padding:6px 13px; cursor:pointer; transition:.2s; background:none; }
  .vf-fopt:hover { color:var(--head); border-color:var(--hi); }
  .vf-fopt.on { background:var(--gold); color:#0a0a0a; border-color:var(--gold); }
  .vf-dactions { display:flex; gap:10px; position:sticky; bottom:-26px; background:var(--carbon); padding:16px 0 0; }
  .vf-dactions button { flex:1; font-family:var(--font-display); font-size:.85rem; letter-spacing:.14em; text-transform:uppercase; padding:13px; border-radius:2px; cursor:pointer; }
  .vf-dactions .apply { background:var(--gold); color:#0a0a0a; border:0; }
  .vf-dactions .reset { border:1px solid var(--line); color:var(--head); background:none; }
  .vf-dclose { position:absolute; top:22px; right:20px; font-size:1.4rem; color:var(--bd); background:none; border:0; cursor:pointer; }

  @media(max-width:860px){ .vf-featgrid{ grid-template-columns:1fr 1fr; } .vf-feat:first-child{ grid-column:1/-1; } }
  @media(max-width:560px){ .vf-featgrid{ grid-template-columns:1fr; } .vf-card{ flex-basis:78vw; } .vf-arrows{ display:none; } }
</style>

<script>
  function vfInit() {
    if (!document.querySelector('.vf') || !window.__VF_CAT) return;
    const EP = window.__VF_CAT, CATS = window.__VF_CATS, PERSON = window.__VF_PERSON, TOPICS = window.__VF_TOPICS;
    const $ = (s) => document.querySelector(s), $$ = (s) => [...document.querySelectorAll(s)];
    const initials = (n) => n.split(/[\s&.]+/).filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
    const dueto = (name) => { let h = 0; for (const c of name) h = (h * 31 + c.charCodeAt(0)) >>> 0; const a = 20 + (h % 14), b = 28 + ((h >> 4) % 18); return `background:radial-gradient(120% 130% at 78% 18%, hsl(42,40%,${10 + (h % 5)}%), transparent 55%),linear-gradient(150deg,hsl(${a},22%,9%),hsl(${b},30%,15%))`; };
    const card = (e) => `<article class="vf-card"><a class="vf-cardlink" href="${e.slug}"><div class="vf-cstill" style="${e.thumb ? `background-image:url('${e.thumb}')` : dueto(e.name)}">${e.thumb ? '' : `<span class="vf-initials">${initials(e.name)}</span>`}<span class="vf-ghost">${e.n}</span><span class="vf-epline">EP ${e.n} · S${e.s}</span></div><div class="vf-cbody"><div class="vf-name">${e.name}</div><div class="vf-role">${e.role}</div><div class="vf-hook">${e.hook || ''}</div></div></a><div class="vf-actions">${e.yt ? `<a class="vf-watch" href="https://youtu.be/${e.yt}" target="_blank" rel="noopener">▶ Watch</a>` : ''}<a class="vf-read" href="${e.slug}">Read</a></div></article>`;

    function showResults(title, list) {
      $('#vfResTitle').textContent = `${title} · ${list.length}`;
      $('#vfResGrid').innerHTML = list.length ? list.map(card).join('') : `<div class="vf-none">No episodes match yet — try a guest, topic or season, or clear and browse the rails.</div>`;
      $('#vfResults').classList.add('show'); $('#vfBrowseable').classList.add('hidden');
      $('#vfResults').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    function clearResults() {
      $('#vfResults').classList.remove('show'); $('#vfBrowseable').classList.remove('hidden');
      $('#vfSearch').value = ''; $$('#vfChips .vf-chip').forEach((x, i) => x.classList.toggle('on', i === 0));
      Object.values(F).forEach((s) => s.clear()); $$('#vfFilterGroups .vf-fopt').forEach((o) => o.classList.remove('on')); $('#vfFilterToggle').classList.remove('active');
    }
    // search
    function runSearch(q) {
      q = q.trim().toLowerCase(); if (!q) { clearResults(); return; }
      const r = EP.filter((e) => [e.name, e.role, e.catLabel, ...(e.topics || [])].join(' ').toLowerCase().includes(q));
      showResults(`"${q}"`, r);
    }
    $('#vfSearch').addEventListener('input', (e) => runSearch(e.target.value));
    $('#vfClear').addEventListener('click', clearResults);
    // chips
    $$('#vfChips .vf-chip').forEach((ch) => ch.addEventListener('click', () => {
      $$('#vfChips .vf-chip').forEach((x) => x.classList.remove('on')); ch.classList.add('on');
      const c = ch.dataset.cat;
      if (c) showResults(ch.textContent, EP.filter((e) => e.cat === c)); else clearResults();
    }));
    // browse modes
    function buildModes(mode) {
      const data = mode === 'person' ? PERSON : TOPICS.map((t) => ({ key: t.key, label: t.label, sub: `${t.count} episodes` }));
      $('#vfModeGrid').innerHTML = data.map((d) => {
        const c = mode === 'person' ? EP.filter((e) => e.type === d.key).length : (TOPICS.find((t) => t.key === d.key) || {}).count;
        return `<button class="vf-modecell" data-mode="${mode}" data-key="${d.key}" data-k="${d.label}"><div class="vf-mctop"><span class="k">${d.label}</span><span class="c">${c}</span></div><div class="vf-mcsub">${d.sub}</div></button>`;
      }).join('');
      $$('#vfModeGrid .vf-modecell').forEach((cell) => cell.addEventListener('click', () => {
        const k = cell.dataset.key, m = cell.dataset.mode;
        const list = EP.filter((e) => (m === 'person' ? e.type === k : (e.topics || []).includes(k)));
        showResults(cell.dataset.k, list);
      }));
    }
    $$('.vf-modetabs button').forEach((b) => b.addEventListener('click', () => { $$('.vf-modetabs button').forEach((x) => x.classList.remove('on')); b.classList.add('on'); buildModes(b.dataset.mode); }));
    buildModes('person');
    // collections
    $('#vfColGrid').innerHTML = TOPICS.map((t) => `<button class="vf-col" data-key="${t.key}"><h3>${t.label}</h3><span class="n">${t.count} episodes →</span></button>`).join('');
    $$('#vfColGrid .vf-col').forEach((col) => col.addEventListener('click', () => showResults(col.querySelector('h3').textContent, EP.filter((e) => (e.topics || []).includes(col.dataset.key)))));
    // rail arrows
    $$('.vf-rail').forEach((rail) => { const track = rail.querySelector('.vf-track'); rail.querySelectorAll('.vf-arrows button').forEach((btn) => btn.addEventListener('click', () => { const w = track.querySelector('.vf-card')?.offsetWidth || 260; track.scrollBy({ left: (+btn.dataset.dir) * (w + 16) * 2, behavior: 'smooth' }); })); });
    // filter drawer
    const FILTERS = { season: { label: 'Season', opts: [...new Set(EP.map((e) => e.s))].sort((a, b) => b - a).map((s) => [String(s), `Season ${s}`]), get: (e) => String(e.s) }, cat: { label: 'Strand', opts: CATS.map((c) => [c.key, c.label]), get: (e) => e.cat }, type: { label: 'Person', opts: PERSON.map((p) => [p.key, p.label]), get: (e) => e.type } };
    const F = { season: new Set(), cat: new Set(), type: new Set() };
    $('#vfFilterGroups').innerHTML = Object.entries(FILTERS).map(([id, f]) => `<div class="vf-fgroup"><div class="vf-glbl">${f.label}</div><div class="vf-fopts">${f.opts.map(([v, l]) => `<button class="vf-fopt" data-g="${id}" data-v="${v}">${l}</button>`).join('')}</div></div>`).join('');
    function anyF() { return Object.values(F).some((s) => s.size); }
    function applyF(close) {
      $('#vfFilterToggle').classList.toggle('active', anyF());
      if (!anyF()) { if (close) closeD(); clearResults(); return; }
      const list = EP.filter((e) => Object.entries(FILTERS).every(([id, f]) => !F[id].size || F[id].has(f.get(e))));
      showResults('Filtered', list); if (close) closeD();
    }
    $$('#vfFilterGroups .vf-fopt').forEach((o) => o.addEventListener('click', () => { const s = F[o.dataset.g]; s.has(o.dataset.v) ? s.delete(o.dataset.v) : s.add(o.dataset.v); o.classList.toggle('on', s.has(o.dataset.v)); }));
    const openD = () => { $('#vfDrawer').classList.add('open'); $('#vfDrawerBg').classList.add('open'); };
    const closeD = () => { $('#vfDrawer').classList.remove('open'); $('#vfDrawerBg').classList.remove('open'); };
    $('#vfFilterToggle').addEventListener('click', openD); $('#vfDrawerClose').addEventListener('click', closeD); $('#vfDrawerBg').addEventListener('click', closeD);
    $('#vfApply').addEventListener('click', () => applyF(true));
    $('#vfReset').addEventListener('click', () => { Object.values(F).forEach((s) => s.clear()); $$('#vfFilterGroups .vf-fopt').forEach((o) => o.classList.remove('on')); applyF(false); });
  }
  document.addEventListener('astro:page-load', vfInit);
</script>
