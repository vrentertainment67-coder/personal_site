---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { getEpisodes, buildTopicSet, getFlagshipTopics, CATEGORIES, initials, dueto } from '../../../lib/vicfix.js';

// Build one indexable facet page per strand, per season, and per flagship
// topic. Every card is a real <a href> to the episode — these pages are the
// crawlable "view all" targets behind the archive rails & collection tiles.
export async function getStaticPaths() {
  const eps = await getEpisodes();
  const topicSet = buildTopicSet(eps);
  const flagship = getFlagshipTopics(topicSet);
  const paths = [];

  for (const c of CATEGORIES) {
    const list = eps.filter((e) => e.cat === c.key);
    if (list.length) paths.push({ params: { slug: `strand-${c.key}` }, props: { kind: 'Strand', title: c.label, blurb: c.desc, eps: list } });
  }
  for (const s of [...new Set(eps.map((e) => e.s))].sort((a, b) => b - a)) {
    const list = eps.filter((e) => e.s === s);
    paths.push({ params: { slug: `season-${s}` }, props: { kind: 'Season', title: `Season ${s}`, blurb: s === Math.max(...eps.map((e) => e.s)) ? 'The current chapter.' : 'The full season.', eps: list } });
  }
  for (const t of flagship) {
    const list = eps.filter((e) => e.topics.map((x) => x.toLowerCase()).includes(t.label.toLowerCase()));
    paths.push({ params: { slug: `topic-${t.key}` }, props: { kind: 'Thread', title: t.label, blurb: `Every VIC Fix conversation that runs through ${t.label.toLowerCase()}.`, eps: list } });
  }
  return paths;
}

const { kind, title, blurb, eps } = Astro.props;
const url = `https://djvicofficial.com/thevicfix/collection/${Astro.params.slug}/`;

const itemList = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: `${title} — The VIC Fix`, url,
  mainEntity: { '@type': 'ItemList', itemListElement: eps.map((e, i) => ({ '@type': 'ListItem', position: i + 1, url: `https://djvicofficial.com${e.slug}`, name: `${e.name} — The VIC Fix S${e.s}E${e.n}` })) },
};
const breadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://djvicofficial.com/' },
  { '@type': 'ListItem', position: 2, name: 'The VIC Fix', item: 'https://djvicofficial.com/thevicfix/' },
  { '@type': 'ListItem', position: 3, name: 'Archive', item: 'https://djvicofficial.com/thevicfix/archive/' },
  { '@type': 'ListItem', position: 4, name: title, item: url },
] };
---

<Layout
  title={`${title} — The VIC Fix | ${eps.length} Episodes | DJ VIC`}
  description={`${title}: ${eps.length} long-form VIC Fix conversation${eps.length === 1 ? '' : 's'}. ${blurb}`}
  canonical={url}
  schema={[itemList, breadcrumb]}
>
  <Nav />

  <main id="main-content" class="vfc">
    <section class="vfc-head">
      <a class="vfc-back" href="/thevicfix/archive/">← The VIC Fix Archive</a>
      <div class="vfc-eyebrow">{kind} · {eps.length} {eps.length === 1 ? 'Episode' : 'Episodes'}</div>
      <h1>{title}</h1>
      <p class="vfc-blurb">{blurb}</p>
    </section>

    <section class="vfc-grid">
      {eps.map((e) => (
        <article class="vf-card">
          <a class="vf-cardlink" href={`${e.slug}#ep-bio`}>
            <div class="vf-cstill" style={e.thumb ? `background-image:url('${e.thumb}')` : dueto(e.name)}>
              {!e.thumb && <span class="vf-initials">{initials(e.name)}</span>}
              {e.duration && <span class="vf-dur">{e.duration}</span>}
              <span class="vf-ghost">{e.n}</span>
              <span class="vf-epline">EP {e.n} · S{e.s}</span>
            </div>
            <div class="vf-cbody">
              <div class="vf-name">{e.name}</div>
              <div class="vf-role">{e.role}</div>
              <div class="vf-hook">{e.hook}</div>
            </div>
          </a>
          <div class="vf-actions">
            {e.yt && <a class="vf-watch" href={`${e.slug}#ep-video`}>▶ Watch</a>}
            <a class="vf-read" href={`${e.slug}#ep-bio`}>Read</a>
          </div>
        </article>
      ))}
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .vfc { --gold:#c9a84c; --gold-br:#e6c768; --carbon:#121214; --line:rgba(232,232,224,.10); --head:#e8e8e0; --bd:#8a8878; --hi:#a8a898; background:#080808; min-height:80vh; }
  .vfc a { text-decoration:none; color:inherit; }

  .vfc-head { max-width:1320px; margin:0 auto; padding:clamp(7rem,11vw,9rem) clamp(16px,4vw,40px) 0; }
  .vfc-back { font-family:var(--font-display); font-size:.82rem; letter-spacing:.16em; text-transform:uppercase; color:var(--bd); transition:color .2s; }
  .vfc-back:hover { color:var(--gold); }
  .vfc-eyebrow { font-family:var(--font-display); font-size:.82rem; letter-spacing:.3em; text-transform:uppercase; color:var(--gold); margin-top:1.4rem; }
  .vfc-head h1 { font-family:var(--font-display); font-weight:400; color:var(--head); font-size:clamp(2.4rem,7vw,4.5rem); line-height:.95; text-transform:uppercase; margin:.5rem 0 0; }
  .vfc-blurb { font-style:italic; font-size:clamp(.95rem,2vw,1.15rem); color:var(--hi); max-width:620px; margin:1rem 0 0; line-height:1.5; }

  .vfc-grid { max-width:1320px; margin:2.4rem auto 0; padding:0 clamp(16px,4vw,40px) clamp(4rem,8vw,6rem); display:grid; grid-template-columns:repeat(auto-fill,minmax(clamp(220px,22vw,272px),1fr)); gap:14px; }

  .vf-card { border:1px solid var(--line); border-radius:3px; overflow:hidden; background:var(--carbon); transition:transform .35s cubic-bezier(.2,.7,.2,1), border-color .35s, box-shadow .35s; }
  .vf-card:hover { transform:translateY(-6px); border-color:var(--gold); box-shadow:0 18px 40px -18px rgba(0,0,0,.9),0 0 0 1px rgba(201,168,76,.25); }
  .vf-cstill { position:relative; aspect-ratio:4/3; overflow:hidden; background-size:cover; background-position:center; }
  .vf-ghost { position:absolute; right:8px; bottom:-14px; font-family:var(--font-display); font-size:88px; line-height:1; color:rgba(255,255,255,.08); }
  .vf-initials { position:absolute; left:16px; top:12px; font-family:var(--font-display); font-size:2rem; color:rgba(232,220,207,.85); }
  .vf-dur { position:absolute; right:10px; top:10px; font-family:var(--font-display); font-size:.72rem; letter-spacing:.1em; color:var(--head); background:rgba(8,8,8,.82); border:1px solid rgba(201,168,76,.35); padding:3px 7px; border-radius:2px; }
  .vf-epline { position:absolute; left:14px; bottom:10px; font-family:var(--font-display); font-size:.7rem; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); text-shadow:0 1px 6px rgba(0,0,0,.8); }
  .vf-cbody { padding:14px 15px 15px; }
  .vf-name { font-family:var(--font-display); font-size:1.15rem; color:var(--head); text-transform:uppercase; letter-spacing:.02em; line-height:1.05; }
  .vf-role { font-family:var(--font-body); font-size:.74rem; color:var(--gold); margin-top:.3rem; }
  .vf-hook { font-style:italic; font-size:.82rem; color:var(--hi); line-height:1.42; margin-top:.5rem; }
  .vf-actions { display:flex; gap:8px; padding:0 15px 15px; }
  .vf-actions a { flex:1; text-align:center; font-family:var(--font-display); font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; padding:9px 6px; border-radius:2px; transition:.2s; }
  .vf-watch { background:var(--gold); color:#0a0a0a; }
  .vf-watch:hover { background:var(--gold-br); }
  .vf-read { border:1px solid var(--line); color:var(--head); }
  .vf-read:hover { border-color:var(--gold); color:var(--gold); }
</style>
