---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialsStrip from '../components/TestimonialsStrip.jsx';

// Section 7 — Client reviews (fallback until DB-driven; managed in /admin → Reviews)
const weddingReviews = [
  { quote: "Vic absolutely nailed our wedding! From the cocktail night to the reception, he read the room perfectly and kept everyone on the dancefloor all night. Couldn't have asked for better energy.", name: "Sarthak", event: "Groom · Dec 2024 · Kochi", rating: 5 },
  { quote: "VIC played for my special day recently, and rocked our cocktail night! Being a North-South wedding, he chose the perfect energetic tunes to keep our guests going on the floor!", name: "Rashmi Jaiswal", event: "Bride · Jan 2025 · Bangalore", rating: 5 },
  { quote: "I think no one left the dancefloor while Vic was playing! He executed the perfect blend of English and Bollywood songs for my entire wedding functions and it was spot on!", name: "Aryaman", event: "Groom · July 2025 · Bangalore", rating: 5 },
  { quote: "VIC was recommended by my cousin and livened up our wedding parties with his music selection and engaging performances. A special mention on the live baraat with dhol performance!!", name: "Kruthi Singar", event: "Bride · Dec 2023 · Bangalore", rating: 5 },
  { quote: "Working with Vic on multiple weddings has been seamless every time. He's professional, well-prepared, and genuinely elevates the experience. Highly recommended for any event.", name: "Manish Fitkariwala", event: "Wedding Planner · Catapultt", rating: 5 },
];

// Section 3 — Wedding Vlogs
const weddingVlogs = [
  { id: "bFWIs4dhvew", caption: "Prachi & Mridhul — Wedding Vlog, Wayanad" },
  { id: "sebNDm7uiWQ", caption: "Visaaly & Sharan — Destination Wedding, Colombo" },
];

// Section 5 — Couple Testimonial Videos
const coupleVideos = [
  { id: "Dw5gerVqA7w", caption: "Kanchana & Nihar" },
  { id: "x9Q_nA4820w", caption: "Diksha & Pranav" },
  { id: "UCVpbps9hrk", caption: "Raksha & Rahul" },
];

// Section 4 — Wedding Showcase (replace SHOWCASE_VIDEO_ID with your video ID)
const showcaseVideoId = "TU_R42SDuns";

// Section 6 — Curated AV Showcase
const avVideoId = "3FJl0cbpOYY";
---

<Layout
  title="Wedding DJ Bangalore | Luxury Wedding DJ | DJ VIC"
  description="DJ VIC performs at weddings across India — sangeet nights, receptions, and destination weddings. 20+ years, 300+ weddings performed. Enquire now."
  ogTitle="DJ VIC — Wedding DJ · Sangeet, Reception & Destination Weddings Across India"
  ogDescription="Premium wedding DJ for celebrations across India and internationally. Sangeet nights, cocktail hours, receptions, and destination weddings. Trusted at JW Marriott, Leela, Taj and beyond."
  ogImage="https://djvicofficial.com/images/og-weddings.jpg"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Wedding DJ Services Bangalore",
      "provider": { "@id": "https://djvicofficial.com/#business" },
      "description": "Luxury wedding DJ for sangeet, cocktail, and reception events in Bangalore.",
      "areaServed": "Bangalore, India",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "ratingCount": "47",
        "bestRating": "5"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How far in advance should I book DJ VIC for my wedding?",
          "acceptedAnswer": { "@type": "Answer", "text": "We recommend booking at least 3–6 months in advance, especially for peak wedding season (October–February). Popular dates fill quickly." }
        },
        {
          "@type": "Question",
          "name": "Does DJ VIC perform at destination weddings?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. DJ VIC has performed at destination weddings across India and internationally, including Sri Lanka and beyond." }
        },
        {
          "@type": "Question",
          "name": "What events does DJ VIC cover at a wedding?",
          "acceptedAnswer": { "@type": "Answer", "text": "DJ VIC covers all wedding events including sangeet nights, mehendi, cocktail hours, wedding receptions, and after-parties." }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",     "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Weddings", "item": "https://djvicofficial.com/weddings/" }
      ]
    }
  ]}
>
  <Nav />

  <main id="main-content">

    <!-- ══════════════════════════════════════════
         1. HERO
    ══════════════════════════════════════════ -->
    <section id="weddings-hero" class="hero-bg" data-img-slot="weddings.hero">
      <div class="hero-inner">
        <div class="section-label">Wedding DJ</div>
        <h1>Your Love Story,<br/>Our Soundtrack</h1>
        <p class="hero-sub">20+ years of unforgettable celebrations across India &amp; beyond.</p>
        <a href="/book/" class="cta-btn cta-btn--gold">Book DJ Vic for Your Wedding</a>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         3. FROM SUNRISE DRIVES TO THE LAST DANCE
    ══════════════════════════════════════════ -->
    <section id="weddings-vlogs">
      <div class="section-label">Wedding Films</div>
      <h2>From Sunrise Drives to the Last Dance</h2>
      <p class="section-sub">
        Real couples. Real celebrations. A glimpse into the magic we create together.
      </p>
      <div class="yt-grid yt-grid--2col">
        {weddingVlogs.map((v) => (
          <a
            href={`https://youtu.be/${v.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="yt-card"
          >
            <div class="yt-thumb">
              <img
                src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
                onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${v.id}/hqdefault.jpg'`}
                alt={v.caption}
                loading="lazy"
                width="480"
                height="360"
              />
              <div class="yt-play">
                <svg viewBox="0 0 68 48" width="52" height="37">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--gold)"/>
                  <path d="M45 24 27 14v20" fill="#000"/>
                </svg>
              </div>
            </div>
            <p class="yt-caption">{v.caption}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. ROCKING WEDDINGS SINCE 2007
    ══════════════════════════════════════════ -->
    <section id="weddings-showcase" class="section-alt">
      <div class="section-label">Wedding Showcase</div>
      <h2>Rocking Weddings Since 2007</h2>
      <p class="section-sub">
        Nearly two decades of dancefloors, sangeet nights, and unforgettable receptions
        — India and beyond.
      </p>
      {showcaseVideoId !== "SHOWCASE_VIDEO_ID" ? (
        <div class="yt-grid yt-grid--1col">
          <a
            href={`https://youtu.be/${showcaseVideoId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="yt-card"
          >
            <div class="yt-thumb">
              <img
                src={`https://img.youtube.com/vi/${showcaseVideoId}/maxresdefault.jpg`}
                alt="DJ VIC Wedding Showcase — Full Reception and Dance Floor Performance"
                loading="lazy"
                width="1280"
                height="720"
                onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${showcaseVideoId}/hqdefault.jpg'`}
              />
              <div class="yt-play">
                <svg viewBox="0 0 68 48" width="52" height="37">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--gold)"/>
                  <path d="M45 24 27 14v20" fill="#000"/>
                </svg>
              </div>
            </div>
            <p class="yt-caption">Wedding Showcase — DJ VIC</p>
          </a>
        </div>
      ) : (
        <div class="placeholder-card">
          <p><!-- TODO: Replace SHOWCASE_VIDEO_ID in weddings.astro with your Wedding Showcase YouTube video ID --></p>
          <p class="placeholder-text">Wedding showcase video coming soon.</p>
        </div>
      )}
    </section>

    <!-- ══════════════════════════════════════════
         5. TRUSTED BY COUPLES
    ══════════════════════════════════════════ -->
    <section id="weddings-couples">
      <div class="section-label">Real Weddings</div>
      <h2>Trusted by Couples</h2>
      <p class="section-sub">Watch their stories — and hear what they have to say.</p>
      <div class="yt-grid yt-grid--3col">
        {coupleVideos.map((v) => (
          <a
            href={`https://youtu.be/${v.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="yt-card"
          >
            <div class="yt-thumb">
              <img
                src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
                onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${v.id}/hqdefault.jpg'`}
                alt={v.caption}
                loading="lazy"
                width="480"
                height="360"
              />
              <div class="yt-play">
                <svg viewBox="0 0 68 48" width="52" height="37">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--gold)"/>
                  <path d="M45 24 27 14v20" fill="#000"/>
                </svg>
              </div>
            </div>
            <p class="yt-caption">{v.caption}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         6. CURATED MUSIC & AUDIO VISUAL
    ══════════════════════════════════════════ -->
    <section id="weddings-av" class="section-alt">
      <div class="section-label">Performance Showcase</div>
      <h2>Curated Music &amp; Audio Visual Experiences for Your Special Day</h2>
      <p class="section-sub section-sub--gold">
        A recent performance showcase at JW Marriott, Golfshire, Nandi Hills
      </p>
      <div class="yt-grid yt-grid--center">
        <a
          href={`https://youtu.be/${avVideoId}`}
          target="_blank"
          rel="noopener noreferrer"
          class="yt-card"
        >
          <div class="yt-thumb">
            <img
              src="/images/av-thumbnail.jpg"
              alt="DJ VIC audio-visual wedding pool party at JW Marriott, Golfshire, Nandi Hills"
              loading="lazy"
              width="1280"
              height="720"
            />
            <div class="yt-play">
              <svg viewBox="0 0 68 48" width="64" height="45">
                <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--gold)"/>
                <path d="M45 24 27 14v20" fill="#000"/>
              </svg>
            </div>
          </div>
          <p class="yt-caption">Wedding Pool Party — JW Marriott, Golfshire, Nandi Hills</p>
        </a>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         7. TESTIMONIALS
    ══════════════════════════════════════════ -->
    <section id="weddings-testimonials">
      <div class="section-label">Client Reviews</div>
      <h2>Here's What the Clients Have to Say</h2>
      <p class="section-sub">Straight from the couples and planners who trusted DJ VIC with their big day.</p>
      <TestimonialsStrip client:visible category="wedding" fallback={weddingReviews} />
    </section>

    <!-- ══════════════════════════════════════════
         8. DESTINATION & NRI WEDDINGS
    ══════════════════════════════════════════ -->
    <section class="destination-section" aria-labelledby="destination-heading">
      <div class="destination-inner">

        <div class="destination-text">
          <p class="section-label">Destination &amp; NRI Weddings</p>
          <h2 id="destination-heading">
            Your wedding isn't<br/>in Bangalore?<br/>Neither is the boundary.
          </h2>
          <p class="destination-desc">
            DJ VIC has performed at weddings across India and internationally —
            from Goa and Udaipur to Sri Lanka, the UK, and Australia. Whether
            you're planning a destination wedding, an NRI celebration, or a
            multi-city function, the logistics are handled directly.
          </p>
          <div class="destination-locations">
            <span>🇮🇳 Pan-India</span>
            <span>🇱🇰 Sri Lanka</span>
            <span>🇦🇺 Australia</span>
            <span>🇬🇧 United Kingdom</span>
            <span>+ More</span>
          </div>
          <a href="/book/" class="cta-btn cta-btn--gold destination-cta">
            Enquire for Your Destination &rarr;
          </a>
        </div>

        <div class="destination-stats">
          <div class="d-stat">
            <span class="d-num">18</span>
            <span class="d-lbl">Countries Performed In</span>
          </div>
          <div class="d-stat">
            <span class="d-num">300+</span>
            <span class="d-lbl">Weddings Performed</span>
          </div>
          <div class="d-stat">
            <span class="d-num">20+</span>
            <span class="d-lbl">Years of Experience</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         9. DESTINATION GUIDE LINK
    ══════════════════════════════════════════ -->
    <section id="weddings-guide">
      <div class="guide-inner">
        <span class="guide-label">Wedding Planning Guides</span>
        <p class="guide-text">Working out your budget? Our honest 2026 guide breaks down real <a href="/blog/wedding-dj-cost-bangalore-2026/">wedding DJ costs in Bangalore</a> — every price tier, what each one delivers, and what should be in the quote.</p>
        <a href="/blog/wedding-dj-cost-bangalore-2026/" class="guide-link">Wedding DJ Cost Guide &rarr;</a>
        <p class="guide-text" style="margin-top:1.75rem;">Planning a destination wedding? Read our complete guide to hiring a DJ — sound logistics, multi-day planning, and what to brief your DJ before the event.</p>
        <a href="/blog/destination-wedding-dj-india/" class="guide-link">Destination Wedding DJ Guide &rarr;</a>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         9. FAQ
    ══════════════════════════════════════════ -->
    <section id="weddings-faq">
      <div class="faq-inner">
        <div class="section-label">Common Questions</div>
        <h2>Wedding DJ FAQ</h2>
        <div class="faq-grid">
          <details class="faq-item">
            <summary>How far in advance should we book?</summary>
            <p>For peak wedding seasons (October–February and April–May), 6–12 months in advance is recommended. DJ VIC takes a limited number of bookings per month, so popular Saturdays fill up quickly. Reach out as soon as you have a date in mind.</p>
          </details>
          <details class="faq-item">
            <summary>Do you cover both sangeet night and the reception?</summary>
            <p>Yes — DJ VIC performs at all parts of the wedding celebration: sangeet night, cocktail hour, and reception. Each has a different energy and setlist. Packages covering multiple events are available.</p>
          </details>
          <details class="faq-item">
            <summary>Can we customise the music?</summary>
            <p>Completely. The setlist is built around your preferences — Bollywood, international, retro, hip-hop, Punjabi, or any mix. DJ VIC works with each couple to understand their story and translates that into the music.</p>
          </details>
          <details class="faq-item">
            <summary>Can you travel for destination weddings?</summary>
            <p>Yes. DJ VIC has performed at weddings across India and in 18 countries, including Sri Lanka, Australia, and the UK. Travel and logistics are discussed as part of the booking. There is no location that is off the table.</p>
          </details>
          <details class="faq-item">
            <summary>Do you bring your own equipment?</summary>
            <p>Yes — full professional setup is included. DJ VIC co-ordinates with the venue's sound and AV team before the event to ensure a seamless technical setup. You don't need to arrange separate equipment.</p>
          </details>
          <details class="faq-item">
            <summary>What makes DJ VIC different from other wedding DJs?</summary>
            <p>The audio-visual format — original music compositions synced with custom visuals, developed since 2007. Combined with 300+ weddings across 20+ years, and a reputation built on couples who trust VIC to be the emotional anchor of their celebration, not just background music.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         10. CLOSING CTA
    ══════════════════════════════════════════ -->
    <section id="weddings-cta" class="cta-section">
      <h2>Ready to Make Your Wedding Unforgettable?</h2>
      <p class="section-sub">Get in touch and let's plan the music for your special day.</p>
      <a href="/book/" class="cta-btn cta-btn--gold">Book DJ Vic &rarr;</a>
    </section>

  </main>

  <a href="/book/" class="sticky-quote-cta" id="sticky-quote-cta">Get a Quote &rarr;</a>

  <Footer />

  <script>
    // Show sticky CTA only after the hero CTA has scrolled out of view
    document.addEventListener('astro:page-load', () => {
      const heroBtn = document.querySelector('#weddings-hero .cta-btn');
      const stickyBtn = document.getElementById('sticky-quote-cta');
      if (!heroBtn || !stickyBtn) return;
      // Only activate sticky behaviour on mobile
      if (window.matchMedia('(min-width: 601px)').matches) return;

      const show = () => { stickyBtn.style.opacity = '1'; stickyBtn.style.pointerEvents = 'auto'; };
      const hide = () => { stickyBtn.style.opacity = '0'; stickyBtn.style.pointerEvents = 'none'; };

      // Start hidden; JS controls visibility
      stickyBtn.style.transition = 'opacity 0.3s';
      hide();

      const obs = new IntersectionObserver(([entry]) => {
        entry.isIntersecting ? hide() : show();
      }, { threshold: 0.1 });
      obs.observe(heroBtn);
    });
  </script>
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  #weddings-hero {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.82) 30%, rgba(0,0,0,0.45) 65%, rgba(0,0,0,0.25) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.75) 100%),
      url('https://images.unsplash.com/photo-1519741497674-611481863552?w=1600&q=85');
    background-position: center center;
    /* Pull content into a constrained inner wrapper */
    align-items: stretch;
    padding: 0;
  }

  .hero-inner {
    padding: 8rem 2.5rem 4rem;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
  }

  .hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 1rem;
    max-width: 52ch;
    margin: 0 0 0.5rem;
    line-height: 1.6;
  }

  /* ─── Sticky mobile CTA ────────────────────────── */
  .sticky-quote-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 85;
    background: var(--gold);
    color: #000;
    text-align: center;
    padding: 1rem 2rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 -2px 16px rgba(0,0,0,0.5);
    transition: background 0.2s;
  }
  .sticky-quote-cta:hover {
    background: var(--gold-light);
    color: #000;
  }

  /* ─── Gold CTA button ──────────────────────────── */
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
    margin-top: 2rem;
  }
  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }
  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }

  /* ─── Section shared ──────────────────────────── */
  .section-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  h2 {
    color: var(--white);
  }

  .section-sub {
    color: rgba(255,255,255,0.65);
    max-width: 760px;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .section-sub--gold {
    color: rgba(201,168,76,0.75);
  }

  .section-alt {
    background: rgba(0,0,0,0.25);
  }

  /* ─── YouTube thumbnail cards ─────────────────── */
  .yt-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .yt-grid--2col {
    grid-template-columns: repeat(2, 1fr);
  }

  .yt-grid--3col {
    grid-template-columns: repeat(3, 1fr);
  }

  .yt-grid--1col {
    grid-template-columns: 1fr;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .yt-grid--center {
    grid-template-columns: 1fr;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
  }

  .yt-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .yt-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
    border-radius: 10px;
    border: 1px solid #1e1e1e;
  }

  .yt-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .yt-card:hover .yt-thumb img {
    transform: scale(1.04);
  }

  .yt-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.45);
    opacity: 0;
