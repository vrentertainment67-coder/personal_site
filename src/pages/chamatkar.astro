---
// Dedicated Chamatkar event page — shareable link with the guest-list RSVP,
// event details, and a "from last time" recap (photos + videos).
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EventRSVP from '../components/EventRSVP.jsx';

// Event details (edition 2). These mirror the live row in the Supabase
// `events` table (slug chamatkar-2026-07-11); the RSVP writes against `slug`.
const EVENT = {
  slug: 'chamatkar-2026-07-11',
  title: 'Chamatkar',
  edition: 'Edition 2',
  venue: 'Happy Brew',
  area: 'Koramangala, Bangalore',
  dateLabel: 'Saturday 11 July',
  timeLabel: '9:00 PM onwards',
  lineup: 'DJ VIC',
  genre: 'Bollywood / Commercial — Audio-Visual Set',
  banner: '/images/chamatkar.jpg',
  rsvpCutoff: '2026-07-11T12:30:00+00:00',
  expiry: '2026-07-11T19:30:00+00:00',
  mapsQuery: 'Happy Brew, Koramangala, Bangalore',
};

// ── FROM LAST TIME (edition 1) — add media here and it renders automatically.
// Photos: put files in public/images/chamatkar/ and list their paths.
const PHOTOS: string[] = [
  // '/images/chamatkar/last-01.jpg',
  // '/images/chamatkar/last-02.jpg',
];
// Videos: a YouTube id OR a full youtu.be / youtube.com link — either works.
const VIDEOS: string[] = [
  // 'dQw4w9WgXcQ',
  // 'https://youtu.be/xxxxxxxxxxx',
];

const ytId = (v: string) => {
  const m = v.match(/(?:v=|youtu\.be\/|embed\/)([A-Za-z0-9_-]{6,})/);
  return m ? m[1] : v;
};

const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(EVENT.mapsQuery)}`;
const desc = `Chamatkar returns — ${EVENT.lineup} live at ${EVENT.venue}, ${EVENT.area}. ${EVENT.dateLabel}, ${EVENT.timeLabel}. ${EVENT.genre}. Get on the guest list.`;
---

<Layout
  title="Chamatkar — Guest List | DJ VIC"
  description={desc}
  ogTitle="Chamatkar — You're Invited"
  ogDescription={`${EVENT.lineup} · ${EVENT.venue}, ${EVENT.area} · ${EVENT.dateLabel}. Bollywood × global, audio-visual. Tap to get on the guest list.`}
  ogImage="https://djvicofficial.com/images/chamatkar.jpg"
  canonical="https://djvicofficial.com/chamatkar/"
>
  <Nav />

  <main id="main-content" class="ck">
    <!-- ── HERO ── -->
    <section class="ck-hero" style={`background-image:linear-gradient(to bottom,rgba(6,6,6,.62),rgba(6,6,6,.82) 62%,#080808),url('${EVENT.banner}')`}>
      <div class="ck-hero-inner">
        <span class="ck-eyebrow">Guest List · {EVENT.edition}</span>
        <h1 class="ck-title">{EVENT.title}</h1>
        <p class="ck-lineup">{EVENT.lineup}</p>
        <p class="ck-genre">{EVENT.genre}</p>
        <div class="ck-meta">
          <span>🗓 {EVENT.dateLabel}</span>
          <span>🕘 {EVENT.timeLabel}</span>
          <span>📍 {EVENT.venue} · {EVENT.area}</span>
        </div>
        <a href="#rsvp" class="ck-cta">Get on the guest list ↓</a>
      </div>
    </section>

    <!-- ── RSVP ── -->
    <section id="rsvp" class="ck-rsvp">
      <div class="ck-sec-head">
        <span class="ck-kicker">RSVP</span>
        <h2>Get on the guest list</h2>
        <p class="ck-sub">Drop your name — we'll WhatsApp you the details before the night.</p>
      </div>
      <EventRSVP client:load
        slug={EVENT.slug}
        title={EVENT.title}
        venue={EVENT.venue}
        area={EVENT.area}
        dateLabel={EVENT.dateLabel}
        timeLabel={EVENT.timeLabel}
        rsvpCutoff={EVENT.rsvpCutoff}
        expiry={EVENT.expiry}
      />
    </section>

    <!-- ── FROM LAST TIME ── -->
    <section class="ck-recap">
      <div class="ck-sec-head">
        <span class="ck-kicker">From last time</span>
        <h2>The first Chamatkar</h2>
        <p class="ck-sub">Bollywood flipped through a global lens, visuals locked to every drop, and a room that never sat down. Edition 2 picks up where that night left off.</p>
      </div>

      {VIDEOS.length > 0 && (
        <div class="ck-videos">
          {VIDEOS.map((v) => (
            <div class="ck-video">
              <iframe
                src={`https://www.youtube.com/embed/${ytId(v)}?rel=0&modestbranding=1`}
                title="Chamatkar — last edition"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          ))}
        </div>
      )}

      {PHOTOS.length > 0 && (
        <div class="ck-photos">
          {PHOTOS.map((src, i) => (
            <a class="ck-photo" href={src} target="_blank" rel="noopener noreferrer">
              <img src={src} alt={`Chamatkar last edition ${i + 1}`} loading="lazy" />
            </a>
          ))}
        </div>
      )}

      {VIDEOS.length === 0 && PHOTOS.length === 0 && (
        <p class="ck-soon">📸 Photos &amp; clips from the last edition — dropping here soon.</p>
      )}
    </section>

    <!-- ── DETAILS ── -->
    <section class="ck-details">
      <div class="ck-sec-head"><span class="ck-kicker">The details</span><h2>Know before you go</h2></div>
      <div class="ck-dgrid">
        <div class="ck-dcard"><span class="ck-dlabel">When</span><span class="ck-dval">{EVENT.dateLabel}</span><span class="ck-dsub">{EVENT.timeLabel}</span></div>
        <div class="ck-dcard"><span class="ck-dlabel">Where</span><span class="ck-dval">{EVENT.venue}</span><span class="ck-dsub">{EVENT.area}</span><a class="ck-dlink" href={mapsHref} target="_blank" rel="noopener noreferrer">Open in Maps →</a></div>
        <div class="ck-dcard"><span class="ck-dlabel">Sound</span><span class="ck-dval">{EVENT.lineup}</span><span class="ck-dsub">{EVENT.genre}</span></div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .ck { background: #080808; color: #e8e8e0; }
  .ck section { max-width: none; }

  /* ── Hero ── */
  .ck-hero { background-size: cover; background-position: center; padding: clamp(7rem, 13vw, 11rem) clamp(16px, 4vw, 40px) clamp(3.5rem, 7vw, 5.5rem); text-align: center; }
  .ck-hero-inner { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
  .ck-eyebrow { font-family: 'Bebas Neue', sans-serif; font-size: .9rem; letter-spacing: .34em; text-transform: uppercase; color: var(--gold, #c9a84c); }
  .ck-title { font-family: 'Bebas Neue', sans-serif; font-weight: 400; font-size: clamp(4rem, 15vw, 8.5rem); line-height: .9; letter-spacing: .02em; text-transform: uppercase; color: #fff; margin: .6rem 0 0; }
  .ck-lineup { font-family: 'Bebas Neue', sans-serif; font-size: clamp(1.4rem, 3.5vw, 2rem); letter-spacing: .1em; color: #e2c475; margin: 1rem 0 0; }
  .ck-genre { font-size: clamp(.8rem, 1.8vw, .95rem); letter-spacing: .04em; color: rgba(255,255,255,.6); margin: .35rem 0 0; }
  .ck-meta { display: flex; flex-wrap: wrap; gap: .6rem 1.4rem; justify-content: center; margin: 1.6rem 0 0; font-size: .92rem; color: rgba(255,255,255,.82); }
  .ck-cta { display: inline-block; margin-top: 2rem; background: var(--gold, #c9a84c); color: #0a0a0a; font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .08em; text-transform: uppercase; padding: .85rem 2rem; border-radius: 4px; text-decoration: none; transition: background .2s, transform .15s; }
  .ck-cta:hover { background: #e2c475; transform: translateY(-1px); }

  /* ── Section shells ── */
  .ck-rsvp, .ck-recap, .ck-details { max-width: 1080px; margin: 0 auto; padding: clamp(3rem, 6vw, 4.5rem) clamp(16px, 4vw, 40px); }
  .ck-rsvp { border-top: 1px solid #141414; }
  .ck-sec-head { text-align: center; max-width: 640px; margin: 0 auto clamp(1.6rem, 3vw, 2.2rem); }
  .ck-kicker { font-family: 'Bebas Neue', sans-serif; font-size: .78rem; letter-spacing: .3em; text-transform: uppercase; color: var(--gold, #c9a84c); }
  .ck-sec-head h2 { font-family: 'Bebas Neue', sans-serif; font-weight: 400; font-size: clamp(2rem, 5vw, 3rem); line-height: 1; text-transform: uppercase; color: #fff; margin: .5rem 0 0; }
  .ck-sub { font-size: clamp(.9rem, 1.8vw, 1.02rem); color: rgba(255,255,255,.6); line-height: 1.55; margin: .8rem 0 0; }

  /* ── Recap media ── */
  .ck-videos { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(360px, 100%), 1fr)); gap: 16px; margin-top: .5rem; }
  .ck-video { position: relative; aspect-ratio: 16/9; border-radius: 8px; overflow: hidden; border: 1px solid rgba(201,168,76,.25); background: #000; }
  .ck-video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .ck-photos { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(200px, 100%), 1fr)); gap: 10px; margin-top: 16px; }
  .ck-photo { display: block; aspect-ratio: 4/5; border-radius: 6px; overflow: hidden; border: 1px solid #1c1c1c; }
  .ck-photo img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .4s ease; }
  .ck-photo:hover img { transform: scale(1.05); }
  .ck-soon { text-align: center; color: rgba(255,255,255,.45); font-style: italic; border: 1px dashed rgba(201,168,76,.25); border-radius: 8px; padding: 2.2rem 1rem; margin: 0; }

  /* ── Details ── */
  .ck-details { border-top: 1px solid #141414; }
  .ck-dgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr)); gap: 14px; }
  .ck-dcard { background: #101010; border: 1px solid #1e1e1e; border-radius: 8px; padding: 1.2rem 1.3rem; display: flex; flex-direction: column; gap: .25rem; }
  .ck-dlabel { font-family: 'Bebas Neue', sans-serif; font-size: .74rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold, #c9a84c); }
  .ck-dval { font-size: 1.15rem; color: #fff; font-weight: 600; }
  .ck-dsub { font-size: .88rem; color: rgba(255,255,255,.6); }
  .ck-dlink { margin-top: .5rem; font-size: .82rem; color: var(--gold, #c9a84c); text-decoration: none; border-bottom: 1px solid rgba(201,168,76,.35); align-self: flex-start; padding-bottom: 1px; }
  .ck-dlink:hover { color: #e2c475; }
</style>
