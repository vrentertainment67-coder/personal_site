---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const eventsData = allEvents.map(e => ({
  slug: e.id,
  title: e.data.title,
  date: e.data.date,
  time: e.data.time,
  venue: e.data.venue,
  address: e.data.address || '',
  city: e.data.city,
  isPrivate: e.data.isPrivate || false,
  guestListAvailable: e.data.guestListAvailable || false,
  creativeImage: e.data.creativeImage || '',
  dresscode: e.data.dresscode || '',
  genre: e.data.genre || [],
  hostedBy: e.data.hostedBy || '',
  videoSetBy: e.data.videoSetBy || '',
  description: e.data.description,
  tags: e.data.tags || [],
}));
---

<Layout
  title="Events — DJ VIC Live in Bangalore"
  description="Catch DJ VIC live — view upcoming events, club nights and sets in Bangalore. Click a date to see event details and join the guest list."
  canonical="https://djvicofficial.com/events/"
>
  <Nav />

  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────── -->
    <section id="events-hero">
      <div class="hero-inner">
        <span class="hero-label">Live &amp; In Person</span>
        <h1>Events</h1>
        <p class="hero-sub">Upcoming sets, club nights, and appearances.<br/>Click any highlighted date for event details and guest list.</p>
      </div>
    </section>

    <!-- ── Calendar ──────────────────────────────────── -->
    <section id="calendar-section">
      <div class="cal-container" id="cal-container">

        <!-- Month nav -->
        <div class="cal-header">
          <button class="cal-arrow" id="cal-prev" aria-label="Previous month">&#8592;</button>
          <div class="cal-header-center">
            <span class="cal-month-name" id="cal-month-name"></span>
            <select class="cal-year-select" id="year-select" aria-label="Select year">
              <option value="2025">2025</option>
              <option value="2026">2026</option>
              <option value="2027">2027</option>
            </select>
          </div>
          <button class="cal-arrow" id="cal-next" aria-label="Next month">&#8594;</button>
        </div>

        <!-- Day labels -->
        <div class="cal-day-labels">
          <span>Sun</span><span>Mon</span><span>Tue</span>
          <span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
        </div>

        <!-- Date grid -->
        <div class="cal-grid" id="cal-grid"></div>

      </div>

      <p class="cal-no-events" id="cal-no-events" style="display:none">
        No events this month — check back soon.
      </p>
    </section>

  </main>

  <!-- ── Modal ─────────────────────────────────────── -->
  <div class="modal-overlay" id="event-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-box">
      <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>

      <div id="modal-img-wrap">
        <img src="" alt="" id="modal-img" class="modal-img" width="800" height="800" />
      </div>

      <div class="modal-content">

        <!-- Private state -->
        <div id="modal-private" style="display:none">
          <span class="private-badge">Private Event</span>
          <p class="private-text">This is a private booking — not open to the public.</p>
        </div>

        <!-- Public state -->
        <div id="modal-public">
          <p class="modal-datetime" id="modal-datetime"></p>
          <h2 class="modal-title" id="modal-title"></h2>

          <div id="modal-venue-block">
            <p class="modal-venue" id="modal-venue"></p>
            <p class="modal-address" id="modal-address"></p>
          </div>

          <div id="modal-genre-wrap">
            <span class="field-label" style="display:block;margin-bottom:6px">Genres</span>
            <div class="modal-tags" id="modal-genre"></div>
          </div>

          <div class="modal-field" id="modal-dresscode-wrap">
            <span class="field-label">Dress Code</span>
            <span class="field-value" id="modal-dresscode"></span>
          </div>

          <div class="modal-field" id="modal-lineup-wrap">
            <span class="field-label">Line-up</span>
            <span class="field-value" id="modal-lineup"></span>
          </div>
        </div>

        <div class="modal-divider" id="modal-divider"></div>

        <div id="modal-cta-wrap">
          <a href="#" id="modal-cta" class="modal-cta-btn">Join the Guest List &rarr;</a>
        </div>

      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ eventsData, base }}>
  const MONTHS = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];
  const DAYS_LONG = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const MONTHS_LONG = ['January','February','March','April','May','June',
                       'July','August','September','October','November','December'];

  // Event map: 'YYYY-MM-DD' -> event
  const eventMap = {};
  for (const ev of eventsData) eventMap[ev.date] = ev;

  const today = new Date();
  let currentYear = today.getFullYear();
  let currentMonth = today.getMonth();

  const yearSelect = document.getElementById('year-select');
  yearSelect.value = currentYear;

  function pad(n) { return String(n).padStart(2, '0'); }

  function renderCalendar(year, month) {
    document.getElementById('cal-month-name').textContent = `${MONTHS[month]}`;
    yearSelect.value = year;

    const firstDay  = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const todayStr  = `${today.getFullYear()}-${pad(today.getMonth()+1)}-${pad(today.getDate())}`;

    const grid = document.getElementById('cal-grid');

    // Trigger slide-in animation on re-render
    grid.style.animation = 'none';
    void grid.offsetWidth;
    grid.style.animation = '';

    grid.innerHTML = '';
    let hasEvents = false;

    // Empty leading cells
    for (let i = 0; i < firstDay; i++) {
      const empty = document.createElement('div');
      empty.className = 'cal-cell cal-cell--empty';
      grid.appendChild(empty);
    }

    // Date cells
    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${year}-${pad(month+1)}-${pad(d)}`;
      const event   = eventMap[dateStr];
      const isToday = dateStr === todayStr;
      const isPast  = dateStr < todayStr;

      const cell = document.createElement('div');
      const cls  = ['cal-cell'];
      if (isToday) cls.push('cal-cell--today');
      if (isPast)  cls.push('cal-cell--past');
      if (event && !event.isPrivate) cls.push('cal-cell--event');
      if (event &&  event.isPrivate) cls.push('cal-cell--private');
      cell.className = cls.join(' ');

      // Date number
      const num = document.createElement('span');
      num.className = 'cal-num';
      num.textContent = d;
      cell.appendChild(num);

      // Event dot (no labels ever)
      if (event) {
        hasEvents = true;
        const dot = document.createElement('span');
        dot.className = event.isPrivate ? 'cal-dot cal-dot--dim' : 'cal-dot';
        cell.appendChild(dot);

        if (!event.isPrivate) {
          cell.setAttribute('tabindex', '0');
          cell.setAttribute('role', 'button');
          cell.setAttribute('aria-label', `${event.title} — ${dateStr}. Press Enter for details.`);
          cell.addEventListener('click', () => openModal(event));
          cell.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(event); }
          });
        }
      }

      grid.appendChild(cell);
    }

    document.getElementById('cal-no-events').style.display = hasEvents ? 'none' : 'block';
  }

  function openModal(event) {
    const modal = document.getElementById('event-modal');

    // Image
    const imgWrap = document.getElementById('modal-img-wrap');
    const img     = document.getElementById('modal-img');
    if (event.creativeImage) {
      img.src = event.creativeImage;
      img.alt = event.title;
      imgWrap.style.display = 'block';
    } else {
      imgWrap.style.display = 'none';
    }

    if (event.isPrivate) {
      document.getElementById('modal-private').style.display = 'block';
      document.getElementById('modal-public').style.display  = 'none';
      document.getElementById('modal-cta-wrap').style.display = 'none';
      document.getElementById('modal-divider').style.display  = 'none';
      document.getElementById('modal-title').textContent = 'Private Event';
    } else {
      document.getElementById('modal-private').style.display = 'none';
      document.getElementById('modal-public').style.display  = 'block';
      document.getElementById('modal-title').textContent = event.title;

      // Date + time line  e.g. "SATURDAY, 25 APRIL 2026  ·  9:00 PM ONWARDS"
      const d = new Date(event.date + 'T00:00:00');
      const dayName  = DAYS_LONG[d.getDay()].toUpperCase();
      const monthName = MONTHS_LONG[d.getMonth()].toUpperCase();
      document.getElementById('modal-datetime').textContent =
        `${dayName}, ${d.getDate()} ${monthName} ${d.getFullYear()}  ·  ${event.time.toUpperCase()}`;

      // Venue
      document.getElementById('modal-venue').textContent = event.venue;
      const addrEl = document.getElementById('modal-address');
      addrEl.textContent  = event.address;
      addrEl.style.display = event.address ? 'block' : 'none';
      document.getElementById('modal-venue-block').style.display = 'block';

      // Genre tags
      const genreWrap    = document.getElementById('modal-genre');
      const genreSection = document.getElementById('modal-genre-wrap');
      genreWrap.innerHTML = '';
      if (event.genre && event.genre.length) {
        event.genre.forEach(g => {
          const span = document.createElement('span');
          span.className   = 'modal-tag';
          span.textContent = g;
          genreWrap.appendChild(span);
        });
        genreSection.style.display = 'block';
        genreWrap.style.display    = 'flex';
      } else {
        genreSection.style.display = 'none';
      }

      // Dress code
      const dcWrap = document.getElementById('modal-dresscode-wrap');
      if (event.dresscode) {
        document.getElementById('modal-dresscode').textContent = event.dresscode;
        dcWrap.style.display = 'flex';
      } else {
        dcWrap.style.display = 'none';
      }

      // Line-up
      const luWrap  = document.getElementById('modal-lineup-wrap');
      const parts   = [];
      if (event.hostedBy)  parts.push(`Hosted by ${event.hostedBy}`);
      if (event.videoSetBy) parts.push(`Video Set by ${event.videoSetBy}`);
      if (parts.length) {
        document.getElementById('modal-lineup').textContent = parts.join('  ·  ');
        luWrap.style.display = 'flex';
      } else {
        luWrap.style.display = 'none';
      }

      // CTA
      const ctaWrap = document.getElementById('modal-cta-wrap');
      const divider = document.getElementById('modal-divider');
      if (event.guestListAvailable) {
        document.getElementById('modal-cta').href = `${base}/events/${event.slug}/`;
        ctaWrap.style.display = 'block';
        divider.style.display = 'block';
      } else {
        ctaWrap.style.display = 'none';
        divider.style.display = 'none';
      }
    }

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    document.getElementById('modal-close').focus();
  }

  function closeModal() {
    document.getElementById('event-modal').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('cal-prev').addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    renderCalendar(currentYear, currentMonth);
  });

  document.getElementById('cal-next').addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    renderCalendar(currentYear, currentMonth);
  });

  yearSelect.addEventListener('change', (e) => {
    currentYear = parseInt(e.target.value);
    renderCalendar(currentYear, currentMonth);
  });

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('event-modal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('event-modal')) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  renderCalendar(currentYear, currentMonth);
</script>

<style is:global>
  /* ── Hero ─────────────────────────────────────────── */
  #events-hero {
    padding: 7rem 2rem 3.5rem;
    text-align: center;
  }
  #events-hero .hero-inner {
    max-width: 640px;
    margin-inline: auto;
  }
  #events-hero .hero-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1.25rem;
  }
  #events-hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(64px, 12vw, 96px);
    color: #e0dccf;
    letter-spacing: 0.04em;
    line-height: 1;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }
  #events-hero .hero-sub {
    font-size: 15px;
    color: #888880;
    line-height: 1.7;
    max-width: 480px;
    margin-inline: auto;
  }

  /* ── Calendar section ─────────────────────────────── */
  #calendar-section {
    padding: 0 1.5rem 5rem;
  }
  #calendar-section .cal-container {
    max-width: 860px;
    margin-inline: auto;
    background: #111111;
    border: 1px solid #1e1e1e;
    border-radius: 8px;
    padding: 40px;
    animation: fadeIn 0.3s ease;
  }

  /* ── Calendar header ──────────────────────────────── */
  #calendar-section .cal-header {
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  #calendar-section .cal-arrow {
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid #1e1e1e;
    color: #c9a84c;
    font-size: 18px;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  #calendar-section .cal-arrow:hover {
    border-color: #c9a84c;
    background: #1a1500;
  }
  #calendar-section .cal-header-center {
    text-align: center;
  }
  #calendar-section .cal-month-name {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    letter-spacing: 0.05em;
    color: #e0dccf;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  #calendar-section .cal-year-select {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: #c9a84c;
    background: #0d0d0d;
    border: 1px solid #2a2a2a;
    padding: 4px 12px;
    border-radius: 4px;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    text-align: center;
    text-align-last: center;
  }

  /* ── Day labels ───────────────────────────────────── */
  #calendar-section .cal-day-labels {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border-bottom: 1px solid #1e1e1e;
    margin-bottom: 0;
  }
  #calendar-section .cal-day-labels span {
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #555550;
    padding: 12px 0;
  }

  /* ── Grid ─────────────────────────────────────────── */
  #cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    animation: slideIn 0.2s ease;
  }

  /* ── Cells — all JS-generated, must be global ──────── */
  #cal-grid .cal-cell {
    min-height: 80px;
    padding: 10px 8px;
    border: 1px solid #0f0f0f;
    position: relative;
    cursor: default;
    vertical-align: top;
    transition: background 0.15s;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  #cal-grid .cal-cell--empty {
    background: #0a0a0a;
    opacity: 0.4;
  }
  #cal-grid .cal-cell--today {
    border-color: #2a2000;
  }
  #cal-grid .cal-cell--event {
    cursor: pointer;
    border-color: #2a2000;
  }
  #cal-grid .cal-cell--event:hover {
    background: #1a1500;
  }

  /* Date number */
  #cal-grid .cal-num {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #555550;
    line-height: 1;
  }
  #cal-grid .cal-cell--today .cal-num {
    color: #e0dccf;
    font-weight: 600;
  }
  #cal-grid .cal-cell--event .cal-num {
    color: #c9a84c;
    font-weight: 700;
  }
  #cal-grid .cal-cell--past .cal-num {
    color: #333330;
  }
  #cal-grid .cal-cell--past.cal-cell--event .cal-num {
    color: #888880;
  }

  /* Event dot */
  #cal-grid .cal-dot {
    display: block;
    width: 6px;
    height: 6px;
    background: #c9a84c;
    border-radius: 50%;
    margin-top: 6px;
  }
  #cal-grid .cal-dot--dim {
    background: #7a6330;
  }

  /* ── No-events message ────────────────────────────── */
  #cal-no-events {
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555550;
    padding: 2rem 0 0;
    max-width: 860px;
    margin-inline: auto;
  }

  /* ── Modal ────────────────────────────────────────── */
  #event-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  #event-modal.open {
    display: flex;
    animation: fadeIn 0.2s ease;
  }
  #event-modal .modal-box {
    position: relative;
    background: #111111;
    border: 1px solid #1e1e1e;
    border-top: 3px solid #c9a84c;
    border-radius: 8px;
    max-width: 520px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 32px 100px rgba(0,0,0,0.9);
    animation: slideUp 0.25s ease;
  }
  #event-modal .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: transparent;
    border: none;
    color: #888880;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    z-index: 10;
    padding: 4px 8px;
    transition: color 0.15s;
  }
  #event-modal .modal-close:hover { color: #e0dccf; }
  #event-modal .modal-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px 6px 0 0;
  }
  #event-modal .modal-content {
    padding: 28px;
  }
  #event-modal .modal-datetime {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 8px;
  }
  #event-modal .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 0.04em;
    color: #e0dccf;
    line-height: 1;
    margin-bottom: 16px;
    text-transform: uppercase;
    padding-right: 2rem;
  }
  #event-modal .modal-venue {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #888880;
    margin-bottom: 4px;
  }
  #event-modal .modal-address {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: #555550;
    margin-bottom: 16px;
  }
  #event-modal .modal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }
  #event-modal .modal-tag {
    background: #1a1500;
    border: 1px solid #2a2000;
    color: #c9a84c;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
  }
  #event-modal .modal-field {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 12px;
  }
  #event-modal .field-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c9a84c;
  }
  #event-modal .field-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: #888880;
  }
  #event-modal .modal-divider {
    height: 1px;
    background: #1e1e1e;
    margin: 16px 0;
  }
  #event-modal .modal-cta-btn {
    display: block;
    width: 100%;
    background: #c9a84c;
    color: #060606;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 24px;
    border: none;
    border-radius: 4px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s;
  }
  #event-modal .modal-cta-btn:hover {
    background: #b8923e;
    color: #060606;
  }
  #event-modal .private-badge {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #060606;
    background: #c9a84c;
    padding: 4px 12px;
    border-radius: 2px;
    margin-bottom: 12px;
  }
  #event-modal .private-text {
    font-size: 14px;
    color: #555550;
    line-height: 1.6;
  }

  /* ── Animations ───────────────────────────────────── */
  @keyframes fadeIn  { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes slideIn { from { opacity: 0; transform: translateX(8px); } to { opacity: 1; transform: translateX(0); } }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 640px) {
    #calendar-section .cal-container { padding: 16px; }
    #calendar-section .cal-month-name { font-size: 36px; }
    #calendar-section .cal-arrow { width: 36px; height: 36px; font-size: 15px; }
