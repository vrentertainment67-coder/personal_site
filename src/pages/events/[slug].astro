---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const eventDate = new Date(event.data.date + 'T00:00:00');
const formattedDate = eventDate.toLocaleDateString('en-IN', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});

const formAction = `https://formspree.io/f/${event.data.guestListFormId || 'xbdqanrk'}`;
const formSubject = `Guest List RSVP — ${event.data.title} at ${event.data.venue}`;
const successUrl  = `https://djvicofficial.com/events/${event.id}/?rsvp=success`;
---

<Layout
  title={`${event.data.title} — Guest List | DJ VIC`}
  description={event.data.description}
  canonical={`https://djvicofficial.com/events/${event.id}/`}
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Event",
      "name": event.data.title,
      "startDate": event.data.date,
      "location": {
        "@type": "Place",
        "name": event.data.venue,
        "address": event.data.address || event.data.city
      },
      "description": event.data.description,
      "organizer": { "@id": "https://djvicofficial.com/#person" }
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",            "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Events",          "item": "https://djvicofficial.com/events/" },
        { "@type": "ListItem", "position": 3, "name": event.data.title,  "item": `https://djvicofficial.com/events/${event.id}/` }
      ]
    }
  ]}
>
  <Nav />

  <main id="main-content">

    <article id="event-page">

      {event.data.creativeImage && (
        <div class="event-hero-img">
          <img
            src={event.data.creativeImage}
            alt={`Event flyer — ${event.data.title} at ${event.data.venue}`}
            class="event-flyer"
            loading="lazy"
            width="800"
            height="800"
          />
        </div>
      )}

      <div class="event-content">

        <a href={`${base}/events/`} class="back-link">&larr; All Events</a>

        <div class="event-meta-row">
          {event.data.tags.map((tag: string) => (
            <span class="event-tag">{tag}</span>
          ))}
        </div>

        <h1>{event.data.title}</h1>

        <div class="event-details">
          <div class="event-detail">
            <span class="detail-icon">&#128197;</span>
            <div>
              <span class="detail-main">{formattedDate}</span>
              <span class="detail-sub">{event.data.time}</span>
            </div>
          </div>
          {!event.data.isPrivate && (
            <div class="event-detail">
              <span class="detail-icon">&#128205;</span>
              <div>
                <span class="detail-main">{event.data.venue}</span>
                {event.data.address && <span class="detail-sub">{event.data.address}</span>}
              </div>
            </div>
          )}
          {event.data.dresscode && (
            <div class="event-detail">
              <span class="detail-icon">&#128084;</span>
              <div>
                <span class="detail-label">Dress Code</span>
                <span class="detail-main">{event.data.dresscode}</span>
              </div>
            </div>
          )}
          {(event.data.hostedBy || event.data.videoSetBy) && (
            <div class="event-detail">
              <span class="detail-icon">&#127925;</span>
              <div>
                {event.data.hostedBy && <span class="detail-main">Hosted by {event.data.hostedBy}</span>}
                {event.data.videoSetBy && <span class="detail-sub">Video Set by {event.data.videoSetBy}</span>}
              </div>
            </div>
          )}
        </div>

        {event.data.genre.length > 0 && (
          <div class="event-genre-tags">
            {event.data.genre.map((g: string) => (
              <span class="genre-tag">{g}</span>
            ))}
          </div>
        )}

        <p class="event-description">{event.data.description}</p>

        {event.data.isPrivate ? (
          <div class="private-notice">
            <span class="private-badge">Private Event</span>
            <p>This event is not open to the public.</p>
          </div>
        ) : event.data.guestListAvailable ? (
          <div class="guestlist-section">
            <div class="guestlist-card">
              <span class="gl-label">Entry</span>
              <h2>Join the Guest List</h2>
              <p>Fill in your details below and we'll confirm your spot closer to the date. Entry is via guestlist only.</p>

              <!-- Success state -->
              <div id="rsvp-success" class="rsvp-success" style="display:none">
                <span class="rsvp-tick">✓</span>
                <p>You're on the list! We'll be in touch closer to the date.</p>
              </div>

              <!-- Form -->
              <form
                class="guestlist-form"
                action={formAction}
                method="POST"
              >
                <input type="hidden" name="_subject" value={formSubject} />
                <input type="hidden" name="_next"    value={successUrl} />
                <input type="hidden" name="event_name"  value={event.data.title} />
                <input type="hidden" name="event_date"  value={formattedDate} />
                <input type="hidden" name="event_venue" value={event.data.venue} />

                <div class="form-row">
                  <div class="form-field">
                    <label for="gl-name">Full Name <span class="req">*</span></label>
                    <input type="text"  id="gl-name"      name="name"      required placeholder="Your name" />
                  </div>
                  <div class="form-field">
                    <label for="gl-phone">Phone Number <span class="req">*</span></label>
                    <input type="tel"   id="gl-phone"     name="phone"     required placeholder="+91 98765 43210" />
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-field">
                    <label for="gl-guests">Number of Guests <span class="req">*</span></label>
                    <select id="gl-guests" name="guests" required>
                      <option value="1">1 — Just me</option>
                      <option value="2">2 people</option>
                      <option value="3">3 people</option>
                      <option value="4">4 people</option>
                      <option value="5+">5+ people</option>
                    </select>
                  </div>
                  <div class="form-field">
                    <label for="gl-instagram">Instagram Handle</label>
                    <input type="text" id="gl-instagram" name="instagram" placeholder="@yourusername" />
                  </div>
                </div>

                <button type="submit" class="cta-btn cta-btn--gold">Request My Spot &rarr;</button>
              </form>

              <p class="gl-note">Questions? Email <a href="mailto:bookings@djvicofficial.com" data-loc="event_page">bookings@djvicofficial.com</a></p>
            </div>
          </div>
        ) : (
          <div class="guestlist-section">
            <a href={`${base}/book/`} class="cta-btn cta-btn--outline">Get in Touch &rarr;</a>
          </div>
        )}

      </div>

    </article>

  </main>

  <Footer />
</Layout>

<script>
  // WhatsApp notification on form submit
  const form = document.querySelector('.guestlist-form');
  if (form) {
    form.addEventListener('submit', function () {
      const name      = document.getElementById('gl-name')?.value      || '';
      const phone     = document.getElementById('gl-phone')?.value     || '';
      const guests    = document.getElementById('gl-guests')?.value    || '1';
      const instagram = document.getElementById('gl-instagram')?.value || 'not provided';
      const eventName  = form.querySelector('[name="event_name"]')?.value  || '';
      const eventDate  = form.querySelector('[name="event_date"]')?.value  || '';
      const eventVenue = form.querySelector('[name="event_venue"]')?.value || '';

      const msg = encodeURIComponent(
        `🎟️ New Guest List RSVP\n\nEvent: ${eventName}\nVenue: ${eventVenue}\nDate: ${eventDate}\n\nName: ${name}\nPhone: ${phone}\nGuests: ${guests}\nInstagram: ${instagram}`
      );

      setTimeout(() => {
        window.open(`https://wa.me/919611711677?text=${msg}`, '_blank');
      }, 1500);
    });
  }

  // Show success state if redirected back with ?rsvp=success
  if (window.location.search.includes('rsvp=success')) {
    const successEl = document.getElementById('rsvp-success');
    const formEl    = document.querySelector('.guestlist-form');
    if (successEl) successEl.style.display = 'block';
    if (formEl)    formEl.style.display    = 'none';
  }
</script>

<style>
  #event-page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 7rem 2rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }

  .event-hero-img {
    position: sticky;
    top: 6rem;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 16px 64px rgba(0,0,0,0.6);
  }

  .event-flyer {
    width: 100%;
    height: auto;
    display: block;
  }

  .event-content {
    padding-top: 1rem;
  }

  .back-link {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--gold); }

  .event-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .event-tag {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 3px 8px;
    border-radius: 2px;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--white);
    margin-bottom: 2rem;
    line-height: 1.05;
  }

  .event-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(201,168,76,0.1);
  }

  .event-detail {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .detail-icon {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .detail-label {
    display: block;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 2px;
  }

  .detail-main {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.4;
  }

  .detail-sub {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    margin-top: 2px;
  }

  .event-genre-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .genre-tag {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 3px 9px;
    border-radius: 2px;
  }

  .event-description {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* Guest list card */
  .guestlist-section {
    margin-top: 1.5rem;
  }

  .guestlist-card {
    background: #111;
    border: 1px solid rgba(201,168,76,0.15);
    border-top: 3px solid var(--gold);
    border-radius: 4px;
    padding: 2rem;
  }

  .gl-label {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 0.5rem;
  }

  .guestlist-card h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .guestlist-card p {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* Form */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .req { color: var(--gold); }

  .form-field input,
  .form-field select {
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.875rem;
    padding: 0.65rem 0.85rem;
    border-radius: 3px;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  .form-field input::placeholder { color: rgba(255,255,255,0.2); }

  .form-field input:focus,
  .form-field select:focus {
    border-color: rgba(201,168,76,0.5);
  }

  .form-field select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .guestlist-form .cta-btn--gold {
    margin-top: 0.5rem;
  }

  /* RSVP success */
  .rsvp-success {
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .rsvp-tick {
    font-size: 1.2rem;
    color: var(--gold);
    flex-shrink: 0;
    line-height: 1.6;
  }

  .rsvp-success p {
    color: rgba(255,255,255,0.75) !important;
    margin-bottom: 0 !important;
    font-size: 0.9rem !important;
  }

  .gl-note {
    margin-top: 1rem;
    font-size: 0.75rem !important;
    color: rgba(255,255,255,0.3) !important;
    margin-bottom: 0 !important;
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .gl-note a {
    color: rgba(255,255,255,0.4);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .gl-note a:hover { color: var(--gold); }

  /* Private notice */
  .private-notice {
    margin-top: 1.5rem;
  }
  .private-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #000;
    background: var(--gold);
    padding: 3px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .private-notice p {
    color: rgba(255,255,255,0.4);
    font-size: 0.9rem;
  }

  /* CTA buttons */
  .cta-btn {
    display: inline-block;
    padding: 0.8rem 1.75rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border: 1px solid transparent;
  }
  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border-color: var(--gold);
    width: 100%;
    text-align: center;
  }
  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }
  .cta-btn--outline {
    background: transparent;
    color: var(--white);
    border-color: rgba(255,255,255,0.3);
  }
  .cta-btn--outline:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* No image: full-width single column */
  @media (max-width: 768px) {
    #event-page {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-inline: 1.25rem;
    }
    .event-hero-img { position: static; }
  }
</style>
