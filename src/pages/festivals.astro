---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Festival & Live Show DJ India | DJ VIC"
  description="Book DJ VIC for festivals, open-air events, and large-format live shows across India. 18 countries, 1400+ performances. High-energy sets built for big stages."
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Festival DJ India",
      "provider": { "@id": "https://djvicofficial.com/#business" },
      "description": "Large-format festival and live show DJ bookings across India. High-energy open-format sets for open-air events and stages.",
      "areaServed": "India"
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",      "item": "https://djvicofficial.com/" },
        { "@type": "ListItem", "position": 2, "name": "Festivals", "item": "https://djvicofficial.com/festivals/" }
      ]
    }
  ]}
>
  <Nav />
  <main id="main-content">

    <section id="festivals-hero" class="hero-bg">
      <div class="section-label">Festivals & Live Shows</div>
      <h1>Festival &amp; Live Show DJ India</h1>
      <p class="tagline">Built for Big Stages</p>
      <p>18 countries. 1400+ performances. 19+ years reading rooms from intimate clubs to open-air stages.</p>
      <a href={`${base}/book/`} class="cta-btn cta-btn--gold">Book for Your Festival &rarr;</a>
    </section>

    <section id="festivals-stats">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-num">18</span>
          <span class="stat-label">Countries</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">1400+</span>
          <span class="stat-label">Performances</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">19+</span>
          <span class="stat-label">Years</span>
        </div>
      </div>
    </section>

    <section id="festivals-about">
      <div class="section-label">Large Format</div>
      <h2>A Different Kind of Set</h2>
      <p class="section-sub">
        A festival set is a different beast. The crowd is bigger, the energy ceiling is higher,
        and the window to make an impression is shorter. VIC has performed across India and
        internationally — he knows how to open a stage, build a room, and close on a moment.
      </p>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-label">Music Festivals</span>
          <p>Multi-stage festivals and large outdoor events — open-format sets calibrated for maximum floor impact.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">Open-Air Events</span>
          <p>Rooftop events, outdoor venues, and open-air stages — DJ VIC brings the energy regardless of the format.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">New Year's Eve</span>
          <p>NYE is the highest-stakes night of the year. DJ VIC has headlined NYE events across India.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">College Fests</span>
          <p>High-energy campus performances built around young crowds — commercial, Bollywood, hip-hop, and EDM.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">Brand Festivals</span>
          <p>Brand-led festival activations where music is central to the experience — DJ sets that fit the identity.</p>
        </div>
        <div class="feature-item">
          <span class="feature-label">City Events</span>
          <p>Public events, city celebrations, and large-format civic experiences where the stage demands presence.</p>
        </div>
      </div>
    </section>

    <section id="festivals-av" class="section-alt">
      <div class="section-label">Signature Format</div>
      <h2>Audio Visual Sets for Festival Stages</h2>
      <p class="section-sub">
        DJ VIC's signature audio-visual format — original music synced with custom visuals — is built for
        festival and large-format stages where the experience needs to be total. Music and visuals composed
        together as a single performance.
      </p>
      <div class="av-card">
        <span class="av-tag">Available Format</span>
        <p>Full AV production rider available on request. DJ VIC works with your technical and production team to deliver a seamless AV performance.</p>
      </div>
    </section>

    <section id="festivals-rider">
      <div class="section-label">Technical</div>
      <h2>Stage &amp; Technical Requirements</h2>
      <p class="section-sub">
        Full tech rider and stage requirements available on request. DJ VIC performs on Pioneer CDJ setups
        and works with your house system or brings his own depending on the format.
      </p>
      <a href="mailto:bookings@djvicofficial.com" class="contact-link">Request tech rider → bookings@djvicofficial.com</a>
    </section>

    <section id="festivals-cta" class="cta-section">
      <h2>Book DJ VIC for Your Festival</h2>
      <p class="section-sub">Available for festival slots, headline sets, and large-format events across India and internationally.</p>
      <a href={`${base}/book/`} class="cta-btn cta-btn--gold">Get in Touch &rarr;</a>
    </section>

    <section id="festivals-links">
      <div class="internal-links">
        <span class="links-label">Also explore</span>
        <a href={`${base}/corporate/`}>Corporate Events &rarr;</a>
        <a href={`${base}/nightlife/`}>Club &amp; Nightlife &rarr;</a>
        <a href={`${base}/remixes/`}>Remixes &rarr;</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  #festivals-hero {
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.88) 30%, rgba(0,0,0,0.5) 65%, rgba(0,0,0,0.2) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.75) 100%),
      url('https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=1600&q=85');
    background-position: center center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
    margin-top: 0;
  }

  .stat-card {
    background: #0d0d0d;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-align: center;
    align-items: center;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .section-label {
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem;
  }

  h2 { color: var(--white); }

  .section-sub {
    color: rgba(255,255,255,0.65); max-width: 680px;
    margin-top: 0.5rem; margin-bottom: 2rem;
  }

  .section-alt { background: rgba(0,0,0,0.25); }

  .feature-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem;
  }

  .feature-item {
    background: #111; border: 1px solid rgba(201,168,76,0.12);
    border-left: 3px solid var(--gold); padding: 1.5rem;
  }

  .feature-label {
    display: block; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem;
  }

  .feature-item p { font-size: 0.875rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin: 0; }

  .av-card {
    background: #111;
    border-left: 3px solid var(--gold);
    border: 1px solid rgba(201,168,76,0.2);
    border-left: 3px solid var(--gold);
    padding: 1.75rem 2rem;
    max-width: 640px;
    margin-top: 1rem;
  }

  .av-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .av-card p {
    color: rgba(255,255,255,0.7);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin: 0;
  }

  .contact-link {
    font-size: 0.85rem;
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid rgba(201,168,76,0.3);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact-link:hover {
    color: var(--gold-light);
    border-color: var(--gold-light);
  }

  .cta-btn {
    display: inline-block; padding: 0.85rem 2rem; font-family: var(--font-body);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
    cursor: pointer; transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px; margin-top: 2rem; text-decoration: none;
  }

  .cta-btn--gold { background: var(--gold); color: #000; border: 1px solid var(--gold); }
  .cta-btn--gold:hover { background: var(--gold-light); color: #000; transform: translateY(-1px); }

  .cta-section {
    text-align: center; background: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(201,168,76,0.1);
  }

  .cta-section h2::before { display: none; }
  .cta-section .section-sub { margin-left: auto; margin-right: auto; text-align: center; }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .links-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .internal-links a {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: color 0.2s;
  }

  .internal-links a:hover { color: var(--gold-light); }

  @media (max-width: 700px) {
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 480px) {
    .feature-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
