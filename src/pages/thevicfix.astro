---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allEpisodes = await getCollection('vicfixEpisodes');
const episodes = allEpisodes.sort((a, b) => {
  if (a.data.season !== b.data.season) return a.data.season - b.data.season;
  return a.data.episode - b.data.episode;
});
---

<Layout
  title="The VIC Fix — India's Nightlife Podcast by DJ VIC | 42 Episodes"
  description="The VIC Fix is a long-form podcast by DJ VIC documenting India's nightlife culture. Real conversations with DJs, bartenders, venue founders, and artists. 2 seasons, 42 episodes on YouTube."
  ogTitle="The VIC Fix — India's Nightlife Stories, Unfiltered"
  ogDescription="38+ long-form conversations with the DJs, founders, venue owners, and artists shaping India's nightlife and music culture. Hosted by DJ VIC. Now in Season 2."
  schema={{
    "@context": "https://schema.org",
    "@type": "PodcastSeries",
    "name": "The Vic Fix",
    "description": "India's nightlife and culture podcast hosted by DJ VIC. Unfiltered conversations with DJs, founders, and artists.",
    "url": "https://djvicofficial.com/thevicfix/",
    "author": {
      "@type": "Person",
      "name": "DJ VIC",
      "url": "https://djvicofficial.com"
    },
    "inLanguage": "en-IN",
    "genre": ["Music", "Culture", "Nightlife", "Entertainment"]
  }}
>
  <Nav />

  <main id="main-content">

    <!-- ══════════════════════════════════════════
         1. HERO
    ══════════════════════════════════════════ -->
    <section id="podcast-hero" class="hero-bg">
      <img
        src="/images/vic fix logo2.png"
        alt=""
        aria-hidden="true"
        class="vicfix-logo"
      />
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="hero-badge">Season 2 — Now Live</span>
        </div>
        <h1>The VIC Fix</h1>
        <p class="tagline">Real Stories. Real Culture. Real Nightlife.</p>
        <p>
          A long-form podcast documenting India's nightlife culture — unfiltered
          conversations with DJs, artists, founders, and creative leaders.
        </p>
        <div class="hero-actions">
          <a href="https://www.youtube.com/@thedjvicofficial" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--gold">
            Watch on YouTube &rarr;
          </a>
          <a href="https://www.instagram.com/thevicfix" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--outline">
            @thevicfix
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         2. FILTERS + EPISODE GRID
    ══════════════════════════════════════════ -->
    <section id="episode-listing">
      <div class="listing-inner">

        <!-- Filter bar -->
        <div class="filter-bar">
          <div class="filter-row filter-seasons">
            <button class="season-btn active" data-season="all">All Seasons</button>
            <button class="season-btn" data-season="1">Season 1</button>
            <button class="season-btn" data-season="2">Season 2</button>
          </div>
          <div class="filter-row filter-cats">
            <button class="cat-btn active" data-category="all">All</button>
            <button class="cat-btn" data-category="behind-the-decks">Behind the Decks</button>
            <button class="cat-btn" data-category="room-makers">The Room Makers</button>
            <button class="cat-btn" data-category="architects">The Architects</button>
            <button class="cat-btn" data-category="other-side-of-the-bar">Other Side of the Bar</button>
            <button class="cat-btn" data-category="bigger-picture">The Bigger Picture</button>
          </div>
        </div>

        <p class="episode-count">Showing {episodes.length} episodes</p>

        <!-- Episode grid -->
        <div class="episodes-grid" id="episodes-grid">
          {episodes.map((ep) => {
            const ytThumb = `https://img.youtube.com/vi/${ep.data.youtubeId}/maxresdefault.jpg`;
            const imgSrc = ep.data.guestPhoto ? ep.data.guestPhoto : ytThumb;
            return (
              <a
                href={`/thevicfix/${ep.id}/`}
                class="episode-card"
                data-category={ep.data.category}
                data-season={String(ep.data.season)}
              >
                <div class="card-thumb">
                  <img
                    src={imgSrc}
                    alt={ep.data.guestName}
                    loading="lazy"
                    onerror={`this.src='https://img.youtube.com/vi/${ep.data.youtubeId}/hqdefault.jpg'`}
                  />
                  <span class="season-badge">S{ep.data.season} &middot; E{ep.data.episode}</span>
                  <span class="category-tag">{ep.data.categoryLabel}</span>
                </div>
                <div class="card-body">
                  <h3>{ep.data.guestName}</h3>
                  <p class="guest-title-ep">{ep.data.guestTitle}</p>
                  <p class="ep-tagline">{ep.data.tagline}</p>
                  <span class="watch-cta">Watch Episode &rarr;</span>
                </div>
              </a>
            );
          })}
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         3. ABOUT THE SHOW
    ══════════════════════════════════════════ -->
    <section id="podcast-about">
      <div class="section-label">About the Show</div>
      <h2>Beyond the Music</h2>
      <p class="section-sub">
        Hosted by DJ VIC — nearly two decades in nightlife across 18 countries — The VIC
        Fix goes beyond the music to document the people, places, and moments that shaped
        India's after-dark culture. DJs, bartenders, venue founders, promoters, artists:
        the ones who built the scene, told in their own words.
      </p>
      <div class="about-stats">
        <div class="stat-item">
          <span class="stat-num">2</span>
          <span class="stat-label">Seasons</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">42<span class="stat-plus">+</span></span>
          <span class="stat-label">Episodes</span>
        </div>
        <div class="stat-item">
          <span class="stat-num">19<span class="stat-plus">+</span></span>
          <span class="stat-label">Years in Nightlife</span>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         4. WHERE TO WATCH
    ══════════════════════════════════════════ -->
    <section id="podcast-platforms">
      <div class="section-label">Where to Watch</div>
      <h2>Find the VIC Fix</h2>
      <p class="section-sub">Watch full episodes on YouTube, and catch clips and behind-the-scenes on Instagram.</p>
      <div class="platform-grid">
        <a href="https://www.youtube.com/@thedjvicofficial" target="_blank" rel="noopener noreferrer" class="platform-card">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
            <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
          </svg>
          <span class="platform-name">YouTube</span>
          <span class="platform-handle">@thedjvicofficial</span>
        </a>
        <a href="https://www.instagram.com/thevicfix" target="_blank" rel="noopener noreferrer" class="platform-card">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <span class="platform-name">Instagram</span>
          <span class="platform-handle">@thevicfix</span>
        </a>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         5. TESTIMONIALS
    ══════════════════════════════════════════ -->
    <section id="podcast-testimonials" class="section-alt">
      <div class="section-label">What People Are Saying</div>
      <h2>The Response</h2>
      <div class="testimonial-grid">
        <blockquote class="testimonial-card">
          <span class="t-quote">&ldquo;</span>
          <p class="t-body">Thanks bro for bringing these podcast sessions. This is exactly the kind of content the nightlife scene here needed.</p>
          <footer class="t-footer">
            <strong class="t-name">Asad</strong>
            <span class="t-role">Viewer</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <span class="t-quote">&ldquo;</span>
          <p class="t-body">Real, unfiltered, no fluff. The VIC Fix captures the actual story of Bangalore nightlife — something no one else has documented like this.</p>
          <footer class="t-footer">
            <strong class="t-name">Community Response</strong>
            <span class="t-role">Viewers &amp; Listeners</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <span class="t-quote">&ldquo;</span>
          <p class="t-body">The natural flow and unbiased storytelling is what sets this apart. It covers venues, artists, and the evolution of the industry honestly.</p>
          <footer class="t-footer">
            <strong class="t-name">Listener Review</strong>
            <span class="t-role">Season 1</span>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         6. BE A GUEST FORM
    ══════════════════════════════════════════ -->
    <span id="apply"></span>
    <section id="podcast-collab">
      <div class="guest-layout">

        <!-- Left: context -->
        <div class="guest-left">
          <div class="section-label">Be a Guest</div>
          <h2>Want to Be on The VIC Fix?</h2>
          <p class="guest-intro">
            If you're a DJ, artist, venue founder, bartender, promoter, or anyone who
            has shaped India's nightlife culture — this show is for you.
          </p>
          <ul class="guest-criteria">
            <li>You've got a story worth telling</li>
            <li>You're connected to music, nightlife, or culture</li>
            <li>You're based in India or have an India connection</li>
            <li>You can commit to a long-form conversation</li>
          </ul>
          <p class="guest-note">
            All submissions are reviewed personally. If there's a fit, you'll hear back
            within a week.
          </p>
        </div>

        <!-- Right: form -->
        <div class="guest-right">
          <form
            class="guest-form"
            action="https://formspree.io/f/mzdkgvpq"
            method="POST"
          >
            <input type="hidden" name="_subject" value="New Guest Application — The VIC Fix" />
            <input type="hidden" name="_next" value="https://djvicofficial.com/thanks/?from=vicfix" />
            <input type="text" name="_gotcha" style="display:none" />
            <div class="form-row">
              <div class="form-group">
                <label for="guest-name">Full Name <span class="required">*</span></label>
                <input type="text" id="guest-name" name="name" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="guest-email">Email <span class="required">*</span></label>
                <input type="email" id="guest-email" name="email" placeholder="your@email.com" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="guest-phone">Phone / WhatsApp</label>
                <input type="tel" id="guest-phone" name="phone" placeholder="+91 98765 43210" />
              </div>
              <div class="form-group">
                <label for="guest-instagram">Instagram Handle</label>
                <input type="text" id="guest-instagram" name="instagram" placeholder="@yourhandle" />
              </div>
            </div>

            <div class="form-group">
              <label for="guest-role">What do you do? <span class="required">*</span></label>
              <select id="guest-role" name="role" required>
                <option value="" disabled selected>Select your background</option>
                <option value="DJ">DJ / Producer</option>
                <option value="Artist">Artist / Musician</option>
                <option value="Venue">Venue Owner / Operator</option>
                <option value="Promoter">Promoter / Event Organiser</option>
                <option value="Bartender">Bartender / Mixologist</option>
                <option value="Brand">Brand / Creative Director</option>
                <option value="Other">Other (tell us below)</option>
              </select>
            </div>

            <div class="form-group">
              <label for="guest-story">Your Story <span class="required">*</span></label>
              <textarea
                id="guest-story"
                name="story"
                rows="5"
                placeholder="Tell us who you are, what you've been part of, and why your story belongs on The VIC Fix..."
                required
              ></textarea>
            </div>

            <button type="submit" class="form-submit">
              Send My Story &rarr;
            </button>
          </form>
        </div>

      </div>
    </section>

  </main>

  <Footer />

<script>
  // ── Filter logic ──────────────────────────────────────
  const cards = document.querySelectorAll('.episode-card');
  const countEl = document.querySelector('.episode-count');

  function updateFilters() {
    const activeSeasonBtn = document.querySelector('.season-btn.active');
    const activeCatBtn = document.querySelector('.cat-btn.active');
    const activeSeason = activeSeasonBtn ? activeSeasonBtn.dataset.season : 'all';
    const activeCategory = activeCatBtn ? activeCatBtn.dataset.category : 'all';
    let visible = 0;
    cards.forEach(card => {
      const matchSeason = activeSeason === 'all' || card.dataset.season === activeSeason;
      const matchCat = activeCategory === 'all' || card.dataset.category === activeCategory;
      const show = matchSeason && matchCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countEl) {
      countEl.textContent = `Showing ${visible} episode${visible !== 1 ? 's' : ''}`;
    }
  }

  document.querySelectorAll('.season-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.season-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      updateFilters();
    });
  });

  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      updateFilters();
    });
  });

  updateFilters();
</script>

<script>
  // ── WA notification on guest form submit ──────────────
  const guestForm = document.querySelector('form[action*="mzdkgvpq"]');
  if (guestForm) {
    guestForm.addEventListener('submit', function () {
      const name = document.getElementById('guest-name')?.value || '';
      const role = document.getElementById('guest-role')?.value || '';
      const msg = encodeURIComponent(
        `🎙️ New VIC Fix Guest Application\n\nName: ${name}\nRole: ${role}\n\n(Full details sent to email)`
      );
      setTimeout(() => {
        window.open(`https://wa.me/919611711677?text=${msg}`, '_blank');
      }, 1000);
    });
  }
</script>

</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  #podcast-hero {
    position: relative;
    overflow: hidden;
    background-image:
      linear-gradient(to right, rgba(0,0,0,0.9) 30%, rgba(0,0,0,0.55) 70%, rgba(0,0,0,0.3) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.85) 100%),
      url('https://hosting.renderforestsites.com/19480377/1066059/media/e94568f5bfc73623b03fccac9a9c7a5d.jpg');
    background-position: center center;
  }

  .vicfix-logo {
    position: absolute;
    right: -3rem;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(320px, 48vw, 600px);
    height: auto;
    opacity: 0.07;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    margin-bottom: 1rem;
  }

  .hero-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #000;
    background: var(--gold);
    padding: 0.3rem 0.85rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  /* ─── CTA Buttons ──────────────────────────────── */
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, transform 0.15s;
    border-radius: 2px;
  }
  .cta-btn--gold {
    background: var(--gold);
    color: #000;
    border: 1px solid var(--gold);
  }
  .cta-btn--gold:hover {
    background: var(--gold-light);
    color: #000;
    transform: translateY(-1px);
  }
  .cta-btn--outline {
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
  }
  .cta-btn--outline:hover {
    background: rgba(201,168,76,0.1);
    transform: translateY(-1px);
  }

  /* ─── Episode Listing Section ─────────────────── */
  #episode-listing {
    background: #050505;
    max-width: 100%;
    padding: 0;
    border-top: 1px solid #111;
    border-bottom: 1px solid #111;
  }

  .listing-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 4rem 2.5rem 5rem;
  }

  /* ─── Filter bar ──────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .season-btn,
  .cat-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.5);
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    border-radius: 2px;
  }

  .season-btn:hover,
  .cat-btn:hover {
    border-color: rgba(201,168,76,0.4);
    color: var(--gold);
  }

  .season-btn.active,
  .cat-btn.active {
    background: var(--gold);
    border-color: var(--gold);
    color: #000;
  }

  .episode-count {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 2rem;
  }

  /* ─── Episodes grid ───────────────────────────── */
  .episodes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .episode-card {
    display: flex;
    flex-direction: column;
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.06);
    text-decoration: none;
    color: var(--white);
    transition: border-color 0.25s, background 0.25s;
    overflow: hidden;
    position: relative;
  }

  .episode-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .episode-card:hover {
    border-color: rgba(201,168,76,0.25);
    background: #131313;
  }

  .episode-card:hover::before {
    transform: scaleX(1);
  }

  .card-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .episode-card:hover .card-thumb img {
    transform: scale(1.04);
  }

  .season-badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    font-size: 0.48rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #000;
    background: var(--gold);
    padding: 0.2rem 0.55rem;
  }

  .category-tag {
    position: absolute;
    bottom: 0.6rem;
    left: 0.6rem;
    font-size: 0.45rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.72);
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255,255,255,0.12);
  }

  .card-body {
    padding: 1.1rem 1.1rem 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .card-body h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.25;
    margin: 0;
  }

  .guest-title-ep {
    font-size: 0.7rem;
    color: var(--gold);
    letter-spacing: 0.03em;
    margin: 0;
    opacity: 0.85;
  }

